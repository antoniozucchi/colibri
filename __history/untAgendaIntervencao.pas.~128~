procedure TFrmAgendaIntervencao.StringGridDrawCell(Sender: TObject; ACol,
  ARow: Integer; Rect: TRect; State: TGridDrawState);
var
  R: TRect;
begin
  R := Rect;
  R.Left := R.Left - 4;
  if (ARow = 0) then
  begin
    try
      StringGrid.Canvas.Brush.Color := clGray;
      StringGrid.Canvas.Font.Style := [];
      StringGrid.Canvas.FillRect(R);
      DrawText(StringGrid.Canvas.Handle, PChar(StringGrid.Cells[ACol, ARow]),
      -1, R, DT_Center);
    except
    end;
  end;
  if (booComparar)AND(ARow > 0) then
  begin
    if (ACol = 5)AND(StringGrid.Cells[ACol,ARow] = 'NP') then
    begin
      try
        StringGrid.Canvas.Brush.Color := clRed;
        StringGrid.Canvas.Font.Style := [];
        StringGrid.Canvas.FillRect(R);
        DrawText(StringGrid.Canvas.Handle, PChar(StringGrid.Cells[ACol, ARow]),
        -1, R, DT_Center);
      except
      end;
    end
    else if (ACol = 6) then
    begin
      try
        if StrToInt(StringGrid.Cells[ACol,ARow]) = 0 then
        begin
          StringGrid.Canvas.Brush.Color := clLime;
          StringGrid.Canvas.Font.Style := [];
          StringGrid.Canvas.FillRect(R);
          DrawText(StringGrid.Canvas.Handle, PChar(StringGrid.Cells[ACol, ARow]),
          -1, R, DT_Center);
        end
        else if StrToInt(StringGrid.Cells[ACol,ARow]) < 0 then
        begin
          StringGrid.Canvas.Brush.Color := clYellow;
          StringGrid.Canvas.Font.Style := [];
          StringGrid.Canvas.FillRect(R);
          DrawText(StringGrid.Canvas.Handle, PChar(StringGrid.Cells[ACol, ARow]),
          -1, R, DT_Center);
        end
        else if StrToInt(StringGrid.Cells[ACol,ARow]) > 0 then
        begin
          StringGrid.Canvas.Brush.Color := clAqua;
          StringGrid.Canvas.Font.Style := [];
          StringGrid.Canvas.FillRect(R);
          DrawText(StringGrid.Canvas.Handle, PChar(StringGrid.Cells[ACol, ARow]),
          -1, R, DT_Center);
        end;
      except
        StringGrid.Canvas.Brush.Color := clRed;
        StringGrid.Canvas.Font.Style := [];
        StringGrid.Canvas.FillRect(R);
        DrawText(StringGrid.Canvas.Handle, PChar(StringGrid.Cells[ACol, ARow]),
        -1, R, DT_Center);
      end;
    end;
  end;
end;

procedure TFrmAgendaIntervencao.StringGridFixedCellClick(Sender: TObject; ACol,
  ARow: Integer);
begin
  FrmPrincipal.clasifica(StringGrid,ACol,true);
