procedure TFrmImportacao.actCarteiraTipoEtapaServicoExecute(Sender: TObject);
  var
    txtTipoEtapaServicoOP,txtTipoEtapaServicoOM,
    ImportadoPor,ComputadorImportacao,ImpactoFalha: String;
    DataImportacao: TDateTime;
begin
  ImportadoPor:= FrmPrincipal.logChave;
  DataImportacao:= now;
  ComputadorImportacao:= FrmPrincipal.logMaquina;
  FrmDataModule.ADOQueryAnalisarTipoEtapaServico.Active:= false;
  FrmDataModule.ADOQueryAnalisarTipoEtapaServico.Active:= true;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.
  ADOQueryAnalisarTipoEtapaServico.RecordCount,
  'Analisando "Tipo de Etapa de Serviço"...');
  actInterromper.Enabled:= true;
  FrmDataModule.ADOQueryAnalisarTipoEtapaServico.First;
  while not FrmDataModule.ADOQueryAnalisarTipoEtapaServico.Eof do
  begin
    //Interromper Processo
    Application.ProcessMessages;
    if Interromper and (Application.MessageBox(PChar('Deseja realmente cancelar o processo?'),
    '.::ATENÇĂO::.',36) = 6) then
    begin
      Interromper := False;
      break;
    end
    else
      Interromper := False;
    //=========================================
    txtTipoEtapaServicoOP:= FrmPrincipal.verificaTipoEtapaServico(FrmDataModule.
    DataSourceAnalisarTipoEtapaServico.DataSet.FieldByName('CentroTrabalhoOP').asString);
    txtTipoEtapaServicoOM:= FrmPrincipal.verificaTipoEtapaServico(FrmDataModule.
    DataSourceAnalisarTipoEtapaServico.DataSet.FieldByName('CentroTrabalhoOM').asString);
    ImpactoFalha:= FrmPrincipal.verificaImpactoFalha(FrmDataModule.
    DataSourceAnalisarTipoEtapaServico.DataSet.FieldByName('LocalInstalacao').asString);
    //=========================================
    FrmDataModule.ADOQueryAnalisarTipoEtapaServico.Edit;
    FrmDataModule.DataSourceAnalisarTipoEtapaServico.DataSet.
    FieldByName('txtTipoEtapaServicoOP').asString:= txtTipoEtapaServicoOP;
    FrmDataModule.DataSourceAnalisarTipoEtapaServico.DataSet.
    FieldByName('txtTipoEtapaServicoOM').asString:= txtTipoEtapaServicoOM;
    FrmDataModule.DataSourceAnalisarTipoEtapaServico.DataSet.
    FieldByName('TipoOperacao').AsString :=
    FrmPrincipal.verificaOperacao(FrmDataModule.DataSourceAnalisarTipoEtapaServico.DataSet.
    FieldByName('StatusSistemaOP').asString);
    FrmDataModule.DataSourceAnalisarTipoEtapaServico.DataSet.
    FieldByName('ImpactoFalha').AsString := ImpactoFalha;
    if ImpactoFalha = '6' then
      FrmDataModule.DataSourceAnalisarTipoEtapaServico.DataSet.
      FieldByName('BooleanCritico').AsBoolean := true;
    //Usuário
    FrmDataModule.DataSourceAnalisarTipoEtapaServico.DataSet.
    FieldByName('ImportadoPor').asString:= ImportadoPor;
    FrmDataModule.DataSourceAnalisarTipoEtapaServico.DataSet.
    FieldByName('DataImportacao').AsDateTime:= DataImportacao;
    FrmDataModule.DataSourceAnalisarTipoEtapaServico.DataSet.
    FieldByName('ComputadorImportacao').AsString:= ComputadorImportacao;
    FrmDataModule.ADOQueryAnalisarTipoEtapaServico.Post;
    FrmDataModule.ADOQueryAnalisarTipoEtapaServico.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmPrincipal.ProgressBarAtualizar;
  actInterromper.Enabled:= false;
  //FrmPrincipal.actUploadDBMemoria.Execute;
  actLimparFiltros.Execute;
end;

procedure TFrmImportacao.actCopiarMemoriaLocalExecute(Sender: TObject);
  var
    Caminho_Copia,enderecoMemoria: String;
begin
  FrmDataModule.ADOQueryColibri.Active:= false;
  FrmDataModule.ADOQueryColibri.Active:= true;
  enderecoMemoria := FrmPrincipal.Caption;
  enderecoMemoria:= ExtractFilePath(enderecoMemoria)+'\dbMemoria.mdb';
  Caminho_Copia := ExtractFilePath(Application.ExeName) + 'TEMPMemoria.mdb';
  DeleteFile(Caminho_Copia);
  CopyFile(PChar(enderecoMemoria), PChar(Caminho_Copia), false);
  FrmPrincipal.conectarBDDireto(Caminho_Copia,FrmDataModule.ADOConnectionMemoria);
end;

