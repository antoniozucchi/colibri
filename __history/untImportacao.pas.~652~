procedure TFrmImportacao.PlataformaTabela(Tabela,Fonte: String;booleanRegistro: Boolean);
  var
    Plataforma,LocalInstalacaoSAP: String;
begin
  FrmDataModule.ADOQueryConsultaPlataforma.Active:= false;
  FrmDataModule.ADOQueryConsultaPlataforma.Active:= true;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.
  ADOQueryConsultaPlataforma.RecordCount,
  'Analisando "Instalaçăo"...');
  FrmDataModule.ADOQueryConsultaPlataforma.First;
  actInterromper.Enabled:= true;
  while not FrmDataModule.ADOQueryConsultaPlataforma.Eof do
  begin
    //Interromper Processo
    Application.ProcessMessages;
    if Interromper and (Application.MessageBox(PChar('Deseja realmente cancelar o processo?'),
    '.::ATENÇĂO::.',36) = 6) then
    begin
      Interromper := False;
      break;
    end
    else
      Interromper := False;
    //=========================================
    LocalInstalacaoSAP:= FrmDataModule.DataSourceConsultaPlataforma.
    DataSet.FieldByName('LocalInstalacaoSAP').asString;
    Plataforma:= FrmDataModule.DataSourceConsultaPlataforma.
    DataSet.FieldByName('Plataforma').asString;
    preenchePlataforma_LocalInstalacaoSAP(Plataforma,
    LocalInstalacaoSAP,Tabela,Fonte,booleanRegistro);
    //================================================
    FrmDataModule.ADOQueryConsultaPlataforma.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmDataModule.ADOQueryConsultaPlataforma.First;
  FrmPrincipal.ProgressBarAtualizar;
  actInterromper.Enabled:= false;
end;

procedure TFrmImportacao.preenchePlataforma_LocalInstalacaoSAP(Plataforma,
  LocalInstalacaoConsulta,Tabela,Fonte: String;booleanRegistro: Boolean);
begin
  if ((LocalInstalacaoConsulta = '')or(LocalInstalacaoConsulta = '0')) then
    LocalInstalacaoConsulta:= '999999999';
  try
    if Fonte = 'Consulta' then
    begin
      FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
      FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Clear;
      FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Add(
      'SELECT '+tabela+'.* FROM '+tabela+
      ' WHERE (LocalInstalacao LIKE '+QuotedStr('%'+LocalInstalacaoConsulta+'%')+');');
      FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
      FrmDataModule.ADOQueryTemporarioDBConsulta1.Active:= true;
      //Preencher Plataforma na consulta da carteira
      FrmDataModule.ADOQueryTemporarioDBConsulta1.First;
      while not FrmDataModule.ADOQueryTemporarioDBConsulta1.Eof do
      begin
        FrmDataModule.ADOQueryTemporarioDBConsulta1.Edit;
        FrmDataModule.DataSourceTemporarioDBConsulta1.
        DataSet.FieldByName('Plataforma').AsString:= Plataforma;
        FrmDataModule.ADOQueryTemporarioDBConsulta1.Next;
      end;
    end
    else if Fonte = 'Memoria' then
    begin
      FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
      FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
      FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(
      'SELECT '+tabela+'.* FROM '+tabela+
      ' WHERE (LocalInstalacao LIKE '+QuotedStr('%'+LocalInstalacaoConsulta+'%')+');');
      FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
      FrmDataModule.ADOQueryTemporarioDBMemoria.Active:= true;
      //Preencher Plataforma na consulta da carteira
      FrmDataModule.ADOQueryTemporarioDBMemoria.First;
      while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
      begin
        FrmDataModule.ADOQueryTemporarioDBMemoria.Edit;
        FrmDataModule.DataSourceTemporarioDBMemoria.
        DataSet.FieldByName('Plataforma').AsString:= Plataforma;
        if booleanRegistro then
        begin
          //Usuário
          FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
          FieldByName('ImportadoPor').asString:= FrmPrincipal.logChave;
          FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
          FieldByName('DataImportacao').AsDateTime:= now;
          FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
          FieldByName('ComputadorImportacao').AsString:= FrmPrincipal.logMaquina;
        end;
        FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
      end;
    end;
  except

  end;
end;

