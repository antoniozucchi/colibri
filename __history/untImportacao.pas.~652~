procedure TFrmImportacao.actTextoLongoOMExecute(Sender: TObject);
var
  ExcelOM,SheetOM: Variant;
  i,matrizLinhaOM,ARow: Integer;
begin
  try
    try
      ARow:= 4;
      try
        ExcelOM := CreateOleObject('Excel.Application');
      except
        MessageBox(0,'Verifique se o Microsoft Office Excel esta instalado na sua máquina.',
        'Excel', MB_ICONERROR);
      end;
      // Abrir o arquivo
      try
        ExcelOM.Workbooks.Open(edtEnderecoTextoLongoOM.Text);
      except
        MessageBox(0,'Arquivo năo encontrado, verifique o endereço do arquivo!',
        'Excel', MB_ICONERROR);
      end;
      // Abrir a primeira planilha do arquivo
      SheetOM := ExcelOM.WorkSheets[1];
      //Excluir todos os registros atuais
      FrmPrincipal.deleteQueryRapido(
      FrmDataModule.ADOQueryImportarTextoLongoCarteira,'tblTextoLongoCarteira');
      //Verificar a ultima Linha
      matrizLinhaOM:= (SheetOM.Cells.SpecialCells(11).Row);
      // Inicializar ProgressBar
      FrmPrincipal.ProgressBarIncializa(matrizLinhaOM,'Texto Longo OM...');
      //Importar texto longo da planilha de OM
      actInterromper.Enabled:= true;
      for i := ARow to matrizLinhaOM do
      begin
        Application.ProcessMessages;
        if Interromper and (Application.MessageBox(PChar('Deseja realmente cancelar o processo?'),
        '.::ATENÇĂO::.',36) = 6) then
        begin
          Interromper := False;
          break;
        end
        else
          Interromper := False;
        try
          // Inserir novo registro na tabela de dados
          FrmDataModule.ADOQueryImportarTextoLongoCarteira.Insert;
          // Preencher as colunas do registro na tabela de dados
          FrmDataModule.DataSourceImportarTextoLongoCarteira.DataSet.
          FieldByName('OrdemManutencao').AsInteger := ExcelOM.Workbooks[1].Sheets[1].Cells[i,1];
          FrmDataModule.DataSourceImportarTextoLongoCarteira.DataSet.
          FieldByName('TextoLongoCarteira').AsWideString := ExcelOM.Workbooks[1].Sheets[1].Cells[i,2];
          FrmDataModule.ADOQueryImportarTextoLongoCarteira.Post;
        except
        end;
        // Incremento ProgressBar
        FrmPrincipal.ProgressBarIncremento(1);
      end;
       //===================================================
      FrmDataModule.ADOQueryImportarTextoLongoCarteira.First;
      actInterromper.Enabled:= false;
      // Atualizar ProgressBar
      FrmPrincipal.ProgressBarAtualizar;
    finally
      //Fechar Excel OM
      ExcelOM.Application.DisplayAlerts := False;
      ExcelOM.Quit;
      ExcelOM := Unassigned;
      FreeAndNil(ExcelOM);
    end;
  except
    MessageBox(0,'Ocorreu um erro durante a importaçăo e a operaçăo foi cancelada!',
    'Excel', MB_ICONERROR);
    FrmDataModule.ADOQueryImportarTextoLongoCarteira.First;
    FrmDataModule.DataSourceImportarTextoLongoCarteira.Enabled := true;
    // Atualizar ProgressBar
    FrmPrincipal.ProgressBarAtualizar;
    //Fechar Excel OM
    ExcelOM.Application.DisplayAlerts := False;
    ExcelOM.Quit;
    ExcelOM := Unassigned;
    FreeAndNil(ExcelOM);
  end;
end;

