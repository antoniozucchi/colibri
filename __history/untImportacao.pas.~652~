procedure TFrmImportacao.AnalisaTipoEtapaServico_BooleanCritico(DataSource: TDataSource;ADOQuery: TADOQuery;
CentroTrabalho: String; Tratamento: Integer);
  var
    SQLBase,NotaManutencao: String;
begin
  actVetorLocalCritico.Execute;
  //=========================================
  DataSource.Enabled:= false;
  ADOQuery.First;
  FrmPrincipal.ProgressBarIncializa(ADOQuery.RecordCount,
  'Analisando "Tipo de Etapa de Serviço"...');
  actInterromper.Enabled:= true;
  //=========================================
  while not ADOQuery.Eof do
  begin
    //Interromper Processo
    Application.ProcessMessages;
    if Interromper and (Application.MessageBox(PChar('Deseja realmente cancelar o processo?'),
    '.::ATENÇĂO::.',36) = 6) then
    begin
      Interromper := False;
      break;
    end
    else
      Interromper := False;
    //=========================================
    ADOQuery.Edit;
    DataSource.DataSet.FieldByName('txtTipoEtapaServico').asString:= FrmPrincipal.verificaTipoEtapaServico(
    DataSource.DataSet.FieldByName(CentroTrabalho).asString);
    DataSource.DataSet.FieldByName('BooleanCritico').AsBoolean := FrmPrincipal.verificaCritico(
    DataSource.DataSet.FieldByName('LocalInstalacao').asString);
    case Tratamento of
      0://Notas de Manutençăo Fora de Operaçăo
      begin
        //Comentario
        NotaManutencao:= DataSource.DataSet.FieldByName('NotaManutencao').AsString;
        SQLBase:= 'SELECT tblComentarioForaOperacao.* FROM tblComentarioForaOperacao '+
        'WHERE ((NotaManutencao LIKE '+QuotedStr(NotaManutencao)+'));';
        FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
        FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Clear;
        FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Add(SQLBase);
        FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
        if not FrmDataModule.ADOQueryTemporarioDBConsulta1.IsEmpty then
        begin
          DataSource.DataSet.FieldByName('Comentario').AsString:= FrmDataModule.
          ADOQueryTemporarioDBConsulta1.FieldByName('Comentario').AsString;
          DataSource.DataSet.FieldByName('DataComentario').AsDateTime:= FrmDataModule.
          ADOQueryTemporarioDBConsulta1.FieldByName('DataComentario').AsDateTime;
          DataSource.DataSet.FieldByName('ComentarioPor').AsString:= FrmDataModule.
          ADOQueryTemporarioDBConsulta1.FieldByName('ComentarioPor').AsString;
          DataSource.DataSet.FieldByName('ComputadorComentario').AsString:= FrmDataModule.
          ADOQueryTemporarioDBConsulta1.FieldByName('ComputadorComentario').AsString;
        end
        else
        begin
          DataSource.DataSet.FieldByName('Comentario').AsString:= '';
          DataSource.DataSet.FieldByName('DataComentario').AsString:= '';
          DataSource.DataSet.FieldByName('ComentarioPor').AsString:= '';
          DataSource.DataSet.FieldByName('ComputadorComentario').AsString:= '';
        end;
      end;
    end;
    //Usuário
    DataSource.DataSet.FieldByName('ImportadoPor').asString:= FrmPrincipal.logChave;
    DataSource.DataSet.FieldByName('DataImportacao').AsDateTime:= now;
    DataSource.DataSet.FieldByName('ComputadorImportacao').AsString:= FrmPrincipal.logMaquina;
    //================================================
    FrmPrincipal.ProgressBarIncremento(1);
    ADOQuery.Post;
    ADOQuery.Next;
  end;
  ADOQuery.First;
  DataSource.Enabled:= true;
  FrmPrincipal.ProgressBarAtualizar;
  actInterromper.Enabled:= false;
  actLimparFiltros.Execute;
end;

