procedure TFrmImportacao.actNOTA_PadraoExecute(Sender: TObject);
  var
    TAGBusca,SQLString,SQLBase,PlataformaBusca,SQLPlataforma: String;
    PrazoToleravel: Integer;
begin
  FrmDataModule.ADOQueryPadraoLEC.Active:= False;
  FrmDataModule.ADOQueryPadraoLEC.Active:= True;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryPadraoLEC.RecordCount,
  'Analisando Padrăo LEC...');
  FrmDataModule.ADOQueryPadraoLEC.First;
  while not FrmDataModule.ADOQueryPadraoLEC.Eof do
  begin
    TAGBusca:= FrmDataModule.DataSourcePadraoLEC.DataSet.FieldByName('TAGBusca').AsString;
    PlataformaBusca:= FrmDataModule.DataSourcePadraoLEC.DataSet.FieldByName('PlataformaBusca').AsString;
    if TAGBusca <> '' then
    begin
      SQLPlataforma:= '';
      if PlataformaBusca <> 'Todas' then
      begin
       SQLPlataforma:= 'AND'+FrmPrincipal.palavraBusca(SQLPlataforma,'Plataforma','Exato',PlataformaBusca,'AND');
      end;
      SQLString:= FrmPrincipal.palavraBuscaAND('DenominacaoLocalInstalacao',TAGBusca);
      SQLBase:= 'SELECT tblNotaManutencao.* FROM tblNotaManutencao '+
      'WHERE ((TextoBreveNOTA LIKE "FO:%")AND(FimAvaria IS NULL)AND(BooleanCritico = True))AND'+
      SQLString+SQLPlataforma+';';
      FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
      FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
      FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
      FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
      while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
      begin
        try
          PrazoToleravel:= FrmDataModule.DataSourcePadraoLEC.DataSet.FieldByName('PrazoToleravel').AsInteger;
        except
          PrazoToleravel:= 0;
        end;
        FrmDataModule.ADOQueryTemporarioDBMemoria.Edit;
        FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('BooleanSIGM').AsBoolean:= True;
        FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('Salvaguarda').AsString:=
        FrmDataModule.DataSourcePadraoLEC.DataSet.FieldByName('Salvaguarda').AsString;
        FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('AcaoAdotadaIndisponibilidade').AsString:=
        FrmDataModule.DataSourcePadraoLEC.DataSet.FieldByName('AcaoAdotadaIndisponibilidade').AsString;
        FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('PrazoToleravel').AsInteger:= PrazoToleravel;
        if PrazoToleravel = 0 then
          FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('VencimentoAvaria').AsString:= '-'
        else
          FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('VencimentoAvaria').AsString:=
          FormatDateTime('dd/mm/yyyy',IncDay(FrmDataModule.
          DataSourceTemporarioDBMemoria.DataSet.FieldByName('InicioAvaria').AsDateTime,PrazoToleravel));
        FrmDataModule.ADOQueryTemporarioDBMemoria.Post;
        //==================================================================
        FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
      end;
    end;
    //=========================================================================
    FrmDataModule.ADOQueryPadraoLEC.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmPrincipal.ProgressBarAtualizar;
end;

procedure TFrmImportacao.actNOTA_SIGMExecute(Sender: TObject);
  var
    NotaManutencao: Integer;
    SQLBase: String;
begin
  SQLBase:= 'SELECT tblNotaManutencao.* FROM tblNotaManutencao WHERE (BooleanSIGM = True);';
  FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
  FrmDataModule.ADOQueryTemporarioDBMemoria.Open;

  while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
  begin
    NotaManutencao:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('NotaManutencao').AsInteger;
    //Abre pesquisa na tabela SIGM com o numero da Nota de Manutençăo e Grava na Tabela de Notas.
    SQLBase:= 'SELECT tblSIGM.* FROM tblSIGM WHERE (NotaManutencao = "'+IntToStr(NotaManutencao)+'");';
    FrmDataModule.ADOQueryTemporarioDBOperacao.Close;
    FrmDataModule.ADOQueryTemporarioDBOperacao.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBOperacao.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBOperacao.Open;
    //============================================================
    FrmDataModule.ADOQueryTemporarioDBMemoria.Edit;
    FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('CodigoSIGM').AsInteger:=
    FrmDataModule.DataSourceTemporarioDBOperacao.DataSet.FieldByName('idSIGM').AsInteger;
    FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('GIM_FAM').AsString:=
    FrmDataModule.DataSourceTemporarioDBOperacao.DataSet.FieldByName('GIM_FAM').AsString;
    FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('DescricaoGM').AsString:=
    FrmDataModule.DataSourceTemporarioDBOperacao.DataSet.FieldByName('DescricaoGM').AsString;
    FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('PrazoGM').AsString:=
    FrmDataModule.DataSourceTemporarioDBOperacao.DataSet.FieldByName('PrazoGM').AsString;
    FrmDataModule.ADOQueryTemporarioDBMemoria.Post;
    //============================================================
    FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
  end;
end;

