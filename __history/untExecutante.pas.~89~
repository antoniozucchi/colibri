procedure TFrmExecutante.DBGridTipoServicoCellClick(Column: TColumn);
begin
  try
    if (Self.DBGridTipoServico.SelectedField.DataType = ftBoolean)AND
    (Column.Field.FieldName = 'BooleanCarteira') then
    begin
      DBGridTipoServico.Options:=
      [dgTitles,dgIndicator,dgColumnResize,dgColLines,dgRowLines,
      dgTabs,dgAlwaysShowSelection,dgTitleClick,dgTitleHotTrack];
      FrmDataModule.ADOQueryTipoEtapaServico.Edit;
      FrmDataModule.DataSourceTipoEtapaServico.DataSet.
      FieldByName('BooleanCarteira').AsBoolean:= not
      Self.DBGridTipoServico.SelectedField.AsBoolean;
      FrmDataModule.ADOQueryTipoEtapaServico.Post;
    end
    else
      DBGridTipoServico.Options:=
      [dgEditing,dgTitles,dgIndicator,dgColumnResize,dgColLines,dgRowLines,
      dgTabs,dgConfirmDelete,dgCancelOnExit,dgTitleClick,dgTitleHotTrack];
  except

  end;
end;

procedure TFrmExecutante.DBGridTipoServicoDrawColumnCell(Sender: TObject;
  const Rect: TRect; DataCol: Integer; Column: TColumn; State: TGridDrawState);
  Const
    CtrlState : array[Boolean] of Integer = (DFCS_BUTTONCHECK,
    DFCS_BUTTONCHECK or DFCS_CHECKED);
  var
    CheckBoxRectangle : TRect;
begin
  FrmPrincipal.GridZebrado(DBGridTipoServico,ColunasLayoutTipoEtapaServico,State,Rect,DataCol,Column);
  if (Column.Field.FieldName = 'BooleanCarteira') then
  begin
    Self.DBGridTipoServico.Canvas.FillRect(Rect);
    CheckBoxRectangle.Left := Rect.Left + 2;
    CheckBoxRectangle.Right := Rect.Right - 2;
    CheckBoxRectangle.Top := Rect.Top + 2;
    CheckBoxRectangle.Bottom := Rect.Bottom - 2;
    DrawFrameControl(Self.DBGridTipoServico.Canvas.Handle,
    CheckBoxRectangle, DFC_BUTTON,
    CtrlState[Column.Field.AsBoolean]);
  end;
end;

