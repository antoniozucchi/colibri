procedure TFrmConsultaProgramacao.actCarregarDatasExecute(Sender: TObject);
  var
    Programacao: String;
    listaCodigoProgramacao: TStringList;
    i,row,codigoProgramacao,NumLinhas: Integer;
    DataInicial: TDateTime;
begin
  listaCodigoProgramacao:= TStringList.Create;
  listaCodigoProgramacao.delimiter:= ';';
  listaCodigoProgramacao.StrictDelimiter:= true;
  //============================================================================
  NumLinhas:= GanttChart1.AbsoluteRowCount;
  FrmPrincipal.ProgressBarIncializa(NumLinhas,'Atualizando datas de programaçăo no banco de dados...');
  for row := 0 to NumLinhas-1 do
  begin
    Programacao:= listProgramacao[row];
    try
      DataInicial:= StrToDate(corrigirDataGantt(GanttChart1.AbsoluteRow[row].Cells[2].Text));
      //Verificar se a data esta no passado
      if DataInicial >= FrmPrincipal.carregaDataMinima(false) then
      begin
        listaCodigoProgramacao.DelimitedText:= Programacao;
        for I := 0 to listaCodigoProgramacao.Count-1 do
        begin
          codigoProgramacao:= StrToInt(listaCodigoProgramacao[i]);
          alterarDataProgramacao(IncDay(DataInicial,i),codigoProgramacao);
        end;
      end;
    except
    end;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmPrincipal.ProgressBarAtualizar;
  FrmDataModule.ADOQueryProgramacaoDiaria_Consulta.Active:= false;
  FrmDataModule.ADOQueryProgramacaoDiaria_Consulta.Active:= true;
end;

procedure TFrmConsultaProgramacao.actCopiarExecute(Sender: TObject);
  var
    DataProgramacao: String;
    i: Integer;
begin
  case RadioGroupCopiar.ItemIndex of
    0:
    begin
      if ListBoxCopiar.Count <> 0  then
      begin
        for I := 0 to ListBoxCopiar.Count-1 do
        begin
          DataProgramacao:= ListBoxCopiar.Items[i];
          if FrmPrincipal.isData(DataProgramacao) then
            FrmPrincipal.CopiarProgramacao(DataProgramacao,
            FrmDataModule.DataSourceProgramacaoDiaria_Consulta);
        end;
        dataInicio.DateTime:= StrToDate(ListBoxCopiar.Items[0]);
        dataFim.DateTime:= StrToDate(ListBoxCopiar.Items[ListBoxCopiar.Count-1]);
        actProcurar.Execute;
      end
      else
        MessageBox(0,'Nenhuma data selecionda.','Colibri',MB_ICONEXCLAMATION)
    end;
    1:
    begin
      if ListBoxCopiar.Count <> 0  then
      begin
        for I := 0 to ListBoxCopiar.Count-1 do
        begin
          DataProgramacao:= ListBoxCopiar.Items[i];
          if FrmPrincipal.isData(DataProgramacao) then
          begin
            FrmDataModule.ADOQueryInserirProgramacao.Active:= false;
            FrmDataModule.ADOQueryInserirProgramacao.Active:= true;
            FrmDataModule.ADOQueryProgramacaoDiaria_Consulta.First;
            FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryProgramacaoDiaria_Consulta.RecordCount,
            'Copiando...');
            while not FrmDataModule.ADOQueryProgramacaoDiaria_Consulta.Eof do
            begin
              FrmPrincipal.CopiarProgramacao(DataProgramacao,
              FrmDataModule.DataSourceProgramacaoDiaria_Consulta);
              FrmDataModule.ADOQueryProgramacaoDiaria_Consulta.Next;
              FrmPrincipal.ProgressBarIncremento(1);
            end;
          end;
        end;
        dataInicio.DateTime:= StrToDate(ListBoxCopiar.Items[0]);
        dataFim.DateTime:= StrToDate(ListBoxCopiar.Items[ListBoxCopiar.Count-1]);
        FrmPrincipal.ProgressBarAtualizar;
        actProcurar.Execute;
      end
      else
        MessageBox(0,'Nenhuma data selecionda.','Colibri',MB_ICONEXCLAMATION)
    end;
  end;
end;

