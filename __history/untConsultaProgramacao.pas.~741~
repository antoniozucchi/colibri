procedure TFrmConsultaProgramacao.actGraficoPlataformaExecute(Sender: TObject);
  var
    BarSeriesGRF: TBarSeries;
    GrfCor,EixoX: Integer;
    Plataforma,SQLString,DataProcuraIncio,DataProcuraFim,SQLBase: String;
    CalcHoras: THoras;
    TotalHoras: Double;
begin
  BarSeriesGRF:= carregaSerie;
  DataProcuraIncio:= (FormatDateTime('mm/dd/yyyy',dataInicio.Date));
  DataProcuraFim:= (FormatDateTime('mm/dd/yyyy',dataFim.Date));
  SQLString:= carregaStatus(ColunasLayoutProgramacao);
  FrmDataModule.ADOQueryConsultaPlataforma.Active:= false;
  FrmDataModule.ADOQueryConsultaPlataforma.Active:= true;
  EixoX:= 0;
  GrfCor:= 0;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryConsultaPlataforma.RecordCount,
  'Gerando gráfico...');
  while not FrmDataModule.ADOQueryConsultaPlataforma.Eof do
  begin
    Plataforma:= FrmDataModule.DataSourceConsultaPlataforma.
    DataSet.FieldByName('Plataforma').AsString;
    FrmDataModule.ADOQueryTemporarioDBColibri.Close;
    FrmDataModule.ADOQueryTemporarioDBColibri.SQL.Clear;
    SQLBase:= 'SELECT tblProgramacaoDiaria.* FROM tblProgramacaoDiaria '+
    'WHERE ((DataProgramacao BETWEEN #'+DataProcuraIncio+'# and #'+DataProcuraFim+'#)'+
    SQLString+'AND(txtDestino LIKE '+QuotedStr('%'+Plataforma+'%')+
    ')AND(HorarioChegada <> "")) ORDER BY DataProgramacao;';
    FrmDataModule.ADOQueryTemporarioDBColibri.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBColibri.Open;
    //=============================================================
    CalcHoras:= calculoHora;
    TotalHoras:= CalcHoras.SomaMinutos;
    //=============================================================
    if (CalcHoras.SomaMinutos > 0) then
    begin
      if RadioGroupHorasTrabalho.ItemIndex >= 3 then
        TotalHoras:= CalcHoras.SomaMinutos/CalcHoras.NumRegistros;

      BarSeriesGRF.AddXY(EixoX,(TotalHoras/60),Plataforma,
      FrmPrincipal.CoresAuto[GrfCor]);
      //=============================================================
      EixoX:= EixoX+1;
      if GrfCor <= 13 then
        GrfCor:= GrfCor+1
      else
        GrfCor:= 0;
    end;
    //=============================================================
    FrmDataModule.ADOQueryConsultaPlataforma.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  ChartGrafico.AddSeries(BarSeriesGRF);
  FrmPrincipal.ProgressBarAtualizar;
end;

