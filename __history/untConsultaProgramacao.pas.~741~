procedure TFrmConsultaProgramacao.actGanttSalvarExecute(Sender: TObject);
  var
    arquivo_modelo,InicioProgramado,FimProgramado: String;
    i: Integer;
    InicioProgramadoDate,FimProgramadoDate: TDateTime;
    Gravar: Boolean;
begin
  SaveDialog1.Filter:= 'Microsoft Access|*.mdb';
  SaveDialog1.FileName:= 'dbGantt.mdb';
  SaveDialog1.DefaultExt:= '*.mdb';
  arquivo_modelo:=ExtractFilePath(Application.ExeName)+'Arquivos\dbGantt.mdb';
  if SaveDialog1.Execute then
  begin
    if CopyFile(PChar(arquivo_modelo), PChar(SaveDialog1.FileName), false) then
    begin
      FrmPrincipal.conectarBDDireto(
      SaveDialog1.FileName,FrmDataModule.ADOConnectionGantt);
      FrmDataModule.ADOQueryGantt.Active:= false;
      FrmDataModule.ADOQueryGantt.Active:= true;
      FrmPrincipal.ProgressBarIncializa(GanttChart1.RowCount,'Salvando gráfico...');
      for i := 0 to GanttChart1.RowCount-1 do
      begin
        InicioProgramado:= GanttChart1.AbsoluteRow[i].Cells[2].Text;
        FimProgramado:= GanttChart1.AbsoluteRow[i].Cells[3].Text;
        Delete(InicioProgramado, 1, 5);
        Delete(FimProgramado, 1, 5);
        try
          InicioProgramadoDate:= StrToDate(InicioProgramado);
          FimProgramadoDate:= StrToDate(FimProgramado);
          Gravar:= true;
        except
          Gravar:= false;
          InicioProgramadoDate:= now;
          FimProgramadoDate:= now;
        end;
        //===============================================
        if Gravar then
        begin
          FrmDataModule.ADOQueryGantt.Insert;
          FrmDataModule.DataSourceGantt.DataSet.
          FieldByName('Plataforma').AsString:=
          GanttChart1.AbsoluteRow[i].Cells[0].Text;
          FrmDataModule.DataSourceGantt.DataSet.
          FieldByName('InicioProgramado').AsDateTime:=
          InicioProgramadoDate;
          FrmDataModule.DataSourceGantt.DataSet.
          FieldByName('FimProgramado').AsDateTime:=
          FimProgramadoDate;
          FrmDataModule.DataSourceGantt.DataSet.
          FieldByName('TextoBreveGantt').AsString:=
          GanttChart1.AbsoluteRow[i].Cells[1].Text;
          try
            FrmDataModule.ADOQueryGantt.Post;
          except
            FrmDataModule.ADOQueryGantt.Cancel;
          end;
        end;
        FrmPrincipal.ProgressBarIncremento(1);
      end;
      FrmPrincipal.ProgressBarAtualizar;
    end;
  end;
end;

