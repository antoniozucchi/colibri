function TFrmConsultaProgramacao.inserirProgramacao(
vetorDataProgramacao: array of TDateTime;
vetorCodigoProgramacao: array of String;
InicioProgramado,FimProgramado: TDateTime): String;
  var
    i: Integer;
    codigoProgramacao: String;
begin
  codigoProgramacao:= '';
  for i := 0 to High(vetorDataProgramacao) do
  begin
    if ((vetorDataProgramacao[i] >= InicioProgramado)AND
    (vetorDataProgramacao[i] <= FimProgramado)) then
    begin
      if codigoProgramacao <> '' then
        codigoProgramacao:= codigoProgramacao+';'+vetorCodigoProgramacao[i]
      else
        codigoProgramacao:= vetorCodigoProgramacao[i];
    end;
  end;
  Result:= codigoProgramacao;
end;

