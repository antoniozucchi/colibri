function TFrmConsultaProgramacao.calculoHora: THoras;
  var
    HorarioSaldo,HorarioDemora,NumAprovados,NumRegistros: Integer;
    HorarioChegada,HorarioSaida,Disponibilidade: String;
    SomaMinutos: Double;
begin
  SomaMinutos:= 0;
  NumRegistros:=0;
  while not FrmDataModule.ADOQueryTemporarioDBColibri.Eof do
  begin
    case RadioGroupHorasTrabalho.ItemIndex of
      0:
      begin
        try
          NumAprovados:= FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('NumAprovados').AsInteger;
          HorarioChegada:= FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('HorarioChegada').AsString;
          HorarioSaida:= FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('HorarioSaida').AsString;
          Disponibilidade:= FrmPrincipal.SubtrairHoras(HorarioChegada,HorarioSaida);
          SomaMinutos:= SomaMinutos+(FrmPrincipal.HoraParaMin(Disponibilidade)*NumAprovados);
        except
        end;
      end;
      1:
      begin
        try
          NumAprovados:= FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('NumAprovados').AsInteger;
          HorarioSaldo:= FrmPrincipal.HoraParaMin(
          FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('HorarioSaldo').AsString);
          SomaMinutos:= SomaMinutos+(HorarioSaldo*NumAprovados);
        except
        end;
      end;
      2:
      begin
        try
          NumAprovados:= FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('NumAprovados').AsInteger;
          HorarioDemora:= FrmPrincipal.HoraParaMin(
          FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('HorarioDemora').AsString);
          SomaMinutos:= SomaMinutos+(HorarioDemora*NumAprovados);
        except
        end;
      end;
      3:
      begin
        try
          HorarioChegada:= FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('HorarioChegada').AsString;
          HorarioSaida:= FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('HorarioSaida').AsString;
          Disponibilidade:= FrmPrincipal.SubtrairHoras(HorarioChegada,HorarioSaida);
          if Disponibilidade <> '00:00' then
          begin
            SomaMinutos:= SomaMinutos+(FrmPrincipal.HoraParaMin(Disponibilidade));
            NumRegistros:= NumRegistros+1;
          end;
        except
        end;
      end;
      4:
      begin
        try
          HorarioSaldo:= FrmPrincipal.HoraParaMin(
          FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('HorarioSaldo').AsString);
          if HorarioSaldo <> 0 then
          begin
            SomaMinutos:= SomaMinutos+(HorarioSaldo);
            NumRegistros:= NumRegistros+1;
          end;
        except
        end;
      end;
      5:
      begin
        try
          HorarioDemora:= FrmPrincipal.HoraParaMin(
          FrmDataModule.DataSourceTemporarioDBColibri.DataSet.
          FieldByName('HorarioDemora').AsString);
          if HorarioDemora <> 0 then
          begin
            SomaMinutos:= SomaMinutos+(HorarioDemora);
            NumRegistros:= NumRegistros+1;
          end;
        except
        end;
      end;
    end;
    FrmDataModule.ADOQueryTemporarioDBColibri.Next;
  end;
  Result.SomaMinutos:= SomaMinutos;
  Result.NumRegistros:= NumRegistros;
end;

function TFrmConsultaProgramacao.carregaSerie: TBarSeries;
  var
    Grafico,HorasTrabalho: String;
begin
  Grafico:= RadioGroupGrafico.Items.Strings[RadioGroupGrafico.ItemIndex];
  case RadioGroupHorasTrabalho.ItemIndex of
    0: HorasTrabalho:= 'Disponibilidade';
    1: HorasTrabalho:= 'Produtividade';
    2: HorasTrabalho:= 'Parado';
    3: HorasTrabalho:= 'Disponibilidade Média';
    4: HorasTrabalho:= 'Produtividade Média';
    5: HorasTrabalho:= 'Parado Média';
  end;
  TituloGrafico:= Grafico+' - '+HorasTrabalho+': '+
  FormatDateTime('dd/mm/yyyy',dataInicio.DateTime)+' ŕ '+
  FormatDateTime('dd/mm/yyyy',dataFim.DateTime);
  ChartGrafico.Title.Caption:= TituloGrafico;
  ChartGrafico.Axes.Left.Title.Caption:= TituloGrafico;
  ChartGrafico.RemoveAllSeries;
  Result:= TBarSeries.Create(ChartGrafico);
  Result.MultiBar:= mbSide;
  Result.AutoBarSize:= true;
  if RadioGroupGrafico.ItemIndex = 0 then
  begin
    Result.XValues.DateTime:= true;
    ChartGrafico.BottomAxis.Visible:= true;
  end
  else
  begin
    Result.XValues.DateTime:= false;
    ChartGrafico.BottomAxis.Visible:= false;
  end;
  Result.CustomBarWidth:= 20;
  if btnMark.Down then
  begin
    Result.Marks.Style:= smsLabelValue;
    Result.Marks.MultiLine:= true;
    Result.Marks.Arrow.Visible:= true;
    Result.Marks.Arrow.Color:= clBlack;
    Result.Marks.Margins.Left:= 1;
    Result.Marks.Margins.Right:= 1;
    Result.Marks.Margins.Top:= 1;
    Result.Marks.Margins.Bottom:= 1;
    Result.Marks.Visible:= true;
  end
  else
    Result.Marks.Visible:= false;
end;

function TFrmConsultaProgramacao.carregaStatus(ColunasLayout: TStringGrid): String;
  var
    SQLString: String;
begin
  SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayout,false);
  //NumAprovados
  if (CheckListBoxStatus.Checked[0])and(SQLString <> '') then
    SQLString:=SQLString+'AND(NumAprovados > 0)'
  else if (CheckListBoxStatus.Checked[0])and(SQLString = '') then
    SQLString:=SQLString+'(NumAprovados > 0)';
  //NumCancelados
