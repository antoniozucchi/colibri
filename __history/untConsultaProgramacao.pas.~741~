procedure TFrmConsultaProgramacao.actGanttAbrirExecute(Sender: TObject);
  var
    InicioProgramado,FimProgramado : TDateTime;
    aTaskBar : TGanttTaskBar;
begin
  OpenDialog1.Filter:= 'Microsoft Access|*.mdb';
  OpenDialog1.DefaultExt:= '*.mdb';
  if OpenDialog1.Execute then
  begin
    FrmPrincipal.conectarBDDireto(
    OpenDialog1.FileName,FrmDataModule.ADOConnectionGantt);
    try
      GanttChart1.DataController.Clear;
      FrmDataModule.ADOQueryGantt.Active:= false;
      FrmDataModule.ADOQueryGantt.Active:= true;
      FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryGantt.RecordCount,
      'Abrindo gráfico...');
      while not FrmDataModule.ADOQueryGantt.Eof do
      begin
        InicioProgramado:= FrmDataModule.DataSourceGantt.DataSet.
        FieldByName('InicioProgramado').AsDateTime;
        FimProgramado:= IncDay(FrmDataModule.DataSourceGantt.DataSet.
        FieldByName('FimProgramado').AsDateTime,1);
        //============================================
        GanttChart1.DataController.AddRow;
        aTaskBar := GanttChart1.DataController.AddTaskBar(InicioProgramado, FimProgramado,
        GanttChart1.AbsoluteRow[GanttChart1.AbsoluteRowCount-1]);
        aTaskBar.DrawOptions.DrawStyle := dsSolid;
        aTaskBar.Color := $0057B1EE;
        //============================================
        GanttChart1.AbsoluteRow[GanttChart1.AbsoluteRowCount-1].
        Cells[0].Text := FrmDataModule.DataSourceGantt.DataSet.
        FieldByName('Plataforma').AsString;
        GanttChart1.AbsoluteRow[GanttChart1.AbsoluteRowCount-1].
        Cells[1].Text := FrmDataModule.DataSourceGantt.DataSet.
        FieldByName('TextoBreveGantt').AsString;
        GanttChart1.AbsoluteRow[GanttChart1.AbsoluteRowCount-1].
        Cells[2].Text := DateToStr(InicioProgramado);
        GanttChart1.AbsoluteRow[GanttChart1.AbsoluteRowCount-1].
        Cells[3].Text := DateToStr(FimProgramado);
        //============================================
        FrmDataModule.ADOQueryGantt.Next;
        FrmPrincipal.ProgressBarIncremento(1);
    end;
    finally
      FrmPrincipal.ProgressBarAtualizar;
    end;
  end;
end;

