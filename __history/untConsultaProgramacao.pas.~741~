    SQLString:=SQLString+'AND(NumCancelados > 0)'
  else if (CheckListBoxStatus.Checked[1])and(SQLString = '') then
    SQLString:=SQLString+'(NumCancelados > 0)';
  //=========================================
  if SQLString <> '' then
    SQLString:= ' AND '+SQLString;

  Result:= SQLString;
end;

