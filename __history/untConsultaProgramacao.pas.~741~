procedure TFrmConsultaProgramacao.selecionarServicos(TipoEtapaServico: String);
  var
    txtDestino,SQLBase,CampoSelecao,TextoBreveOP,TextoBreveOM,OrdemManutencao,
    Operacao,StatusUsuarioOM,CentroTrabalhoOP: String;
    numLinha: Integer;
begin
  actAjudaLimpar.Execute;
  case RadioGroup1.ItemIndex of
    0: StatusUsuarioOM:= 'AND(StatusUsuarioOM LIKE "%GIOP%"))';
    1: StatusUsuarioOM:= 'AND(StatusUsuarioOM LIKE "%TRIA%"))';
    2: StatusUsuarioOM:= ')';
  end;
  RLSelecionarServicos.ColCount:= 9;
  RLSelecionarServicos.Cells[0,0]:= 'Seleçăo';
  RLSelecionarServicos.Cells[1,0]:= 'Serviço/Ano-Etapa';
  RLSelecionarServicos.Cells[2,0]:= 'Texto Breve da Operaçăo';
  RLSelecionarServicos.Cells[3,0]:= 'Texto Breve da Ordem';
  RLSelecionarServicos.Cells[4,0]:= 'Ordem Manutençăo';
  RLSelecionarServicos.Cells[5,0]:= 'Operaçăo';
  RLSelecionarServicos.Cells[6,0]:= 'Centro Trabalho';
  RLSelecionarServicos.Cells[7,0]:= 'Data Base Inicio';
  RLSelecionarServicos.Cells[8,0]:= 'Data Base Fim';
  FrmPrincipal.selComboBox(ComboBoxSelecaoServicoTipoEtapaServico,TipoEtapaServico);
  txtDestino:= FrmDataModule.DataSourceProgramacaoDiaria_Consulta.DataSet.
  FieldByName('txtDestino').AsString;
  SQLBase:='SELECT tblCarteiraTrabalho.* FROM tblCarteiraTrabalho '+
  'WHERE ((txtTipoEtapaServicoOP LIKE '+QuotedStr(TipoEtapaServico)+
  ')AND(Plataforma LIKE '+QuotedStr(txtDestino)+
  ')AND(TipoOperacao NOT LIKE "%CONF%")'+StatusUsuarioOM+
  ' ORDER BY OrdemManutencao,Operacao;';
  FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
  FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
  RLSelecionarServicos.RowCount:= 1;
  while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
  begin
    numLinha:= RLSelecionarServicos.RowCount;
    RLSelecionarServicos.RowCount:= RLSelecionarServicos.RowCount+1;
    RLSelecionarServicos.Cells[0,numLinha]:= '  ';//Selecao
    RLSelecionarServicos.Cells[1,numLinha]:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
    FieldByName('CampoSelecao').AsString;//CampoSelecao
    RLSelecionarServicos.Cells[2,numLinha]:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
    FieldByName('TextoBreveOP').AsString;//TextoBreveOP
    RLSelecionarServicos.Cells[3,numLinha]:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
    FieldByName('TextoBreveOM').AsString;//TextoBreveOM
    RLSelecionarServicos.Cells[4,numLinha]:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
    FieldByName('OrdemManutencao').AsString;//OrdemManutencao
    RLSelecionarServicos.Cells[5,numLinha]:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
    FieldByName('Operacao').AsString;//Operacao
    RLSelecionarServicos.Cells[6,numLinha]:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
    FieldByName('CentroTrabalhoOP').AsString;//CentroTrabalhoOP
    RLSelecionarServicos.Cells[7,numLinha]:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
    FieldByName('DataBaseInicio').AsString;//DataBaseInicio
    RLSelecionarServicos.Cells[8,numLinha]:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
    FieldByName('DataBaseFim').AsString;//DataBaseFim

    FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
  end;
  //Selecionar serviços já existentes
  FrmDataModule.ADOQueryProgramacaoServico_Consulta.First;
  while not FrmDataModule.ADOQueryProgramacaoServico_Consulta.Eof do
  begin
    CampoSelecao:= FrmDataModule.DataSourceProgramacaoServico_Consulta.DataSet.
    FieldByName('CampoSelecao').AsString;
    TextoBreveOP:= FrmDataModule.DataSourceProgramacaoServico_Consulta.DataSet.
    FieldByName('TextoBreveOP').AsString;
    TextoBreveOM:= FrmDataModule.DataSourceProgramacaoServico_Consulta.DataSet.
    FieldByName('TextoBreveOM').AsString;
    OrdemManutencao:= FrmDataModule.DataSourceProgramacaoServico_Consulta.DataSet.
    FieldByName('OrdemManutencao').AsString;
    Operacao:= FrmDataModule.DataSourceProgramacaoServico_Consulta.DataSet.
    FieldByName('Operacao').AsString;
    CentroTrabalhoOP:= FrmDataModule.DataSourceProgramacaoServico_Consulta.DataSet.
    FieldByName('CentroTrabalhoOP').AsString;
    if FrmPrincipal.selecionarServico(RLSelecionarServicos,CampoSelecao,TextoBreveOP,OrdemManutencao) = false then
    begin
      numLinha:= FrmPrincipal.InsertRow1(RLSelecionarServicos,1);
      //Preencher valores
      RLSelecionarServicos.Cells[0,numLinha]:= ' ';
      RLSelecionarServicos.Cells[1,numLinha]:= CampoSelecao;
      RLSelecionarServicos.Cells[2,numLinha]:= TextoBreveOP;
      RLSelecionarServicos.Cells[3,numLinha]:= TextoBreveOM;
      RLSelecionarServicos.Cells[4,numLinha]:= OrdemManutencao;
      RLSelecionarServicos.Cells[5,numLinha]:= Operacao;
      RLSelecionarServicos.Cells[6,numLinha]:= CentroTrabalhoOP;
      RLSelecionarServicos.Cells[7,numLinha]:= '';
      RLSelecionarServicos.Cells[8,numLinha]:= '';
    end;
    FrmDataModule.ADOQueryProgramacaoServico_Consulta.Next;
  end;
  FrmDataModule.ADOQueryProgramacaoServico_Consulta.First;
  //=================================================================
  FrmPrincipal.AutoFitGrade(RLSelecionarServicos);
  try
    RLSelecionarServicos.FixedRows:= 1;
  except
    RLSelecionarServicos.FixedRows:= 0;
  end;
  //================================================
  StatusBarSelecaoServico.Panels[0].Text:=
  'N° Selecionados: '+(IntToStr(FrmPrincipal.CountChecked(RLSelecionarServicos)));
  StatusBarSelecaoServico.Panels[1].Text:=
  'N° Registros: '+(IntToStr(RLSelecionarServicos.RowCount-1));
  FrmPrincipal.AutoFitStatusBar(StatusBarSelecaoServico);
  //================================================
  PanelTituloAjuda1.Caption:= 'Seleçăo de serviços disponivéis';
  PanelSelecaoServico.Visible:= true;
  PanelSelecaoServico.Align:= alClient;
  PanelAjuda.Width:= 1000;
  PanelAjuda.Height:= 350;
  PanelAjuda.Visible:= true;

end;

procedure TFrmConsultaProgramacao.ssss1Click(Sender: TObject);
begin
  while not FrmDataModule.ADOQueryProgramacaoDiaria_Consulta.Eof do
  begin
    actLimparHoras.Execute;
    FrmDataModule.ADOQueryProgramacaoDiaria_Consulta.Next;
  end;
end;

procedure TFrmConsultaProgramacao.WMMDIACTIVATE(var msg: TWMMDIACTIVATE);
var
  active: TWinControl;
  idx: Integer;
begin
  active := FindControl(msg.ActiveWnd) ;

  if Assigned(active) then
  begin
    idx := FrmPrincipal.mdiChildrenTabs.Tabs.IndexOfObject(TObject(msg.ActiveWnd));
    FrmPrincipal.mdiChildrenTabs.Tag := -1;
    FrmPrincipal.mdiChildrenTabs.TabIndex := idx;
    FrmPrincipal.mdiChildrenTabs.Tag := 0;
  end;
end;

