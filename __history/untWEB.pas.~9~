procedure TFrmWEB.WebBrowser1DocumentComplete(ASender: TObject;
  const pDisp: IDispatch; const URL: OleVariant);
  var
    vaIn, vaOut:  OleVariant;
    NomeExecutante,txtFuncao,txtEmpresa,Chave,Matricula: String;
begin
  try
    if (booleanCopiar = true) then
    begin
      //Copiar e colar no memo1
      ((WebBrowser1.Document as IHTMLDocument2).body as IHTMLElement2).focus();
      WebBrowser1.ExecWB(OLECMDID_SELECTALL, OLECMDEXECOPT_PROMPTUSER, vaIn, vaOut);
      WB_Copy(webbrowser1);
      MemoBuscaEmpreagado.Text:= Clipboard.AsText;
      //Carregar resultado no banco de dados
      if pos('Empregado',MemoBuscaEmpreagado.Lines.Text)<>0 then
      begin
        NomeExecutante:=  FrmPrincipal.TextoMaiusculo(buscaInfo('Empregado',3));
        txtFuncao:=  FrmPrincipal.TextoMaiusculo(buscaInfo('Cargo',2));
        txtEmpresa:=  FrmPrincipal.TextoMaiusculo(buscaInfo('Empresa',2));
        Chave:=  FrmPrincipal.TextoMaiusculo(buscaInfo('Chave',2));
        Matricula:=  FrmPrincipal.TextoMaiusculo(buscaInfo('Matrķcula',2));

        if NomeExecutante <> '' then
        begin
          case gravarOnde of
            0://Tabela de Executantes
            begin
              try
                FrmDataModule.ADOQueryExecutante.Edit;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('NomeExecutante').AsString:= NomeExecutante;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('txtFuncao').AsString:= txtFuncao;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('txtEmpresa').AsString:= txtEmpresa;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('Chave').AsString:= Chave;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('CodigoSAP').AsString:= Matricula;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('AvaliadoPor').AsString:= FrmPrincipal.logChave;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('DataAtualizacao').AsDateTime:= now;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('Computador').AsString:= FrmPrincipal.logMaquina;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('booleanBuscaEmpregado').AsBoolean:= true;
                FrmDataModule.ADOQueryExecutante.Post;
                FrmExecutante.SetFocus;
                FrmExecutante.DBGridExecutante.SetFocus;
              except
              end;
            end;
            1://Tabela de importaēćo
            begin
              FrmImportacao.StringGridND.Cells[0,FrmImportacao.StringGridND.Row]:= NomeExecutante;
              FrmImportacao.StringGridND.Cells[2,FrmImportacao.StringGridND.Row]:= txtFuncao;
              FrmImportacao.StringGridND.Cells[3,FrmImportacao.StringGridND.Row]:= txtEmpresa;
            end;
          end;
        end
        else
        begin
          FrmExecutante.StatusBarExecutntes.Panels[5].Text:=
          'Encontrado mais de um resultado!';
          FrmPrincipal.AutoFitStatusBar(FrmExecutante.StatusBarExecutntes);
        end;
      end
      else if pos('Prestador',MemoBuscaEmpreagado.Lines.Text)<>0 then
      begin
        NomeExecutante:=  FrmPrincipal.TextoMaiusculo(buscaInfo('Prestador',3));
        txtEmpresa:=  FrmPrincipal.TextoMaiusculo(buscaInfo('Empresa Contratada',2));
        Chave:=  FrmPrincipal.TextoMaiusculo(buscaInfo('Chave',2));
        Matricula:=  FrmPrincipal.TextoMaiusculo(buscaInfo('Identificador',2));
        if NomeExecutante <> '' then
        begin
          case gravarOnde of
            0://Tabela de Executantes
            begin
              try
                FrmDataModule.ADOQueryExecutante.Edit;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('NomeExecutante').AsString:= NomeExecutante;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('txtEmpresa').AsString:= txtEmpresa;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('Chave').AsString:= Chave;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('CodigoSAP').AsString:= Matricula;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('AvaliadoPor').AsString:= FrmPrincipal.logChave;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('DataAtualizacao').AsDateTime:= now;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('Computador').AsString:= FrmPrincipal.logMaquina;
                FrmDataModule.DataSourceExecutante.DataSet.FieldByName('booleanBuscaEmpregado').AsBoolean:= true;
                FrmDataModule.ADOQueryExecutante.Post;
                FrmExecutante.SetFocus;
                FrmExecutante.DBGridExecutante.SetFocus;
              except
              end;
            end;
            1://Tabela de importaēćo
            begin
              FrmImportacao.StringGridND.Cells[0,FrmImportacao.StringGridND.Row]:= NomeExecutante;
              FrmImportacao.StringGridND.Cells[3,FrmImportacao.StringGridND.Row]:= txtEmpresa;
            end;
          end;
        end
        else
        begin
          ShowMessage('Encontrado mais de um resultado!'+#13+'Necessįrio analisar pįgina completa');
          FrmWEB.Show;
        end;
      end
      else
      begin
        FrmDataModule.ADOQueryExecutante.Edit;
        FrmDataModule.DataSourceExecutante.DataSet.FieldByName('booleanBuscaEmpregado').AsBoolean:= false;
        FrmDataModule.ADOQueryExecutante.Post;
        FrmExecutante.SetFocus;
        FrmExecutante.DBGridExecutante.SetFocus;
      end;
    end;
  finally
    booleanCopiar:= false;
  end;
end;

procedure TFrmWEB.WebBrowser1ProgressChange
(Sender: TObject; Progress,ProgressMax: Integer);
begin
{Ele faz um rotina para saber se o valor Maximo do
Progressbar é maior que 1 e o valor minimo tbem
se for, entćo ele faz a rotina}
  If (Progress>=1) and (ProgressMax>1) then
  begin
    //Ele tira uma valor percentual para colocar
    //no Progressbar
    ProgressBar1.Position := Round((Progress * 100) Div ProgressMax);
    ProgressBar1.Visible  := True;
  end
  else
  begin
    ProgressBar1.Position := 1;
    ProgressBar1.Visible  := False;
  end;
end;

