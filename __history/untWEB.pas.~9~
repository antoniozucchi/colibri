  WebBrowser1.OleObject.Document.all.Item('radio-lope',0).click;
  //preencher valor de pesquisa
  WebBrowser1.OleObject.Document.all.Item('buscar',0).value := txtBusca;
  //Clicar no botćo de busca
  WebBrowser1.OleObject.Document.all.Item('botao',0).click;
