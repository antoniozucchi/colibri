procedure TFrmWEB.ExibirURLsVisitadas(Urls: TStrings);
  var
    Reg: TRegistry;
    S: TStringList;
    i: Integer;
begin
  Reg := TRegistry.Create;
  try
    Reg.RootKey := HKEY_CURRENT_USER;
    if Reg.OpenKey(
    'http://portalpetrobras.petrobras.com.br/PetrobrasPortal/appmanager/portal/'+
    'desktop?_nfpb=true&_pageLabel=home_a_petrobras', False) then
    begin
      S := TStringList.Create;
      try
        reg.GetValueNames(S);
        for i := 0 to S.Count - 1 do
        begin
          Urls.Add(reg.ReadString(S.Strings[i]));
        end;
      finally
        S.Free;
      end;
      Reg.CloseKey;
    end;
  finally
    Reg.Free;
  end;
end;

