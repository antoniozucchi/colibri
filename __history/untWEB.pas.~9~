function TFrmWEB.buscaInfo(txtReferencia: String; somaLinha: Integer): String;
  var
    i,linha,tamanho : Integer;
begin
  for i := 0 to MemoBuscaEmpreagado.Lines.Count - 1 do
  begin
    if Pos(txtReferencia,MemoBuscaEmpreagado.Lines[i]) > 0 then
    begin
      linha := i + somaLinha;
      tamanho := Length(MemoBuscaEmpreagado.Lines.Strings[linha]);
      Result:= Copy(MemoBuscaEmpreagado.Lines.Strings[linha],0,tamanho);
      Break;
    end;
  end;
end;

