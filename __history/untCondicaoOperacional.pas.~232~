procedure TFrmCondicaoOperacional.actGravarSIGMRegistrosExecute(
  Sender: TObject);
  var
    Plataforma,DenominacaoLocalInstalacao,NotaManutencao,TextoBreveNOTA,txtTipoEtapaServico,
    InicioAvaria,Salvaguarda,AcaoAdotadaIndisponibilidade,PrazoToleravel,
    VencimentoAvaria,GIM_FAM,DescricaoGM,PrazoGM,AutorNota: String;
begin
  actLimparFiltros.Execute;
  if not FrmDataModule.ADOQueryAnaliseGM.IsEmpty then
  begin
    FrmDataModule.ADOQueryAnaliseGM.First;
    FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryAnaliseGM.RecordCount,
    'Gravar Registros...');
    FrmDataModule.DataSourceAnaliseGM.Enabled:= false;
    while not FrmDataModule.ADOQueryAnaliseGM.Eof do
    begin
      Plataforma:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('Plataforma').AsString;
      DenominacaoLocalInstalacao:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('DenominacaoLocalInstalacao').AsString;
      NotaManutencao:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('NotaManutencao').AsString;
      TextoBreveNOTA:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('TextoBreveNOTA').AsString;
      txtTipoEtapaServico:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('txtTipoEtapaServico').AsString;
      InicioAvaria:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('InicioAvaria').AsString;
      Salvaguarda:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('Salvaguarda').AsString;
      AcaoAdotadaIndisponibilidade:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('AcaoAdotadaIndisponibilidade').AsString;
      PrazoToleravel:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('PrazoToleravel').AsString;
      VencimentoAvaria:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('VencimentoAvaria').AsString;
      GIM_FAM:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('GIM_FAM').AsString;
      DescricaoGM:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('DescricaoGM').AsString;
      PrazoGM:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('PrazoGM').AsString;
      AutorNota:= FrmDataModule.DataSourceAnaliseGM.DataSet.FieldByName
      ('AutorNota').AsString;
      MemoRegistros.Lines.Add(Plataforma+'#'+DenominacaoLocalInstalacao+'#'+NotaManutencao+'#'+
      TextoBreveNOTA+'#'+txtTipoEtapaServico+'#'+InicioAvaria+'#'+
      Salvaguarda+'#'+AcaoAdotadaIndisponibilidade+'#'+PrazoToleravel+'#'+
      VencimentoAvaria+'#'+GIM_FAM+'#'+DescricaoGM+'#'+PrazoGM+'#'+AutorNota);
      //=====================================================================
      FrmDataModule.ADOQueryAnaliseGM.Next;
      FrmPrincipal.ProgressBarIncremento(1);
    end;
    FrmDataModule.DataSourceAnaliseGM.Enabled:= true;
    FrmDataModule.ADOQueryAnaliseGM.First;
    FrmDataModule.ADOQuerySIGMRegistros.Active:= false;
    FrmDataModule.ADOQuerySIGMRegistros.Active:= true;
    FrmDataModule.ADOQuerySIGMRegistros.Insert;
    FrmDataModule.DataSourceSIGMRegistros.DataSet.FieldByName
    ('Resultados').AsString:= MemoRegistros.Text;
    //=================================================
    FrmDataModule.DataSourceSIGMRegistros.DataSet.FieldByName
    ('AvaliadoPor').AsString:= FrmPrincipal.logChave;
    FrmDataModule.DataSourceSIGMRegistros.DataSet.FieldByName
    ('DataRegistro').AsDateTime:= now;
    FrmDataModule.DataSourceSIGMRegistros.DataSet.FieldByName
    ('Computador').AsString:= FrmPrincipal.logMaquina;
    //=================================================
    FrmDataModule.ADOQuerySIGMRegistros.Post;
    FrmPrincipal.ProgressBarAtualizar;
  end
  else
  begin
    MessageBox(0, PChar('Năo existem registros para gravar!'),
    'Análise de Gestăo de Mudança', MB_ICONINFORMATION);
  end;
end;

