procedure TFrmCondicaoOperacional.actAbrirSIGMRegistrosExecute(Sender: TObject);
  var
    ListaRegistro: TStringLIst;
    i,j,numLinhas: Integer;
    DataRegistro,AvaliadoPor,Computador: String;
begin
  ListaRegistro:= TStringList.Create;
  ListaRegistro.delimiter:= '#';
  ListaRegistro.StrictDelimiter:=true;
  DataRegistro:= FrmDataModule.DataSourceSIGMRegistros.DataSet.FieldByName('DataRegistro').AsString;
  AvaliadoPor:= FrmDataModule.DataSourceSIGMRegistros.DataSet.FieldByName('AvaliadoPor').AsString;
  Computador:= FrmDataModule.DataSourceSIGMRegistros.DataSet.FieldByName('Computador').AsString;
  //Preencher dados
  RLImpressao.FixedRows:= 0;
  RLImpressao.RowCount:= 1;
  RLImpressao.ColCount:= 14;
  RLImpressao.Cells[0,0]:= 'Plataforma';
  RLImpressao.Cells[1,0]:= 'Denomin. Local Instalaçăo';
  RLImpressao.Cells[2,0]:= 'Nota de Manutençăo';
  RLImpressao.Cells[3,0]:= 'Texto Breve [Nota]';
  RLImpressao.Cells[4,0]:= 'Tipo Etapa Serviço [Nota]';
  RLImpressao.Cells[5,0]:= 'Início da Avaria';
  RLImpressao.Cells[6,0]:= 'Salvaguarda';
  RLImpressao.Cells[7,0]:= 'Açăo Adotada Durante Indisponibilidade';
  RLImpressao.Cells[8,0]:= 'Prazo TolerÁvel (Dias)';
  RLImpressao.Cells[9,0]:= 'Validade';
  RLImpressao.Cells[10,0]:= 'GIM/FAM';
  RLImpressao.Cells[11,0]:= 'Descriçăo GM';
  RLImpressao.Cells[12,0]:= 'Prazo GM';
  RLImpressao.Cells[13,0]:= 'Autor Nota';
  MemoRegistros.Text:= FrmDataModule.DataSourceSIGMRegistros.DataSet.
  FieldByName('Resultados').AsString;
  FrmPrincipal.ProgressBarIncializa(MemoRegistros.Lines.Count,
  'Carregando Registros...');
  for i := 0 to MemoRegistros.Lines.Count-1 do
  begin
    numLinhas:= RLImpressao.RowCount;
    RLImpressao.RowCount:= numLinhas+1;
    ListaRegistro.DelimitedText:= MemoRegistros.Lines[i];
    //Preencher valores
    for j := 0 to RLImpressao.ColCount-1 do
    begin
      RLImpressao.Cells[j,numLinhas]:= ListaRegistro[j];
    end;
    //====================================
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  StatusBarImpressao.Panels[0].Text:= 'N° registros: '+
  intToStr(RLImpressao.RowCount-1);
  FrmPrincipal.AutoFitGrade(RLImpressao);
  FrmPrincipal.ProgressBarAtualizar;
  try
    RLImpressao.FixedRows:= 1;
  except
  end;
end;

