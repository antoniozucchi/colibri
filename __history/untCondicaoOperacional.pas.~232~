procedure TFrmCondicaoOperacional.FormCreate(Sender: TObject);
begin
  FrmPrincipal.MDIChildCreated(self.Handle);
  if ((FrmPrincipal.logPerfil = 'Administrador')OR
  (FrmPrincipal.logPerfil = 'PCM')) then
  begin
    actGravarSIGMRegistros.Enabled:= true;
    actSIGM.Enabled:= true;
  end
  else if (FrmPrincipal.logPerfil = 'Operaçăo') then
  begin
    actGravarSIGMRegistros.Enabled:= true;
    actSIGM.Enabled:= true;
  end
  else
  if (FrmPrincipal.logPerfil = 'PIOP')OR
  (FrmPrincipal.logPerfil = 'SEG-PIOP') then
  begin
    actGravarSIGMRegistros.Enabled:= true;
    actSIGM.Enabled:= false;
  end
  else
  begin
    actGravarSIGMRegistros.Enabled:= false;
    actSIGM.Enabled:= false;
  end;
  //Incicializaçăo
  PageControl1.TabIndex:=0;
  FrmPrincipal.SetUpColunasLayout(DBGridForaOperacao, ColunasLayoutFO);
  FrmPrincipal.SetUpColunasLayout(DBGridRestricaoOperacional, ColunasLayoutRO);
  FrmPrincipal.SetUpColunasLayout(DBGridPreventivaAtrasada, ColunasLayoutPreventivaAtrasada);
  FrmPrincipal.SetUpColunasLayout(DBGridAnaliseGM, ColunasLayoutAnaliseGM);
  FrmPrincipal.SetUpColunasLayout(DBGridListaSIGM, ColunasLayoutListaSIGM);
  FrmPrincipal.SetUpColunasLayout(DBGridRegistros, ColunasLayoutRegistros);

  actProcurarFO.Execute;
  FrmDataModule.ADOQueryPlataformaControle.Active:= false;
  FrmDataModule.ADOQueryPlataformaControle.Active:= true;
  FrmPrincipal.carregarCheckListBox(FrmDataModule.ADOQueryPlataformaControle,
  CheckListBoxPlataforma,'Plataforma');
  FrmPrincipal.carregarCheckListBox(FrmDataModule.ADOQueryTipoEtapaServico_Carteira,
  CheckListBoxTipoEtapaServico,'TipoEtapaServico');
  FrmPrincipal.carregarFiltroSistemaCheckList(CheckListBoxSistemaFiltro,DBGridForaOperacao);
end;

