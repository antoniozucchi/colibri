  'GROUP BY tblCarteiraTrabalho.Plataforma, tblCarteiraTrabalho.txtTipoEtapaServicoOM, '+
  'tblCarteiraTrabalho.OrdemManutencao, tblCarteiraTrabalho.LocalInstalacao, '+
  'tblCarteiraTrabalho.DenominacaoLocalInstalacao, tblCarteiraTrabalho.TextoBreveOM, '+
