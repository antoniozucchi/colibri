procedure TFrmCondicaoOperacional.DBGridForaOperacaoDrawColumnCell(Sender: TObject;
  const Rect: TRect; DataCol: Integer; Column: TColumn; State: TGridDrawState);
  var
    DataFimDesejado,Dias5,Dias30: TDateTime;
begin
  FrmPrincipal.GridZebrado(DBGridForaOperacao,ColunasLayoutFO,State,Rect,DataCol,Column);
  if (Column.Field.FieldName = 'BooleanCritico') then
  begin
    if (FrmDataModule.DataSourceForaOperacao.DataSet.
    FieldByName('BooleanCritico').AsBoolean) then
    begin
      TDBGrid(Sender).Canvas.FillRect(Rect);
      FrmPrincipal.ImageList1.Draw(TDBGrid(Sender).Canvas, Rect.Left +10,Rect.Top + 1, 154);
    end
    else
    begin
      TDBGrid(Sender).Canvas.FillRect(Rect);
      FrmPrincipal.ImageList1.Draw(TDBGrid(Sender).Canvas, Rect.Left +10,Rect.Top + 1, 155);
    end;
  end
  else if (Column.Field.FieldName = 'DataFimDesejado') then
  begin
    if FrmDataModule.DataSourceForaOperacao.DataSet.
    FieldByName('DataFimDesejado').AsString <> '' then
    begin
      DataFimDesejado:= FrmDataModule.DataSourceForaOperacao.DataSet.
      FieldByName('DataFimDesejado').AsDateTime;
      Dias5:= IncDay(now,+5);
      Dias30:= IncDay(now,+30);
      if (DataFimDesejado >= Dias30) then
      begin
        DBGridForaOperacao.Canvas.Brush.Color:= clLime;
        DBGridForaOperacao.Font.Color:= clBlack;
        DBGridForaOperacao.Canvas.FillRect(Rect);
        DBGridForaOperacao.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end
      else if ((DataFimDesejado >= Dias5)AND(DataFimDesejado < Dias30)) then
      begin
        DBGridForaOperacao.Canvas.Brush.Color:= clYellow;
        DBGridForaOperacao.Font.Color:= clBlack;
        DBGridForaOperacao.Canvas.FillRect(Rect);
        DBGridForaOperacao.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end
      else if (DataFimDesejado < Dias5) then
      begin
        DBGridForaOperacao.Canvas.Brush.Color:= clRed;
        DBGridForaOperacao.Font.Color:= clBlack;
        DBGridForaOperacao.Canvas.FillRect(Rect);
        DBGridForaOperacao.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end;
    end
    else
    begin
      DBGridForaOperacao.Canvas.Brush.Color:= clSilver;
      DBGridForaOperacao.Font.Color:= clBlack;
      DBGridForaOperacao.Canvas.FillRect(Rect);
      DBGridForaOperacao.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end;
  end;
end;

