  'tblCarteiraTrabalho.DataBaseFim, tblCarteiraTrabalho.StatusUsuarioOM, '+
  'tblCarteiraTrabalho.StatusSistemaOM, tblCarteiraTrabalho.Sala, '+
  'tblCarteiraTrabalho.CampoSelecao, tblCarteiraTrabalho.NotaManutencao, '+
