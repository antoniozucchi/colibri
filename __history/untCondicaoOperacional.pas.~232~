procedure TFrmCondicaoOperacional.actGraficoPlataformaExecute(Sender: TObject);
  var
    BarSeriesGRF: TBarSeries;
    NumRegistros,i,EixoX: Integer;
    Plataforma,SQLString,SQLBase: String;
begin
  ChartGrafico.RemoveAllSeries;
  ChartGrafico.BottomAxis.Visible:= false;
  ChartGrafico.Legend.CheckBoxes:= false;
  ChartGrafico.Legend.LegendStyle:= lsAuto;
  ChartGrafico.Title.Caption:= 'Filtro por Instalaçăo';
  ChartGrafico.Axes.Left.Title.Caption:= 'N° Ordens de Manutençăo';
  BarSeriesGRF:= carregaSerie;
  FrmDataModule.ADOQueryConsultaPlataforma.Active:= false;
  FrmDataModule.ADOQueryConsultaPlataforma.Active:= true;
  EixoX:= 0;
  SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayoutFO,false);
  if SQLString <>'' then
    SQLString:= 'AND'+SQLString;
  i:= 0;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryConsultaPlataforma.RecordCount,
  'Gerando gráfico...');
  while not FrmDataModule.ADOQueryConsultaPlataforma.Eof do
  begin
    Plataforma:= FrmDataModule.DataSourceConsultaPlataforma.
    DataSet.FieldByName('Plataforma').AsString;
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    SQLBase:= 'SELECT tblNotaManutencao.* FROM tblNotaManutencao '+
    FrmPrincipal.filtroFO+SQLString+
    'AND((Plataforma LIKE '+QuotedStr('%'+Plataforma+'%')+'));';
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    NumRegistros:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
    //=============================================================
    if (NumRegistros > 0) then
    begin
      BarSeriesGRF.AddXY(EixoX,NumRegistros,Plataforma,
      FrmPrincipal.CoresAuto[i]);
      if i <= 13 then
        i:= i+1
      else
        i:= 0;
      EixoX:= EixoX+1;
    end;
    FrmDataModule.ADOQueryConsultaPlataforma.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  ChartGrafico.AddSeries(BarSeriesGRF);
  FrmPrincipal.ProgressBarAtualizar;
end;

procedure TFrmCondicaoOperacional.actGraficoTempoExecute(Sender: TObject);
  var
    BarSeriesGRF: TBarSeries;
    NumRegistros,i: Integer;
    Plataforma,DenominacaoLocalInstalacao,SQLString: String;
    InicioAvaria,Hoje: TDateTime;
begin
  ChartGrafico.RemoveAllSeries;
  ChartGrafico.BottomAxis.Visible:= true;
  ChartGrafico.Legend.CheckBoxes:= false;
  ChartGrafico.Legend.LegendStyle:= lsAuto;
  ChartGrafico.Title.Caption:= 'Filtro por tempo';
  ChartGrafico.Axes.Left.Title.Caption:= 'N° Dias indisponível';
  //===========================================================
  BarSeriesGRF:= carregaSerie;
  i:= 0;
  Hoje:= now;
  SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayoutFO,false);
  if SQLString <>'' then
    SQLString:= 'AND'+SQLString;
  FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(
  'SELECT tblNotaManutencao.* FROM tblNotaManutencao '+
  FrmPrincipal.filtroFO+SQLString+' ORDER BY Plataforma;');
  FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount,
  'Gerando gráfico...');
  while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
  begin
    InicioAvaria:= FrmDataModule.DataSourceTemporarioDBMemoria.
    DataSet.FieldByName('InicioAvaria').AsDateTime;
    Plataforma:= FrmDataModule.DataSourceTemporarioDBMemoria.
    DataSet.FieldByName('Plataforma').AsString;
    DenominacaoLocalInstalacao:= FrmDataModule.DataSourceTemporarioDBMemoria.
    DataSet.FieldByName('DenominacaoLocalInstalacao').AsString;

    NumRegistros:= DaysBetween(InicioAvaria,Hoje);
    //=============================================================
    if (NumRegistros > 0) then
    begin
      BarSeriesGRF.AddXY(InicioAvaria,NumRegistros,Plataforma+'-'+DenominacaoLocalInstalacao,
      FrmPrincipal.CoresAuto[i]);
      if i <= 13 then
        i:= i+1
      else
        i:= 0;
    end;
    FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  ChartGrafico.AddSeries(BarSeriesGRF);
  FrmPrincipal.ProgressBarAtualizar;
end;

procedure TFrmCondicaoOperacional.actGraficoTipoEtapaServicoExecute(
  Sender: TObject);
  var
    BarSeriesGRF: TBarSeries;
    NumRegistros,i,EixoX: Integer;
    TipoEtapaServico,SQLString: String;
begin
  ChartGrafico.RemoveAllSeries;
  ChartGrafico.BottomAxis.Visible:= false;
  ChartGrafico.Legend.CheckBoxes:= false;
  ChartGrafico.Legend.LegendStyle:= lsAuto;
  ChartGrafico.Title.Caption:= 'Filtro por Tipo de Etapa de Serviço';
  ChartGrafico.Axes.Left.Title.Caption:= 'N° Ordens de Manutençăo';
  BarSeriesGRF:= carregaSerie;
  FrmDataModule.ADOQueryTipoEtapaServico.Active:= false;
  FrmDataModule.ADOQueryTipoEtapaServico.Active:= true;
  EixoX:= 0;
  SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayoutFO,false);
  if SQLString <>'' then
    SQLString:= 'AND'+SQLString;
  i:= 0;
