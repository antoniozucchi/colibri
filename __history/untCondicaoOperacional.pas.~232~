  case TabelaIndex of
    0:
    begin
      FrmPrincipal.inserirProcura(DBGridForaOperacao,ColunasLayoutFO);
      actProcurarFO.Execute;
    end;
    1:
    begin
      FrmPrincipal.inserirProcura(DBGridRestricaoOperacional,ColunasLayoutRO);
      actProcurarRO.Execute;
    end;
    2:
    begin
      FrmPrincipal.inserirProcura(DBGridAnaliseGM,ColunasLayoutAnaliseGM);
      actProcurarAnaliseGM.Execute;
    end;
    3:
    begin
      FrmPrincipal.inserirProcura(DBGridListaSIGM,ColunasLayoutListaSIGM);
      actProcurarListaSIGM.Execute;
    end;
    4:
    begin
      FrmPrincipal.inserirProcura(DBGridRegistros,ColunasLayoutRegistros);
      actProcurarRegistros.Execute;
    end;
  end;
  if (FrmPrincipal.PanelFiltrosTabela.Visible)AND(FrmPrincipal.PanelAjuda1.Visible) then
    actFiltrosTabela.Execute;
end;

procedure TFrmCondicaoOperacional.actFiltrosExecute(Sender: TObject);
  var
    PalavraLista,PalavraBusca: String;
    i: Integer;
begin
  //Sistemas
  FrmPrincipal.configurarCheckListBox(CheckListBoxSistemaFiltro,DBGridForaOperacao,ColunasLayoutFO,true);
  //Plataformas
  PalavraBusca:= '';
  for I := 0 to CheckListBoxPlataforma.Count-1 do
  begin
    if CheckListBoxPlataforma.Checked[i] then
    begin
      PalavraLista:= CheckListBoxPlataforma.Items[i];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('Plataforma',PalavraBusca,'Contem',ColunasLayoutFO,4,false);
  //Tipo Etapa Serviço
  PalavraBusca:= '';
  for I := 0 to CheckListBoxTipoEtapaServico.Count-1 do
  begin
    if CheckListBoxTipoEtapaServico.Checked[i] then
    begin
      PalavraLista:= CheckListBoxTipoEtapaServico.Items[i];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('txtTipoEtapaServico',PalavraBusca,'Contem',ColunasLayoutFO,4,false);
  actProcurarFO.Execute;
end;

