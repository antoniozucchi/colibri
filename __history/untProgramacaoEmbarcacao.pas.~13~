procedure TFrmProgramacaoEmbarcacao.ExcelOilRecovery(Tipo: Integer);
var
  Excel, Sheet: Variant;
  i,NumRegistros: Integer;
begin
  actLimparFiltros.Execute;
  FrmPrincipal.buscaFiledGrid1('txtTipoEtapaServico','EMBARCAЫO OIL RECOVERY','Contem',ColunasLayout,4,false);
  if Tipo = 0 then
    FrmPrincipal.buscaFiledGrid1('StatusProgramacao','Aprovado','Contem',ColunasLayout,4,false);
  actProcurar.Execute;
  try
    try
      Excel := CreateOleObject('Excel.Application');
      Excel.Workbooks.Add;
      Excel.Workbooks[1].WorkSheets[1].Name := 'Oil Recovery';
      Sheet := Excel.Workbooks[1].WorkSheets['Oil Recovery'];
      Excel.Caption := 'Oil Recovery';
      // CONFIGURAЫO DO PROGRESSBAR
      NumRegistros:= FrmDataModule.ADOQueryProgramacaoEmbarcacao.RecordCount;
      FrmPrincipal.ProgressBarIncializa(NumRegistros,'Gerando Excel...');
      FrmDataModule.DataSourceProgramacaoEmbarcacao.Enabled:=false;
      FrmDataModule.ADOQueryProgramacaoEmbarcacao.First;
      i:=3;
      Excel.Workbooks[1].Sheets[1].Cells[1,1].NumberFormat:= '@';
      Excel.Workbooks[1].Sheets[1].Cells[1,1] := 'PROGRAMAЫO EMBARCAЫO OIL RECOVERY';
      Sheet.Range['A1','G1'].MergeCells:= true;
      Excel.Workbooks[1].Sheets[1].Cells[2,1].NumberFormat:= '@';
      Excel.Workbooks[1].Sheets[1].Cells[2,1] := 'Data';
      Excel.Workbooks[1].Sheets[1].Cells[2,2].NumberFormat:= '@';
      Excel.Workbooks[1].Sheets[1].Cells[2,2] := 'Hora In獳io';
      Excel.Workbooks[1].Sheets[1].Cells[2,3].NumberFormat:= '@';
      Excel.Workbooks[1].Sheets[1].Cells[2,3] := 'Hora Fim';
      Excel.Workbooks[1].Sheets[1].Cells[2,4].NumberFormat:= '@';
      Excel.Workbooks[1].Sheets[1].Cells[2,4] := 'Destino';
      Excel.Workbooks[1].Sheets[1].Cells[2,5].NumberFormat:= '@';
      Excel.Workbooks[1].Sheets[1].Cells[2,5] := 'Texto Breve da Opera誽o';
      Excel.Workbooks[1].Sheets[1].Cells[2,6].NumberFormat:= '@';
      Excel.Workbooks[1].Sheets[1].Cells[2,6] := 'Embarca誽o';
      Excel.Workbooks[1].Sheets[1].Cells[2,7].NumberFormat:= '@';
      Excel.Workbooks[1].Sheets[1].Cells[2,7] := 'Observa誽o';
      while not FrmDataModule.ADOQueryProgramacaoEmbarcacao.Eof do
      begin
        Excel.Workbooks[1].Sheets[1].Cells[i,1].NumberFormat:= 'dd/mm/aaaa';
        Excel.Workbooks[1].Sheets[1].Cells[i,1] :=FrmDataModule.
        DataSourceProgramacaoEmbarcacao.DataSet.FieldByName('DataProgramacao').AsDateTime;
        Excel.Workbooks[1].Sheets[1].Cells[i,2].NumberFormat:= '@';
        Excel.Workbooks[1].Sheets[1].Cells[i,2] := FrmDataModule.
        DataSourceProgramacaoEmbarcacao.DataSet.FieldByName('HoraInicio').AsString;
        Excel.Workbooks[1].Sheets[1].Cells[i,3].NumberFormat:= '@';
        Excel.Workbooks[1].Sheets[1].Cells[i,3] := FrmDataModule.
        DataSourceProgramacaoEmbarcacao.DataSet.FieldByName('HoraFim').AsString;
        Excel.Workbooks[1].Sheets[1].Cells[i,4].NumberFormat:= '@';
        Excel.Workbooks[1].Sheets[1].Cells[i,4] := FrmDataModule.
        DataSourceProgramacaoEmbarcacao.DataSet.FieldByName('txtDestino').AsString;
        Excel.Workbooks[1].Sheets[1].Cells[i,5].NumberFormat:= '@';
        Excel.Workbooks[1].Sheets[1].Cells[i,5] := FrmDataModule.
        DataSourceProgramacaoEmbarcacao.DataSet.FieldByName('TextoBreveOP').AsString;
        Excel.Workbooks[1].Sheets[1].Cells[i,6].NumberFormat:= '@';
        Excel.Workbooks[1].Sheets[1].Cells[i,6] := FrmDataModule.
        DataSourceProgramacaoEmbarcacao.DataSet.FieldByName('NomeEmbarcacao').AsString;
        Excel.Workbooks[1].Sheets[1].Cells[i,7].NumberFormat:= '@';
        Excel.Workbooks[1].Sheets[1].Cells[i,7] := FrmDataModule.
        DataSourceProgramacaoEmbarcacao.DataSet.FieldByName('Observacao').AsString;
        // CONFIGURAЫO DAS C彳ULAS DAS LINHAS
        Sheet.Rows[i].VerticalAlignment := 2; //2=Center
        Sheet.Rows[i].HorizontalAlignment := 3; //3=Center
        // Atualizar ProgressBar
        FrmPrincipal.ProgressBarIncremento(1);
        FrmDataModule.ADOQueryProgramacaoEmbarcacao.Next;
        i:= i+1;
      end;
      // letras do cabe蓷lho
      Sheet.Rows[1].Font.Bold := true;
      Sheet.Rows[1].Font.Italic := true;
      Sheet.Rows[1].VerticalAlignment := 2; // 1=Top - 2=Center - 3=Bottom
      Sheet.Rows[1].HorizontalAlignment := 3; // 3=Center
      Sheet.Rows[2].Font.Bold := true;
      Sheet.Rows[2].Font.Italic := true;
      Sheet.Rows[2].VerticalAlignment := 2; // 1=Top - 2=Center - 3=Bottom
      Sheet.Rows[2].HorizontalAlignment := 3; // 3=Center
      // desenha as grades da tabela
      Sheet.Range['A1', 'G'+IntToStr(NumRegistros+2)].Borders.LineStyle := 1;
      Sheet.Range['A1', 'G'+IntToStr(NumRegistros+2)].Borders.Weight := 2;
      Sheet.Range['A1', 'G'+IntToStr(NumRegistros+2)].Borders.ColorIndex := 1;
      Sheet.Range['A1', 'G2'].Interior.Color := clSilver;
      // Cor da C幨ula
      Excel.Visible := true;
      Excel.columns.Autofit;
    finally
      FrmDataModule.ADOQueryProgramacaoEmbarcacao.First;
      FrmDataModule.DataSourceProgramacaoEmbarcacao.Enabled:=true;
      // Atualizar ProgressBar
      FrmPrincipal.ProgressBarAtualizar;
    end;
  except
    MessageBox(0, 'Erro de conex緌 com o Excel' + #13 + #10 +
    'Verifique se o Microsoft Office Excel esta instalado na sua m嫭uina.',
    'Excel', MB_ICONERROR);
    // Atualizar ProgressBar
    FrmPrincipal.ProgressBarAtualizar;
  end;
end;

