procedure TFrmProgramacaoEmbarcacao.actProcurarExecute(Sender: TObject);
  var
    SQLString,SQLBase,DataProcuraIncio,DataProcuraFim: String;
    Lista: TStringList;
begin
  Lista:= TStringList.Create;
  DataProcuraIncio:= (FormatDateTime('mm/dd/yyyy',dataInicio.Date));
  DataProcuraFim:= (FormatDateTime('mm/dd/yyyy',dataFim.Date));
  //=======================================================
  SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayout,false);
  if SQLString <> '' then
    SQLString:= ' AND '+SQLString;
  SQLBase:= 'SELECT tblProgramacaoEmbarcacao.* FROM tblProgramacaoEmbarcacao '+
  'WHERE ((DataProgramacao BETWEEN #'+DataProcuraIncio+'# and #'+DataProcuraFim+'#))'+
  SQLString+' ORDER BY DataProgramacao;';
  FrmPrincipal.ProcuraQuery(SQLBase,FrmDataModule.ADOQueryProgramacaoEmbarcacao,
  StatusBar1);
  FrmPrincipal.SetupGridPickListSQL(FrmDataModule.ADOConnectionConsulta,'txtDestino',
  'SELECT tblPlataforma.Plataforma FROM tblPlataforma GROUP BY tblPlataforma.Plataforma;',
  DBGridProgramacaoEmbarcacao,false);
  Lista.Clear;
  Lista.Add('EMBARCAЫO OIL RECOVERY');
  Lista.Add('MERGULHO');
  Lista.Add('LANCHA DE PASSAGEIROS');
  FrmPrincipal.SetupGridPickListLista('txtTipoEtapaServico',Lista,DBGridProgramacaoEmbarcacao);
end;

