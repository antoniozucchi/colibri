procedure TFrmProgramacaoEmbarcacao.actAprovarExecute(Sender: TObject);
  var
    NumRegistros: Integer;
begin
  if not FrmDataModule.ADOQueryProgramacaoEmbarcacao.IsEmpty then
  begin
    FrmDataModule.DataSourceProgramacaoEmbarcacao.Enabled:= false;
    NumRegistros:= FrmDataModule.ADOQueryProgramacaoEmbarcacao.RecordCount;
    FrmDataModule.ADOQueryProgramacaoEmbarcacao.First;
    FrmPrincipal.ProgressBarIncializa(NumRegistros,
    'Atribuindo status para programa誽o...');
    while not FrmDataModule.ADOQueryProgramacaoEmbarcacao.Eof do
    begin
      if FrmDataModule.DataSourceProgramacaoEmbarcacao.DataSet.
      FieldByName('BooleanSelecao').AsBoolean then
      begin
        FrmDataModule.ADOQueryProgramacaoEmbarcacao.Edit;
        FrmDataModule.DataSourceProgramacaoEmbarcacao.DataSet.
        FieldByName('StatusProgramacao').AsString:= 'Aprovado';
        FrmDataModule.DataSourceProgramacaoEmbarcacao.DataSet.
        FieldByName('MotivoCancelamento').AsString:= '';
        FrmDataModule.DataSourceProgramacaoEmbarcacao.DataSet.
        FieldByName('PalavraChaveCancelamento').AsString:= '';
        FrmDataModule.DataSourceProgramacaoEmbarcacao.DataSet.
        FieldByName('AvaliadoPor').AsString:= FrmPrincipal.logChave;
        FrmDataModule.DataSourceProgramacaoEmbarcacao.DataSet.
        FieldByName('ComputadorAvaliacao').AsString:= FrmPrincipal.logMaquina;
        FrmDataModule.DataSourceProgramacaoEmbarcacao.DataSet.
        FieldByName('DataAvaliacao').AsDateTime:= now;
        FrmDataModule.ADOQueryProgramacaoEmbarcacao.Post;
      end;
      FrmDataModule.ADOQueryProgramacaoEmbarcacao.Next;
      FrmPrincipal.ProgressBarIncremento(1);
    end;
    FrmPrincipal.ProgressBarAtualizar;
    FrmDataModule.ADOQueryProgramacaoEmbarcacao.First;
    FrmDataModule.DataSourceProgramacaoEmbarcacao.Enabled:= true;
  end;
end;

