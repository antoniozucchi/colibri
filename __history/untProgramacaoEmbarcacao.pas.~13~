procedure TFrmProgramacaoEmbarcacao.DBGridProgramacaoEmbarcacaoDrawColumnCell(Sender: TObject;
  const Rect: TRect; DataCol: Integer; Column: TColumn; State: TGridDrawState);
  Const
    CtrlState : array[Boolean] of Integer = (DFCS_BUTTONCHECK,
    DFCS_BUTTONCHECK or DFCS_CHECKED);
  var
    CheckBoxRectangle : TRect;
begin
  FrmPrincipal.GridZebrado(DBGridProgramacaoEmbarcacao,ColunasLayout,State,Rect,DataCol,Column);
  if (Column.Field.FieldName = 'BooleanSelecao') then
  begin
    Self.DBGridProgramacaoEmbarcacao.Canvas.FillRect(Rect);
    CheckBoxRectangle.Left := Rect.Left + 2;
    CheckBoxRectangle.Right := Rect.Right - 2;
    CheckBoxRectangle.Top := Rect.Top + 2;
    CheckBoxRectangle.Bottom := Rect.Bottom - 2;
    DrawFrameControl(Self.DBGridProgramacaoEmbarcacao.Canvas.Handle,
    CheckBoxRectangle, DFC_BUTTON,
    CtrlState[Column.Field.AsBoolean]);
  end
  else if (Column.Field.FieldName = 'StatusProgramacao') then
  begin
    if FrmDataModule.DataSourceProgramacaoEmbarcacao.DataSet.
    FieldByName('StatusProgramacao').AsString = 'Aprovado' then
    begin
      DBGridProgramacaoEmbarcacao.Canvas.Brush.Color:= clLime;
      DBGridProgramacaoEmbarcacao.Font.Color:= clBlack;
      DBGridProgramacaoEmbarcacao.Canvas.FillRect(Rect);
      DBGridProgramacaoEmbarcacao.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if FrmDataModule.DataSourceProgramacaoEmbarcacao.DataSet.
    FieldByName('StatusProgramacao').AsString = 'Cancelado' then
    begin
      DBGridProgramacaoEmbarcacao.Canvas.Brush.Color:= clRed;
      DBGridProgramacaoEmbarcacao.Font.Color:= clBlack;
      DBGridProgramacaoEmbarcacao.Canvas.FillRect(Rect);
      DBGridProgramacaoEmbarcacao.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else
    begin
      DBGridProgramacaoEmbarcacao.Canvas.Brush.Color:= clYellow;
      DBGridProgramacaoEmbarcacao.Font.Color:= clBlack;
      DBGridProgramacaoEmbarcacao.Canvas.FillRect(Rect);
      DBGridProgramacaoEmbarcacao.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end;
  end;
  if (gdFocused in State) then
  begin
    if (Column.Field.FieldName= 'HoraInicio') then
    begin
      with MaskEditHoraInicio do
      begin
        Left := Rect.Left + DBGridProgramacaoEmbarcacao.Left + 1;
        Top := Rect.Top + DBGridProgramacaoEmbarcacao.Top + 1;
        Width := Rect.Right - Rect.Left + 2;
        Width := Rect.Right - Rect.Left + 2;
        Height := Rect.Bottom - Rect.Top + 2;
        MaskEditHoraInicio.Text:= DBGridProgramacaoEmbarcacao.DataSource.
        DataSet.FieldByName('HoraInicio').AsString;
        Visible := True;
      end;
    end
    else
      MaskEditHoraInicio.Visible := False;
    //===================================================
    if (Column.Field.FieldName= 'HoraFim') then
    begin
      with MaskEditHoraFim do
      begin
        Left := Rect.Left + DBGridProgramacaoEmbarcacao.Left + 1;
        Top := Rect.Top + DBGridProgramacaoEmbarcacao.Top + 1;
        Width := Rect.Right - Rect.Left + 2;
        Width := Rect.Right - Rect.Left + 2;
        Height := Rect.Bottom - Rect.Top + 2;
        MaskEditHoraFim.Text:= DBGridProgramacaoEmbarcacao.DataSource.
        DataSet.FieldByName('HoraFim').AsString;
        Visible := True;
      end;
    end
    else
      MaskEditHoraFim.Visible := False;
  end;
end;

