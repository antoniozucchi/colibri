procedure TFrmPericiaMarinha.actCarregarOrdemManutencaoExecute(Sender: TObject);
  var
    i: integer;
    ListaOM,ListaProrrogacaoData: TStringList;
begin
  try
    MaskEditRelatorio.Visible:= false;
    FrmPrincipal.MemoLayout.Lines.Text:= FrmDataModule.DataSourcePericiaMarinha.
    DataSet.FieldByName('OrdemManutencao').AsString;
    if ((FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('DeclaracaoPlataforma').AsString = 'Sem Declaração')AND
    ((FrmPrincipal.logPerfil = 'SEG')OR(FrmPrincipal.logPerfil = 'Administrador'))) then
    begin
      try
        FrmDataModule.ADOQueryPericiaMarinha.Edit;
        FrmDataModule.DataSourcePericiaMarinha.DataSet.
        FieldByName('DataDeclaracaoPlataforma').AsString:= '';
        FrmDataModule.ADOQueryPericiaMarinha.Post;
      except
        FrmDataModule.ADOQueryPericiaMarinha.Cancel;
        FrmDataModule.ADOQueryPericiaMarinha.Refresh;
      end;
    end;
    //==================================================================
    if FrmPrincipal.MemoLayout.Lines.Count > 0 then
    begin
      ListaOM:= TStringList.Create;
      ListaOM.delimiter:= ';';
      ListaOM.StrictDelimiter:= true;
      StrGridOrdemManutencao.RowCount:= FrmPrincipal.MemoLayout.Lines.Count+1;
      for i := 0 to FrmPrincipal.MemoLayout.Lines.Count-1 do
      begin
        ListaOM.DelimitedText:= FrmPrincipal.MemoLayout.Lines[i];
        StrGridOrdemManutencao.Cells[0,i+1]:= ListaOM[0];
        StrGridOrdemManutencao.Cells[1,i+1]:= ListaOM[1];
        StrGridOrdemManutencao.Cells[2,i+1]:= ListaOM[2];
        StrGridOrdemManutencao.Cells[3,i+1]:= ListaOM[3];
        StrGridOrdemManutencao.Cells[4,i+1]:= ListaOM[4];
        StrGridOrdemManutencao.Cells[5,i+1]:= ListaOM[5];
        StrGridOrdemManutencao.Cells[6,i+1]:= ListaOM[6];
        StrGridOrdemManutencao.Cells[7,i+1]:= ListaOM[7];
        StrGridOrdemManutencao.Cells[8,i+1]:= ListaOM[8];
      end;
      FrmPrincipal.AutoFitGrade(StrGridOrdemManutencao);
      try
        StrGridOrdemManutencao.FixedRows:=1;
      except
      end;
    end
    else
    begin
      StrGridOrdemManutencao.RowCount:= 1;
    end;
  except
  end;
  //========================================================
  try
    FrmPrincipal.MemoLayout.Lines.Text:= FrmDataModule.DataSourcePericiaMarinha.
    DataSet.FieldByName('ProrrogacaoData').AsString;
    if FrmPrincipal.MemoLayout.Lines.Count > 0 then
    begin
      ListaProrrogacaoData:= TStringList.Create;
      ListaProrrogacaoData.delimiter:= ';';
      ListaProrrogacaoData.StrictDelimiter:= true;
      StrGridProrrogacaoData.RowCount:= FrmPrincipal.MemoLayout.Lines.Count+1;
      for i := 0 to FrmPrincipal.MemoLayout.Lines.Count-1 do
      begin
        ListaProrrogacaoData.DelimitedText:= FrmPrincipal.MemoLayout.Lines[i];
        StrGridProrrogacaoData.Cells[1,i+1]:= ListaProrrogacaoData[0];
        StrGridProrrogacaoData.Cells[2,i+1]:= ListaProrrogacaoData[1];
      end;
      FrmPrincipal.AutoFitGrade(StrGridProrrogacaoData);
      StrGridProrrogacaoData.ColWidths[0]:= 20;
      try
        StrGridProrrogacaoData.FixedRows:=1;
      except
      end;
    end
    else
    begin
      StrGridProrrogacaoData.RowCount:= 1;
    end;
  except
  end;
end;

