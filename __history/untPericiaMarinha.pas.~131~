procedure TFrmPericiaMarinha.actOrdemManutencaoExecute(Sender: TObject);
  var
    Relatorio,SQLBase,txtProcura,txtItem,TextoLongoCarteira,CentroTrabalhoOP,CentroTrabalhoOM,
    Sala,OrdemManutencao1,OrdemManutencao2,Operacao,TextoBreveOM,TextoBreveOP,Trabalho,TrabalhoReal: String;
    Item: Integer;
    SQLString,palavraBusca: String;
begin
  try
    Relatorio:= FrmDataModule.DataSourcePericiaMarinha.DataSet.FieldByName('Relatorio').AsString;
    Item:= FrmDataModule.DataSourcePericiaMarinha.DataSet.FieldByName('Item').AsInteger;
    txtItem:= FormatFloat('00',Item);
    txtProcura:= Relatorio+'.'+txtItem;
    SQLBase:= 'SELECT tblCarteiraTrabalho.* FROM tblCarteiraTrabalho '+
    'WHERE ((Sala LIKE '+QuotedStr('%'+txtProcura+'%')+
    ')OR(TextoBreveOM LIKE '+QuotedStr('%'+txtProcura+'%')+'))'+
    ' ORDER BY OrdemManutencao,Operacao;';
    FrmDataModule.ADOQueryIW37N.Close;
    FrmDataModule.ADOQueryIW37N.SQL.Clear;
    FrmDataModule.ADOQueryIW37N.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryIW37N.Open;
    if not FrmDataModule.ADOQueryIW37N.IsEmpty then
    begin
      FrmPrincipal.MemoLayout.Lines.Clear;
      MemoMarinha.Lines.Clear;
      OrdemManutencao1:='111111111';
      while not FrmDataModule.ADOQueryIW37N.Eof do
      begin
        Sala:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('Sala').AsString;
        OrdemManutencao2:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('OrdemManutencao').AsString;
        Operacao:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('Operacao').AsString;
        TextoBreveOM:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('TextoBreveOM').AsString;
        TextoBreveOP:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('TextoBreveOP').AsString;
        Trabalho:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('Trabalho').AsString;
        TrabalhoReal:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('TrabalhoReal').AsString;
        CentroTrabalhoOP:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('CentroTrabalhoOP').AsString;
        CentroTrabalhoOM:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('CentroTrabalhoOM').AsString;
        //=======================================
        FrmPrincipal.MemoLayout.Lines.Add(Sala+';'+
        OrdemManutencao2+';'+
        CentroTrabalhoOM+';'+
        TextoBreveOM+';'+
        Operacao+';'+
        CentroTrabalhoOP+';'+
        TextoBreveOP+';'+
        Trabalho+';'+
        TrabalhoReal);
        //========================================
        if OrdemManutencao1<>OrdemManutencao2 then
        begin
          TextoLongoCarteira:=  FrmPrincipal.verificaTextoLongoCarteira(OrdemManutencao2);
          MemoMarinha.Lines.Add('======== (Ordem de Manutenção: '+OrdemManutencao2+') ========');
          MemoMarinha.Lines.Add(TextoLongoCarteira);
          MemoMarinha.Lines.Add('');
          FrmDataModule.ADOQueryPericiaMarinha.Edit;
          FrmDataModule.DataSourcePericiaMarinha.DataSet.
          FieldByName('TextoLongoOM').AsString:= MemoMarinha.Lines.Text;
          FrmDataModule.ADOQueryPericiaMarinha.Post;
          OrdemManutencao1:=OrdemManutencao2;
        end;
        //========================================
        FrmDataModule.ADOQueryIW37N.Next;
      end;
      FrmDataModule.ADOQueryPericiaMarinha.Edit;
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('OrdemManutencao').AsString:=
      FrmPrincipal.MemoLayout.Lines.Text;
      FrmDataModule.ADOQueryPericiaMarinha.Post;
    end;
    //Busca pelo texto longo da OM
    SQLString:= '';
    SQLString:= FrmPrincipal.palavraBusca(SQLString,'TextoLongoCarteira','Contem',txtProcura);
    if SQLString <> '' then
    begin
      SQLString:= 'WHERE'+SQLString;
    end;
    SQLBase:= 'SELECT tblTextoLongoCarteira.* FROM tblTextoLongoCarteira '+
    SQLString+';';
    FrmPrincipal.ProcuraQuery(SQLBase,FrmDataModule.ADOQueryTemporarioDBMemoria,
    StatusBarPericiaMarinha);
    if not FrmDataModule.ADOQueryTemporarioDBMemoria.IsEmpty then
    begin
      PalavraBusca:= '';
      FrmDataModule.ADOQueryTemporarioDBMemoria.First;
      while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
      begin
        if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+FrmDataModule.DataSourceTemporarioDBMemoria.
        DataSet.FieldByName('OrdemManutencao').AsString
      else
        PalavraBusca:= FrmDataModule.DataSourceTemporarioDBMemoria.
        DataSet.FieldByName('OrdemManutencao').AsString;
        FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
      end;
    end;
    SQLString:= '';
    SQLString:= FrmPrincipal.palavraBusca(SQLString,'OrdemManutencao','Contem',PalavraBusca);
    SQLString:= 'WHERE'+SQLString;
    SQLBase:= 'SELECT tblCarteiraTrabalho.* FROM tblCarteiraTrabalho '+
    SQLString+' ORDER BY OrdemManutencao,Operacao;';
    FrmDataModule.ADOQueryIW37N.Close;
    FrmDataModule.ADOQueryIW37N.SQL.Clear;
    FrmDataModule.ADOQueryIW37N.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryIW37N.Open;
    if not FrmDataModule.ADOQueryIW37N.IsEmpty then
    begin
      FrmPrincipal.MemoLayout.Lines.Clear;
      MemoMarinha.Lines.Clear;
      OrdemManutencao1:='111111111';
      while not FrmDataModule.ADOQueryIW37N.Eof do
      begin
        Sala:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('Sala').AsString;
        OrdemManutencao2:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('OrdemManutencao').AsString;
        Operacao:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('Operacao').AsString;
        TextoBreveOM:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('TextoBreveOM').AsString;
        TextoBreveOP:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('TextoBreveOP').AsString;
        Trabalho:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('Trabalho').AsString;
        TrabalhoReal:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('TrabalhoReal').AsString;
        CentroTrabalhoOP:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('CentroTrabalhoOP').AsString;
        CentroTrabalhoOM:= FrmDataModule.DataSourceIW37N.DataSet.FieldByName('CentroTrabalhoOM').AsString;
        //=======================================
        FrmPrincipal.MemoLayout.Lines.Add(Sala+';'+
        OrdemManutencao2+';'+
        CentroTrabalhoOM+';'+
        TextoBreveOM+';'+
        Operacao+';'+
        CentroTrabalhoOP+';'+
        TextoBreveOP+';'+
        Trabalho+';'+
        TrabalhoReal);
        //========================================
        if OrdemManutencao1<>OrdemManutencao2 then
        begin
          TextoLongoCarteira:=  FrmPrincipal.verificaTextoLongoCarteira(OrdemManutencao2);
          MemoMarinha.Lines.Add('================= (Ordem de Manutenção: '+OrdemManutencao2+') =================');
          MemoMarinha.Lines.Add(TextoLongoCarteira);
          MemoMarinha.Lines.Add('');
          FrmDataModule.ADOQueryPericiaMarinha.Edit;
          FrmDataModule.DataSourcePericiaMarinha.DataSet.
          FieldByName('TextoLongoOM').AsString:=
          MemoMarinha.Lines.Text;
          FrmDataModule.ADOQueryPericiaMarinha.Post;
          OrdemManutencao1:=OrdemManutencao2;
        end;
        //========================================
        FrmDataModule.ADOQueryIW37N.Next;
      end;
      FrmDataModule.ADOQueryPericiaMarinha.Edit;
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('OrdemManutencao').AsString:=
      FrmPrincipal.MemoLayout.Lines.Text;
      FrmDataModule.ADOQueryPericiaMarinha.Post;
    end;
  except
  end;
end;

procedure TFrmPericiaMarinha.actOrdemManutencaoLimparExecute(Sender: TObject);
begin
  FrmDataModule.ADOQueryPericiaMarinha.Edit;
  FrmDataModule.DataSourcePericiaMarinha.DataSet.FieldByName('TextoLongoOM').AsString:= '';
  FrmDataModule.DataSourcePericiaMarinha.DataSet.FieldByName('OrdemManutencao').AsString:= '';
  FrmDataModule.ADOQueryPericiaMarinha.Post;
  actCarregarOrdemManutencao.Execute;
end;

procedure TFrmPericiaMarinha.actOrdemManutencaoTodosExecute(Sender: TObject);
begin
  try
    FrmDataModule.DataSourcePericiaMarinha.Enabled:= false;
    FrmDataModule.ADOQueryPericiaMarinha.First;
    FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryPericiaMarinha.RecordCount,
    'Carregando Ordens de Manutenção');
    while not FrmDataModule.ADOQueryPericiaMarinha.Eof do
    begin
      actOrdemManutencao.Execute;
      FrmDataModule.ADOQueryPericiaMarinha.Next;
      FrmPrincipal.ProgressBarIncremento(1);
    end;
    FrmPrincipal.ProgressBarAtualizar;
    FrmDataModule.DataSourcePericiaMarinha.Enabled:= true;
    FrmDataModule.ADOQueryPericiaMarinha.First;
  except
    ShowMessage('Não foi possível conectar com o banco de dados');
  end;
end;

