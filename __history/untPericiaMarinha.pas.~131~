procedure TFrmPericiaMarinha.actSalvarProrrogacaoDataExecute(Sender: TObject);
  var
    data,nota,TipoRelatorio,SQLBase,Plataforma,Operacional: String;
    i,DiasProrrogacao,DiasProrrogacaoFLAG,NumeroProrrogacao,IntDiferenca: Integer;
    DataPericia,DataPericiaReferencia: TDateTime;
begin
  MemoMarinha.Lines.Clear;
  DiasProrrogacao:= 0;
  NumeroProrrogacao:= StrGridProrrogacaoData.RowCount-2;
  //============================================================================
  for I := 1 to StrGridProrrogacaoData.RowCount-1 do
  begin
    data:= StrGridProrrogacaoData.Cells[1,i];
    nota:= StrGridProrrogacaoData.Cells[2,i];
    MemoMarinha.Lines.Add(data+';'+nota);
    try
      DiasProrrogacao:= DiasProrrogacao+StrToInt(data);
    except
    end;
  end;
  //============================================================================
  DataPericia:= FrmDataModule.DataSourcePericiaMarinha.DataSet.FieldByName('DataPericia').AsDateTime;
  TipoRelatorio:= FrmDataModule.DataSourcePericiaMarinha.DataSet.FieldByName('TipoRelatorio').AsString;
  Plataforma:= FrmDataModule.DataSourcePericiaMarinha.DataSet.FieldByName('Plataforma').AsString;
  Operacional:= FrmDataModule.DataSourcePericiaMarinha.DataSet.FieldByName('Operacional').AsString;
  if ((TipoRelatorio = 'Flag state')AND(Operacional = 'Operacional')) then
  begin
    SQLBase:= 'SELECT tblPericiaMarinha.* FROM tblPericiaMarinha '+
    'WHERE ((TipoRelatorio LIKE "Perícia inicial")AND(Plataforma LIKE '+QuotedStr(Plataforma)+
    ')) ORDER BY DataPericia DESC;';
