  Retificado:= 0;
  Verde:= 0;
  Amarelo:= 0;
  Vermelho:= 0;
  Data1:= FrmPrincipal.DiasFinalCorridos(Now,PrazoCores1);
  Data2:= FrmPrincipal.DiasFinalCorridos(Now,PrazoCores2);
  i:= 0;
  FrmDataModule.ADOQueryPericiaMarinha.Sort := 'Gerencia ASC';
