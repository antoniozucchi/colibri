    FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
    FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
    FrmDataModule.ADOQueryTemporarioDBConsulta1.First;
    if not FrmDataModule.ADOQueryTemporarioDBConsulta1.IsEmpty then
    begin
      DataPericiaReferencia:= FrmDataModule.DataSourceTemporarioDBConsulta1.DataSet.
      FieldByName('DataPericia').AsDateTime;
      //==========================================================================
      IntDiferenca:= DaysBetween(DataPericiaReferencia,DataPericia);
      DiasProrrogacaoFLAG:= DiasProrrogacao + IntDiferenca;
      FrmDataModule.ADOQueryPericiaMarinha.Edit;
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('ProrrogacaoData').AsString:= MemoMarinha.Lines.Text;
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('DataVencimento').AsDateTime:= IncDay(DataPericia,DiasProrrogacao);
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
