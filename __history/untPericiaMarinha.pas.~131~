    FieldByName('Operacional').AsString = 'Operacional' then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clLime;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clRed;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
  end
  else if (Column.Field.FieldName = 'Atendido') then
  begin
    if FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('Atendido').AsString = 'Sim' then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clLime;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('Atendido').AsString = 'Não' then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clRed;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('Atendido').AsString = 'Parcial' then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clYellow;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clAqua;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
  end
  else if (Column.Field.FieldName = 'TotalDiasProrrogacao') then
  begin
    if (FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('TotalDiasProrrogacao').AsInteger >= 365) then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clRed;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if ((FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('TotalDiasProrrogacao').AsInteger >= 275)AND
    (FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('TotalDiasProrrogacao').AsInteger < 365)) then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clFuchsia;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if ((FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('TotalDiasProrrogacao').AsInteger >= 185)AND(FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('TotalDiasProrrogacao').AsInteger < 275)) then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clYellow;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if ((FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('TotalDiasProrrogacao').AsInteger < 185)) then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clLime;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
  end
  else if (Column.Field.FieldName = 'DataVencimento') then
  begin
    if (FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('Retificado').AsString = 'Retificado') then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clSilver;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else
    begin
      DataVencimento:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('DataVencimento').AsDateTime;
      Data1:= FrmPrincipal.DiasFinalCorridos(Now,PrazoCores1);
      Data2:= FrmPrincipal.DiasFinalCorridos(Now,PrazoCores2);
      if (DataVencimento >= Data2) then
      begin
        DBGridPericiaMarinha.Canvas.Brush.Color:= clLime;
        DBGridPericiaMarinha.Font.Color:= clBlack;
        DBGridPericiaMarinha.Canvas.FillRect(Rect);
        DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end
      else if ((DataVencimento < Data2)AND(DataVencimento > Data1)) then
      begin
        DBGridPericiaMarinha.Canvas.Brush.Color:= clYellow;
        DBGridPericiaMarinha.Font.Color:= clBlack;
        DBGridPericiaMarinha.Canvas.FillRect(Rect);
        DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end
      else if (DataVencimento <= Data1) then
      begin
        DBGridPericiaMarinha.Canvas.Brush.Color:= clRed;
        DBGridPericiaMarinha.Font.Color:= clBlack;
        DBGridPericiaMarinha.Canvas.FillRect(Rect);
        DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end;
    end;
  end
  else if (Column.Field.FieldName = 'DataDeclaracaoPlataforma') then
  begin
    if (FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('DeclaracaoPlataforma').AsString = 'Sem Declaração') then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clSilver;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if (FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('DeclaracaoPlataforma').AsString = 'Definitiva') then
    begin
      DBGridPericiaMarinha.Canvas.Brush.Color:= clAqua;
      DBGridPericiaMarinha.Font.Color:= clBlack;
      DBGridPericiaMarinha.Canvas.FillRect(Rect);
      DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else
    begin
      DataVencimento:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('DataDeclaracaoPlataforma').AsDateTime;
      Data1:= FrmPrincipal.DiasFinalCorridos(Now,10);
      if (DataVencimento >= Data1) then
      begin
        DBGridPericiaMarinha.Canvas.Brush.Color:= clLime;
        DBGridPericiaMarinha.Font.Color:= clBlack;
        DBGridPericiaMarinha.Canvas.FillRect(Rect);
        DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end
      else
      begin
        DBGridPericiaMarinha.Canvas.Brush.Color:= clRed;
        DBGridPericiaMarinha.Font.Color:= clBlack;
        DBGridPericiaMarinha.Canvas.FillRect(Rect);
        DBGridPericiaMarinha.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end;
    end;
  end;
  if (gdFocused in State) then
  begin
    //=============================================================
    if (DBGridPericiaMarinha.SelectedField.FieldName= 'DataPericia')AND(PermiteAlterar) then
    begin
      with DBDateTimeDataPericia do
      begin
        Left := Rect.Left + DBGridPericiaMarinha.Left + 1;
        Top := Rect.Top + DBGridPericiaMarinha.Top + 1;
        Width := Rect.Right - Rect.Left + 2;
        Width := Rect.Right - Rect.Left + 2;
        Height := Rect.Bottom - Rect.Top + 2;
        Visible := True;
      end;
    end
    else
      DBDateTimeDataPericia.Visible := False;
    //=============================================================
    if (DBGridPericiaMarinha.SelectedField.FieldName= 'Relatorio')AND
    (PermiteAlterar) then
    begin
      with MaskEditRelatorio do
      begin
        Left := Rect.Left + DBGridPericiaMarinha.Left + 1;
        Top := Rect.Top + DBGridPericiaMarinha.Top + 1;
        Width := Rect.Right - Rect.Left + 2;
        Width := Rect.Right - Rect.Left + 2;
        Height := Rect.Bottom - Rect.Top + 2;
        MaskEditRelatorio.Text:= DBGridPericiaMarinha.DataSource.
        DataSet.FieldByName('Relatorio').AsString;
        Visible := True;
      end;
    end
    else
      MaskEditRelatorio.Visible := False;
  end;
end;

