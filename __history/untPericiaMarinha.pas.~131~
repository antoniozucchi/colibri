      end;
      if Verde<>0 then
      begin
        BarSeriesGRF.AddXY(i,Verde,Gerencia1,clLime);
        i:= i+1;
      end;
      if Amarelo<>0 then
      begin
        BarSeriesGRF.AddXY(i,Amarelo,Gerencia1,clYellow);
        i:= i+1;
      end;
      if Vermelho<>0 then
      begin
        BarSeriesGRF.AddXY(i,Vermelho,Gerencia1,clRed);
        i:= i+1;
      end;
      Gerencia1 := Gerencia2;
      Retificado:= 0;
      Verde:= 0;
      Amarelo:= 0;
      Vermelho:= 0;
      if (FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('Retificado').AsString = 'Retificado') then
      begin
        Retificado:= Retificado+1;
      end
      else
      begin
        DataVencimento:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
        FieldByName('DataVencimento').AsDateTime;
        if (DataVencimento >= Data2) then
          Verde:= Verde+1
        else if ((DataVencimento < Data2)AND(DataVencimento > Data1)) then
          Amarelo:= Amarelo+1
        else if (DataVencimento <= Data1) then
          Vermelho:= Vermelho+1;
      end;
    end;
    FrmDataModule.ADOQueryPericiaMarinha.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  if Retificado<>0 then
  begin
    BarSeriesGRF.AddXY(i,Retificado,Gerencia1,clSilver);
    i:= i+1;
  end;
  if Verde<>0 then
  begin
    BarSeriesGRF.AddXY(i,Verde,Gerencia1,clLime);
    i:= i+1;
  end;
  if Amarelo<>0 then
  begin
    BarSeriesGRF.AddXY(i,Amarelo,Gerencia1,clYellow);
    i:= i+1;
  end;
  if Vermelho<>0 then
  begin
    BarSeriesGRF.AddXY(i,Vermelho,Gerencia1,clRed);
  end;
  FrmDataModule.ADOQueryPericiaMarinha.First;
  //=======================================================================
  ChartGrafico.AddSeries(BarSeriesGRF);
  FrmPrincipal.ProgressBarAtualizar;
end;

