      FrmDataModule.ADOQueryPericiaMarinha.Post;
      FrmPrincipal.MenssagemStatus('Perícia inicial: Não encontrado');
    end;
  end
  else if ((TipoRelatorio = 'Flag state')AND(Operacional = 'Fora Operação')) then
  begin
    SQLBase:= 'SELECT tblPericiaMarinha.* FROM tblPericiaMarinha '+
    'WHERE ((TipoRelatorio LIKE "Inicial Flag")AND(Plataforma LIKE '+QuotedStr(Plataforma)+
