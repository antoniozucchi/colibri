procedure TFrmPericiaMarinha.actPIEPrazoAtendimentoExecute(Sender: TObject);
  var
    PieGRF: TPieSeries;
    NumRegistros,Vermelho,Amarelo,Verde: Integer;
    PrazoAtendimento: TDateTime;
begin
  ChartGrafico.Title.Caption:= RadioGroupEixoX.Items.Strings[RadioGroupEixoX.ItemIndex];
  ChartGrafico.Legend.Visible:= true;
  ChartGrafico.Axes.Left.Title.Caption:= 'Prorrogação Declaração';
  ChartGrafico.RemoveAllSeries;
  ChartGrafico.BottomAxis.Visible:= false;
  ChartGrafico.Legend.CheckBoxes:= false;
  PieGRF:= TPieSeries.Create(ChartGrafico);
  //=================================================
  Vermelho:= 0;
  Amarelo:= 0;
  Verde:= 0;
  FrmDataModule.ADOQueryPericiaMarinha.First;
  NumRegistros:= FrmDataModule.ADOQueryPericiaMarinha.RecordCount;
  FrmPrincipal.ProgressBarIncializa(NumRegistros,'Gerando gráfico...');
  while not FrmDataModule.ADOQueryPericiaMarinha.Eof do
  begin
    PrazoAtendimento:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('PrazoAtendimento').AsDateTime;
    if (PrazoAtendimento <= now) then
      Vermelho:= Vermelho+1
    else if ((PrazoAtendimento > now)AND(PrazoAtendimento <= IncDay(now,30))) then
      Amarelo:= Amarelo+1
    else if (PrazoAtendimento > IncDay(now,30)) then
      Verde:= Verde+1;

    FrmDataModule.ADOQueryPericiaMarinha.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmDataModule.ADOQueryPericiaMarinha.First;
  if Verde <> 0 then
    PieGRF.AddPie(Verde,'Mais de 30d: '+
    FormatFloat('0.0%',(Verde*100)/NumRegistros),clLime);
  if Amarelo <> 0 then
    PieGRF.AddPie(Amarelo,'Menos de 30d: '+
    FormatFloat('0.0%',(Amarelo*100)/NumRegistros),clYellow);
  if Vermelho <> 0 then
    PieGRF.AddPie(Vermelho,'Vencido: '+
    FormatFloat('0.0%',(Vermelho*100)/NumRegistros),clRed);
  //=======================================================================
  ChartGrafico.AddSeries(PieGRF);
  FrmPrincipal.ProgressBarAtualizar;
end;

procedure TFrmPericiaMarinha.actPIEProrrogacaoExecute(Sender: TObject);
  var
    PieGRF: TPieSeries;
    TotalDiasProrrogacao,NumRegistros,ProrroRed,ProrroOrange,
    ProrroYellow,ProrroGreen: Integer;
begin
  ChartGrafico.Title.Caption:= RadioGroupEixoX.Items.Strings[RadioGroupEixoX.ItemIndex];
  ChartGrafico.Legend.Visible:= true;
  ChartGrafico.Axes.Left.Title.Caption:= 'Prorrogação Declaração';
  ChartGrafico.RemoveAllSeries;
  ChartGrafico.BottomAxis.Visible:= false;
  ChartGrafico.Legend.CheckBoxes:= false;
  PieGRF:= TPieSeries.Create(ChartGrafico);
  //=================================================
  ProrroRed:= 0;
  ProrroOrange:= 0;
  ProrroYellow:= 0;
  ProrroGreen:= 0;
  FrmDataModule.ADOQueryPericiaMarinha.First;
  NumRegistros:= FrmDataModule.ADOQueryPericiaMarinha.RecordCount;
  FrmPrincipal.ProgressBarIncializa(NumRegistros,'Gerando gráfico...');
  while not FrmDataModule.ADOQueryPericiaMarinha.Eof do
  begin
    TotalDiasProrrogacao:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('TotalDiasProrrogacao').AsInteger;
    if (TotalDiasProrrogacao >= 365) then
      ProrroRed:= ProrroRed+1
    else if ((TotalDiasProrrogacao >= 275)AND(TotalDiasProrrogacao < 365)) then
      ProrroOrange:= ProrroOrange+1
    else if ((TotalDiasProrrogacao >= 185)AND(TotalDiasProrrogacao < 275)) then
      ProrroYellow:= ProrroYellow+1
    else if (TotalDiasProrrogacao < 185) then
      ProrroGreen:= ProrroGreen+1;
    FrmDataModule.ADOQueryPericiaMarinha.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmDataModule.ADOQueryPericiaMarinha.First;
  if ProrroGreen <> 0 then
    PieGRF.AddPie(ProrroGreen,'1° e 2° até 185d: '+
    FormatFloat('0.0%',(ProrroGreen*100)/NumRegistros),clLime);
  if ProrroYellow <> 0 then
    PieGRF.AddPie(ProrroYellow,'3° até 275d: '+
    FormatFloat('0.0%',(ProrroYellow*100)/NumRegistros),clYellow);
  if ProrroOrange <> 0 then
    PieGRF.AddPie(ProrroOrange,'4° até 365d: '+
    FormatFloat('0.0%',(ProrroOrange*100)/NumRegistros),clFuchsia);
  if ProrroRed <> 0 then
    PieGRF.AddPie(ProrroRed,'Vencido: '+
    FormatFloat('0.0%',(ProrroRed*100)/NumRegistros),clRed);
  //=======================================================================
  ChartGrafico.AddSeries(PieGRF);
  FrmPrincipal.ProgressBarAtualizar;
end;

procedure TFrmPericiaMarinha.actPIEVencimentoExecute(Sender: TObject);
  var
    PieGRF: TPieSeries;
    DataVencimento,Data1,Data2: TDateTime;
    NumRegistros,Retificado,Verde,Amarelo,Vermelho: Integer;
begin
  ChartGrafico.Title.Caption:= RadioGroupEixoX.Items.Strings[RadioGroupEixoX.ItemIndex];
  ChartGrafico.Legend.Visible:= true;
  ChartGrafico.Axes.Left.Title.Caption:= 'Data de Vencimento';
  ChartGrafico.RemoveAllSeries;
  ChartGrafico.BottomAxis.Visible:= false;
  ChartGrafico.Legend.CheckBoxes:= false;
  PieGRF:= TPieSeries.Create(ChartGrafico);
  //=================================================
  Retificado:= 0;
  Verde:= 0;
  Amarelo:= 0;
  Vermelho:= 0;
  Data1:= FrmPrincipal.DiasFinalCorridos(Now,PrazoCores1);
  Data2:= FrmPrincipal.DiasFinalCorridos(Now,PrazoCores2);
  FrmDataModule.ADOQueryPericiaMarinha.First;
  NumRegistros:= FrmDataModule.ADOQueryPericiaMarinha.RecordCount;
  FrmPrincipal.ProgressBarIncializa(NumRegistros,'Gerando gráfico...');
  while not FrmDataModule.ADOQueryPericiaMarinha.Eof do
  begin
    if (FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('Retificado').AsString = 'Retificado') then
    begin
      Retificado:= Retificado+1;
    end
    else
    begin
      DataVencimento:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('DataVencimento').AsDateTime;
      if (DataVencimento >= Data2) then
        Verde:= Verde+1
      else if ((DataVencimento < Data2)AND(DataVencimento > Data1)) then
        Amarelo:= Amarelo+1
      else if (DataVencimento <= Data1) then
        Vermelho:= Vermelho+1;
    end;
    FrmDataModule.ADOQueryPericiaMarinha.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmDataModule.ADOQueryPericiaMarinha.First;
  if Retificado <> 0 then
    PieGRF.AddPie(Retificado,'Retificado'+
    FormatFloat(': 0.0%',(Retificado*100)/NumRegistros),clSilver);
  if Verde <> 0 then
    PieGRF.AddPie(Verde,'X >='+DateToStr(Data2)+
    FormatFloat(': 0.0%',(Verde*100)/NumRegistros),clLime);
  if Amarelo <> 0 then
    PieGRF.AddPie(Amarelo,DateToStr(Data1)+' < X < '+DateToStr(Data2)+
    FormatFloat(': 0.0%',(Amarelo*100)/NumRegistros),clYellow);
  if Vermelho <> 0 then
    PieGRF.AddPie(Vermelho,'X <='+DateToStr(Data1)+
    FormatFloat(': 0.0%',(Vermelho*100)/NumRegistros),clRed);
  //=======================================================================
  ChartGrafico.AddSeries(PieGRF);
  FrmPrincipal.ProgressBarAtualizar;
end;

procedure TFrmPericiaMarinha.actGRFPrazoAtendimentoExecute(Sender: TObject);
  var
    LineVencimento,LinePrazoAtendimento,LineMaxProrrogacao: TLineSeries;
    Plataforma,Gerencia,Relatorio,Texto: String;
    DataVencimento,PrazoAtendimento,MaxProgramacao: TDateTime;
begin
  ChartGrafico.Title.Caption:= RadioGroupEixoX.Items.Strings[RadioGroupEixoX.ItemIndex];
  ChartGrafico.Legend.Visible:= true;
  ChartGrafico.Axes.Left.Title.Caption:= 'Prazo Atendimento';
  ChartGrafico.RemoveAllSeries;
  ChartGrafico.BottomAxis.Visible:= false;
  ChartGrafico.Legend.CheckBoxes:= true;
  //=================================================
  LinePrazoAtendimento:= TLineSeries.Create(ChartGrafico);
  LinePrazoAtendimento.Pointer.Size:= 4;
  LinePrazoAtendimento.Pointer.Visible:= true;
  LinePrazoAtendimento.Pointer.Style:= TSeriesPointerStyle(1);
  LinePrazoAtendimento.Color:= clBlue;
  LinePrazoAtendimento.Title:= 'Prazo Atendimento';
  LinePrazoAtendimento.YValues.DateTime:= true;
  //=================================================
  LineVencimento:= TLineSeries.Create(ChartGrafico);
  LineVencimento.Pointer.Size:= 4;
  LineVencimento.Pointer.Visible:= true;
  LineVencimento.Pointer.Style:= TSeriesPointerStyle(2);
  LineVencimento.Color:= clGreen;
  LineVencimento.Title:= 'Data Vencimento';
  LineVencimento.YValues.DateTime:= true;
  //=================================================
  LineMaxProrrogacao:= TLineSeries.Create(ChartGrafico);
  LineMaxProrrogacao.Pointer.Size:= 4;
  LineMaxProrrogacao.Pointer.Visible:= true;
  LineMaxProrrogacao.Pointer.Style:= TSeriesPointerStyle(3);
  LineMaxProrrogacao.Color:= clRed;
  LineMaxProrrogacao.Title:= 'Máxima Prorrogação';
  LineMaxProrrogacao.YValues.DateTime:= true;
  //=================================================
  FrmDataModule.DataSourcePericiaMarinha.Enabled:= false;
  FrmDataModule.ADOQueryPericiaMarinha.First;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryPericiaMarinha.
  RecordCount,'Gerando gráfico...');
  while not FrmDataModule.ADOQueryPericiaMarinha.Eof do
  begin
    DataVencimento:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('DataVencimento').AsDateTime;
    MaxProgramacao:= IncYear(FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('DataPericia').AsDateTime,1);
    PrazoAtendimento:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('PrazoAtendimento').AsDateTime;
    Plataforma:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('Plataforma').AsString;
    Gerencia:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('Gerencia').AsString;
    Relatorio:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('Relatorio').AsString+'.'+FrmDataModule.DataSourcePericiaMarinha.DataSet.
    FieldByName('Item').AsString;
    Texto:= Plataforma+';'+Gerencia+';'+Relatorio;
    LineVencimento.AddY(DataVencimento,Texto,clGreen);
    LinePrazoAtendimento.AddY(PrazoAtendimento,Texto,clBlue);
    LineMaxProrrogacao.AddY(MaxProgramacao,Texto,clRed);
    FrmDataModule.ADOQueryPericiaMarinha.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmDataModule.ADOQueryPericiaMarinha.First;
  FrmDataModule.DataSourcePericiaMarinha.Enabled:= true;
  //=======================================================================
  ChartGrafico.AddSeries(LineVencimento);
  ChartGrafico.AddSeries(LinePrazoAtendimento);
  ChartGrafico.AddSeries(LineMaxProrrogacao);
  actEtiqueta.Execute;
  FrmPrincipal.ProgressBarAtualizar;
end;

