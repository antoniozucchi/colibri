procedure TFrmPericiaMarinha.DBGridResumoCartaDrawColumnCell(Sender: TObject;
  const Rect: TRect; DataCol: Integer; Column: TColumn; State: TGridDrawState);
    var
      DataVencimento,Data1,Data2: TDateTime;
begin
  FrmPrincipal.GridZebrado(DBGridResumoCarta,ColunasLayoutResumoCarta,State,Rect,DataCol,Column);
  if (Column.Field.FieldName = 'DataVencimento') then
  begin
    if (FrmDataModule.DataSourceResumoCarta.DataSet.
    FieldByName('Retificado').AsString = 'Retificado') then
    begin
      DBGridResumoCarta.Canvas.Brush.Color:= clSilver;
      DBGridResumoCarta.Font.Color:= clBlack;
      DBGridResumoCarta.Canvas.FillRect(Rect);
      DBGridResumoCarta.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else
    begin
      DataVencimento:= FrmDataModule.DataSourceResumoCarta.DataSet.
      FieldByName('DataVencimento').AsDateTime;
      Data1:= FrmPrincipal.DiasFinalCorridos(Now,PrazoCores1);
      Data2:= FrmPrincipal.DiasFinalCorridos(Now,PrazoCores2);
      if (DataVencimento >= Data2) then
      begin
        DBGridResumoCarta.Canvas.Brush.Color:= clLime;
        DBGridResumoCarta.Font.Color:= clBlack;
        DBGridResumoCarta.Canvas.FillRect(Rect);
        DBGridResumoCarta.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end
      else if ((DataVencimento < Data2)AND(DataVencimento > Data1)) then
      begin
        DBGridResumoCarta.Canvas.Brush.Color:= clYellow;
        DBGridResumoCarta.Font.Color:= clBlack;
        DBGridResumoCarta.Canvas.FillRect(Rect);
        DBGridResumoCarta.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end
      else if (DataVencimento <= Data1) then
      begin
        DBGridResumoCarta.Canvas.Brush.Color:= clRed;
        DBGridResumoCarta.Font.Color:= clBlack;
        DBGridResumoCarta.Canvas.FillRect(Rect);
        DBGridResumoCarta.DefaultDrawColumnCell(Rect, DataCol,Column, State);
      end;
    end;
  end;
end;

