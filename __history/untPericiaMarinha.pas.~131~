      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('NumeroProrrogacao').AsInteger:= NumeroProrrogacao;
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('DataReferenciaFlagState').AsString:=
      FrmDataModule.ADOQueryTemporarioDBConsulta1.FieldByName('DataPericia').AsString;
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('RelatorioFlagState').AsString:=
      FrmDataModule.ADOQueryTemporarioDBConsulta1.FieldByName('Relatorio').AsString;
      FrmDataModule.ADOQueryPericiaMarinha.Post;
      FrmPrincipal.MenssagemStatus('Inicial Flag: '+FrmDataModule.
      ADOQueryTemporarioDBConsulta1.FieldByName('Relatorio').AsString);
    end
    else
    begin
      FrmDataModule.ADOQueryPericiaMarinha.Edit;
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('ProrrogacaoData').AsString:= MemoMarinha.Lines.Text;
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('DataVencimento').AsDateTime:= IncDay(DataPericia,DiasProrrogacao);
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('TotalDiasProrrogacao').AsInteger:= DiasProrrogacao;
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('NumeroProrrogacao').AsInteger:= NumeroProrrogacao;
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('DataReferenciaFlagState').AsString:= '';
      FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('RelatorioFlagState').AsString:= 'NA';
      FrmDataModule.ADOQueryPericiaMarinha.Post;
      FrmPrincipal.MenssagemStatus('Inicial Flag: Não encontrado');
    end;
  end
  else
  begin
    FrmDataModule.ADOQueryPericiaMarinha.Edit;
