  FrmDataModule.ADOQueryPericiaMarinha.Sort := DataTipo+' ASC';
  FrmDataModule.ADOQueryPericiaMarinha.First;
  Data1:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
  FieldByName(DataTipo).AsDateTime;
  AnoInicioPericia:= YearOF(Data1);
  if AnoInicioPericia = 1899 then
    for I := 1 to NumRegistros do
    begin
      Data1:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName(DataTipo).AsDateTime;
      AnoInicioPericia:= YearOF(Data1);
      if AnoInicioPericia = 1899 then
        FrmDataModule.ADOQueryPericiaMarinha.Next
      else
        break;
    end;
  FrmDataModule.ADOQueryPericiaMarinha.Last;
  Data2:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
  FieldByName(DataTipo).AsDateTime;
  AnoFimPericia:= YearOF(Data2);
  //=========================================
  FrmDataModule.ADOQueryPericiaMarinha.Sort := 'DataRetificado ASC';
  FrmDataModule.ADOQueryPericiaMarinha.First;
  Data1:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
  FieldByName('DataRetificado').AsDateTime;
  AnoInicioRetificado:= YearOF(Data1);
  if AnoInicioRetificado = 1899 then
    for I := 1 to NumRegistros do
    begin
      Data1:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
      FieldByName('DataRetificado').AsDateTime;
      AnoInicioRetificado:= YearOF(Data1);
      if AnoInicioRetificado = 1899 then
        FrmDataModule.ADOQueryPericiaMarinha.Next
      else
        break;
    end;
  FrmDataModule.ADOQueryPericiaMarinha.Last;
  Data2:= FrmDataModule.DataSourcePericiaMarinha.DataSet.
  FieldByName('DataRetificado').AsDateTime;
  AnoFimRetificado:= YearOF(Data2);
  if (AnoInicioRetificado < AnoInicioPericia)AND(AnoInicioRetificado<>1899) then
    MenorAno:= AnoInicioRetificado
  else
    MenorAno:= AnoInicioPericia;
  if AnoFimPericia > AnoFimRetificado then
    MaiorAno:= AnoFimPericia
  else
    MaiorAno:= AnoFimRetificado;
  //==========================================
  SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayout,false);
  if SQLString<>'' then
    SQLString:= 'AND'+SQLString;
  FrmPrincipal.ProgressBarIncializa(12,'Gerando gráfico...');
  EixoX:= 0;
  NPericia:= 0;
  AVencer:= 0;
  for j := MenorAno to MaiorAno do
    for i := 1 to 12 do
    begin
      try
        //Em aberto
        if DataTipo = 'DataVencimento' then
        begin
          FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
          FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Clear;
          FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Add(
          'SELECT tblPericiaMarinha.* FROM tblPericiaMarinha '+
          'WHERE ((MONTH('+DataTipo+') = '+QuotedStr(IntToStr(i))+
          ')AND(YEAR('+DataTipo+') = "'+IntToStr(j)+'")'+
          'AND(Retificado LIKE "Em aberto"))'+SQLString+';');
          FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
          AVencer:= FrmDataModule.ADOQueryTemporarioDBConsulta1.RecordCount;
        end
        else if DataTipo = 'DataPericia' then
        begin
          FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
          FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Clear;
          FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Add(
          'SELECT tblPericiaMarinha.* FROM tblPericiaMarinha '+
          'WHERE ((MONTH('+DataTipo+') = '+QuotedStr(IntToStr(i))+
          ')AND(YEAR('+DataTipo+') = "'+IntToStr(j)+'"))'+SQLString+';');
          FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
          NPericia:= FrmDataModule.ADOQueryTemporarioDBConsulta1.RecordCount;
        end;
        //Retificados
        FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
        FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Clear;
        FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Add(
        'SELECT tblPericiaMarinha.* FROM tblPericiaMarinha '+
        'WHERE ((MONTH(DataRetificado) = '+QuotedStr(IntToStr(i))+
        ')AND(YEAR(DataRetificado) = "'+IntToStr(j)+'")'+
        'AND(Retificado LIKE "Retificado"))'+SQLString+';');
        FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
        Retificados:= FrmDataModule.ADOQueryTemporarioDBConsulta1.RecordCount;
        case i of
          1: Mes:= 'JAN/'+IntToStr(j);
          2: Mes:= 'FEV/'+IntToStr(j);
          3: Mes:= 'MAR/'+IntToStr(j);
          4: Mes:= 'ABR/'+IntToStr(j);
          5: Mes:= 'MAI/'+IntToStr(j);
          6: Mes:= 'JUN/'+IntToStr(j);
          7: Mes:= 'JUL/'+IntToStr(j);
          8: Mes:= 'AGO/'+IntToStr(j);
          9: Mes:= 'SET/'+IntToStr(j);
          10: Mes:= 'OUT/'+IntToStr(j);
          11: Mes:= 'NOV/'+IntToStr(j);
          12: Mes:= 'DEZ/'+IntToStr(j);
        end;
        //=============================================================
        if ((DataTipo = 'DataVencimento')AND(AVencer > 0)) then
        begin
          BarSeriesGRF.AddXY(EixoX,AVencer,Mes,clRed);
          EixoX:= EixoX+1;
        end;
        if ((DataTipo = 'DataPericia')AND(NPericia > 0)) then
        begin
          BarSeriesGRF.AddXY(EixoX,NPericia,Mes,clBlue);
          EixoX:= EixoX+1;
        end;
        if (Retificados > 0) then
        begin
          BarSeriesGRF.AddXY(EixoX,Retificados,Mes,clLime);
          EixoX:= EixoX+1;
        end;
        FrmPrincipal.ProgressBarIncremento(1);
      except
      end;
    end;
  ChartGrafico.BottomAxis.Visible:= true;
  ChartGrafico.AddSeries(BarSeriesGRF);
  FrmPrincipal.ProgressBarAtualizar;
end;

procedure TFrmPericiaMarinha.GRFVencimento(Tipo: Integer);
  var
    BarSeriesGRF: TBarSeries;
    NumRegistros,i,cor: Integer;
    SQLString,DataProcura: String;
    DataEixo,DataVemciemtnoCarta: TDateTime;
    ListaData: TStringList;
begin
  BarSeriesGRF:= carregaSerie;
  ChartGrafico.Legend.Visible:= true;
  ChartGrafico.Legend.CheckBoxes:= false;
  ChartGrafico.Axes.Left.Title.Caption:= 'N° de Pendências';
  //==========================================
  FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Add(
  'SELECT tblPericiaMarinha.DataVencimento FROM tblPericiaMarinha '+
  'GROUP BY tblPericiaMarinha.DataVencimento ORDER BY DataVencimento;');
  FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
  ListaData:=TStringList.Create;
  ListaData.Clear;
  while not FrmDataModule.ADOQueryTemporarioDBConsulta1.Eof do
  begin
    ListaData.Add(FrmDataModule.ADOQueryTemporarioDBConsulta1.FieldByName('DataVencimento').AsString);
    FrmDataModule.ADOQueryTemporarioDBConsulta1.Next;
  end;
  //==========================================
  cor:= 0;
  SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayout,true);
    if SQLString<>'' then
    SQLString:= SQLString+'AND'
  else
    SQLString:= 'WHERE ';
  FrmPrincipal.ProgressBarIncializa(ListaData.Count,'Gerando gráfico...');
  for I := 0 to ListaData.Count-1 do
  begin
    try
      DataEixo:= StrToDateTime(ListaData[i]);
      DataProcura:= (FormatDateTime('dd/mm/yyyy',DataEixo));
      FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
      FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Clear;
      FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Add(
      'SELECT tblPericiaMarinha.* FROM tblPericiaMarinha '+
      SQLString+'((DataVencimento LIKE '+QuotedStr(Dataprocura)+'));');
      //=============================================================
      FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
      NumRegistros:= FrmDataModule.ADOQueryTemporarioDBConsulta1.RecordCount;
      //=============================================================
      if Tipo = 1 then
      begin
        DataVemciemtnoCarta:= StrToDate(DataProcura);
        DataVemciemtnoCarta:= IncDay(DataVemciemtnoCarta,-PrazoCores1);
        DataProcura:= DateToStr(DataVemciemtnoCarta);
      end;
      if (NumRegistros > 0) then
      begin
        BarSeriesGRF.AddXY(DataEixo,NumRegistros,DataProcura,
        FrmPrincipal.CoresAuto[cor]);
        if cor <= 13 then
          cor:= i+1
        else
          cor:= 0;
      end;
      FrmPrincipal.ProgressBarIncremento(1);
    except
    end;
  end;
  ChartGrafico.AddSeries(BarSeriesGRF);
  FrmPrincipal.ProgressBarAtualizar;
end;

