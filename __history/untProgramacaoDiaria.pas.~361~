procedure TFrmProgramacaoDiaria.abrirAjuda(strTitulo: String; panel: TPanel;
larura,Altura: Integer);
begin
  PanelTituloAjuda.Caption := strTitulo;
  actAjudaLimpar.Execute;
  panel.Visible:= true;
  panel.Align:= alClient;
  PanelAjuda.Width:= larura;
  PanelAjuda.Height:= Altura;

  PanelAjuda.Top:= 220;
  PanelAjuda.Left:= 450;
  PanelAjuda.Visible:= true;
end;

procedure TFrmProgramacaoDiaria.AbrirEdicaoProgramacao(tipo: Integer);
  var
    DestinoPlataforma: String;
begin
  actConfigGRID.Execute;
  PanelCriacao.Visible:= false;
  PanelProgramacao.Visible:= true;
  PanelProgramacao.Align:= alClient;
  DestinoPlataforma:= FrmDataModule.DataSourceProgramacaoDiaria_Cadastro.DataSet.
  FieldByName('txtDestino').AsString;
  case tipo of
    0: //Editar
    begin
      PanelTitulo.Caption:= 'Editar Programaçăo';
      DateTimePickerProgramacao2.Date:= FrmDataModule.DataSourceProgramacaoDiaria_Cadastro.DataSet.
      FieldByName('DataProgramacao').AsDateTime;
      BitBtn22.Action:= actCalcelarProgramacao;
      BitBtn22.Visible:= true;
      btnInserirEditarProgramacao.Action:= actGravarProgramacao;
      btnInserirEditarProgramacao.Visible:= true;
      booleanModoInserir:= false;
    end;
    1: //Inserir
    begin
      DateTimePickerProgramacao2.Date:= IncDay(now,1);
      DateTimePickerProgramacao2.Time:= 0;
      BitBtn22.Action:= actCalcelarProgramacao;
      BitBtn22.Visible:= true;
      btnInserirEditarProgramacao.Action:= actInserirProgramacao;
      btnInserirEditarProgramacao.Visible:= true;
      booleanModoInserir:= true;
    end;
  end;
  FrmPrincipal.selComboBox(ComboBoxDestino,DestinoPlataforma);
  FrmPrincipal.selComboBox(ComboBoxTipoEtapaServico,
  FrmDataModule.DataSourceProgramacaoDiaria_Cadastro.DataSet.
  FieldByName('txtTipoEtapaServico').AsString);
  //===============================================
  actExecutantesServicos.Execute;
  actNumSelecao.Execute;
  FrmPrincipal.clasifica(RLServicos,0,true);
  FrmPrincipal.clasifica(RLServicos,0,true);
  FrmPrincipal.AutoFitGrade(RLServicos);
end;

procedure TFrmProgramacaoDiaria.actAjudaLimparExecute(Sender: TObject);
begin
  PanelAjuda.Visible:= false;
  PanelAjudaInserirServico.Visible:= false;
  PanelNaoEncontrados.Visible:= false;
  PanelLogAcao.Visible:= false;
  PanelConfigurarExecutante.Visible:= false;
end;

procedure TFrmProgramacaoDiaria.actAtualizarComboExecute(Sender: TObject);
begin
  FrmPrincipal.carregarComboBox(FrmDataModule.ADOConnectionConsulta,'Plataforma',
  'SELECT Plataforma FROM tblPlataforma ORDER BY Plataforma;',ComboBoxDestino);
  FrmPrincipal.carregarComboBox(FrmDataModule.ADOConnectionConsulta,'Plataforma',
  'SELECT Plataforma FROM tblPlataforma ORDER BY Plataforma;',ComboBoxOrigem);
  FrmPrincipal.carregarComboBox(FrmDataModule.ADOConnectionConsulta,'TipoEtapaServico',
  'SELECT TipoEtapaServico FROM tblTipoEtapaServico ORDER BY TipoEtapaServico;',ComboBoxTipoEtapaServico);
end;

procedure TFrmProgramacaoDiaria.actAtualizarExecute(Sender: TObject);
begin
FrmPrincipal.actMatrizExecutanteCadastro.Execute;
actExecutantesServicos.Execute;
end;

