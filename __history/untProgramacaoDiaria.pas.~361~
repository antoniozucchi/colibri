          Result.StatusProgramacao:= FrmDataModule.DataSourceTemporarioDBColibri.
          DataSet.FieldByName('StatusProgramacao').AsString;
          Result.AvaliadoPorProgramacao:= FrmDataModule.DataSourceTemporarioDBColibri.
          DataSet.FieldByName('AvaliadoPorProgramacao').AsString;
