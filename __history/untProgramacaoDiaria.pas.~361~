procedure TFrmProgramacaoDiaria.GravarInserirProgramacao(Tipo: Integer;ImportarTudo: Boolean);
  var
    CodigoProgramacaoDiaria,i,NumExecutantes,NumCancelados,NumAprovados: Integer;
    DataProgramacao,StatusProgramacao,AvaliadoPorProgramacao,
    ComputadorProgramacao: String;
    myString,LogAcao: String;
    wideChars: array[0..99] of WideChar;
    booleanReqPT: Boolean;
    DataAvaliacaoProgramacao: TDateTime;
begin
  if ((existeExecutante)AND (existeServico)) then
  begin
    FrmPrincipal.ProgressBarIncializa(15,'Inserindo programaçăo...');
    CodigoProgramacaoDiaria:= 0;
    DataProgramacao:= FrmPrincipal.corrigirData(DateTimePickerProgramacao2.Date);
    //Inlcuir a programaçăo primeiro e depois vincular Executantes e Serviços
    case Tipo of
      0:
      begin
        CodigoProgramacaoDiaria:= FrmPrincipal.incluirProgramacao(
        DataProgramacao,ComboBoxDestino.Text,ComboBoxTipoEtapaServico.Text,
        FrmPrincipal.logChave,FrmPrincipal.logMaquina,now);
        FrmPrincipal.ProgressBarIncremento(1);
      end;
      1:
      begin
        CodigoProgramacaoDiaria:= FrmDataModule.DataSourceProgramacaoDiaria_Cadastro.DataSet.
        FieldByName('idProgramacaoDiaria').AsInteger;
        FrmDataModule.ADOQueryProgramacaoDiaria_Cadastro.Edit;
        FrmDataModule.DataSourceProgramacaoDiaria_Cadastro.DataSet.
        FieldByName('txtTipoEtapaServico').AsString:= ComboBoxTipoEtapaServico.Text;
        FrmDataModule.DataSourceProgramacaoDiaria_Cadastro.DataSet.
        FieldByName('txtDestino').AsString:= ComboBoxDestino.Text;
        FrmDataModule.DataSourceProgramacaoDiaria_Cadastro.DataSet.
        FieldByName('DataProgramacao').AsString:= DataProgramacao;
        //==========================================
        FrmDataModule.DataSourceProgramacaoDiaria_Cadastro.DataSet.
        FieldByName('AvaliadoPor').AsString:= FrmPrincipal.logChave;
        FrmDataModule.DataSourceProgramacaoDiaria_Cadastro.DataSet.
        FieldByName('DataAtualizacao').AsDateTime:= now;
        FrmDataModule.DataSourceProgramacaoDiaria_Cadastro.DataSet.
        FieldByName('ComputadorAtualizacao').AsString:= FrmPrincipal.logMaquina;
        //==========================================
        LogAcao:= 'Programaçăo: '+DataProgramacao+#9+ComboBoxDestino.Text+#9+ComboBoxTipoEtapaServico.Text+#9+
        '['+FrmPrincipal.logChave+'; '+DateToStr(now)+'; '+FrmPrincipal.logMaquina+'; Atualizaçăo]';
        DBMemoLogAcao.Lines.Add(LogAcao);
        //==========================================
        FrmDataModule.ADOQueryProgramacaoDiaria_Cadastro.Post;
        FrmPrincipal.ProgressBarIncremento(1);
      end;
    end;
    if CodigoProgramacaoDiaria <> 0 then
    begin
      //Excluir todos os Executantes existentes anteriormente
      FrmDataModule.ADOQueryProgramacaoExecutante_Cadastro.Active := false;
      FrmDataModule.ADOQueryProgramacaoExecutante_Cadastro.Parameters.Items[0].Value:= CodigoProgramacaoDiaria;
      FrmDataModule.ADOQueryProgramacaoExecutante_Cadastro.Active := true;
      FrmPrincipal.deleteQuery(FrmDataModule.ADOQueryProgramacaoExecutante_Cadastro,'Executantes');
      FrmPrincipal.ProgressBarIncremento(4);
      //Inserir os Executantes
      for i := 1 to RLExecutantes.RowCount-1 do
      begin
        if RLExecutantes.Cells[0,i] = ' ' then
        begin
          try
            if RLExecutantes.Cells[7,i] = '   ' then
              booleanReqPT:= true
            else
              booleanReqPT:= false;
            //=============================================================
            StatusProgramacao:= RLExecutantes.Cells[11,i];
            AvaliadoPorProgramacao:= RLExecutantes.Cells[14,i];
            try
              DataAvaliacaoProgramacao:= StrToDateTime(RLExecutantes.Cells[15,i]);
            except
              DataAvaliacaoProgramacao:= now;
            end;
            ComputadorProgramacao:= RLExecutantes.Cells[16,i];
            if (StatusProgramacao <> 'Cancelado')AND
            (StatusProgramacao <> 'Mudança')AND
            (StatusProgramacao <> 'Aprovado') then
            begin
              StatusProgramacao:= 'Aprovado';
              AvaliadoPorProgramacao:= FrmPrincipal.logChave;
              DataAvaliacaoProgramacao:= now;
              ComputadorProgramacao:= FrmPrincipal.logMaquina;
            end;
            FrmDataModule.ADOQueryInserirExecutante1.Insert;
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('CodigoProgramacaoDiaria').AsInteger:= CodigoProgramacaoDiaria;
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('NomeExecutante').AsString:= (RLExecutantes.Cells[1,i]);
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('Origem').AsString:= (RLExecutantes.Cells[2,i]);
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('Funcao').AsString:= (RLExecutantes.Cells[3,i]);
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('Empresa').AsString:= (RLExecutantes.Cells[4,i]);
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('CodigoSAP').AsString:= (RLExecutantes.Cells[5,i]);
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('Documento').AsString:= (RLExecutantes.Cells[6,i]);
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('RequisitantePT').AsBoolean:= booleanReqPT;
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('RT').AsString:= 'SEM RT';
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('TipoEmbarque').AsString:= 'SEM RT';
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('StatusProgramacao').AsString:= StatusProgramacao;
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('MotivoProgramacao').AsString:= RLExecutantes.Cells[12,i];
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('PalavraChaveProgramacao').AsString:= RLExecutantes.Cells[13,i];
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('StatusExecucao').AsString:= 'Executado';
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('AvaliadoPorProgramacao').AsString:= AvaliadoPorProgramacao;
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('DataAvaliacaoProgramacao').AsDateTime:= DataAvaliacaoProgramacao;
            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('ComputadorProgramacao').AsString:= ComputadorProgramacao;

            FrmDataModule.DataSourceInserirExecutante.DataSet.
            FieldByName('RT_CentroCusto').AsString:= RLExecutantes.Cells[17,i];

            FrmDataModule.ADOQueryInserirExecutante1.Post;
          except
            ShowMessage('Erro ao iserir executante: '+RLExecutantes.Cells[1,i]);
          end;
        end;
      end;
      FrmPrincipal.ProgressBarIncremento(4);
      //Excluir todos os Serviços existentes anteriormente
      FrmDataModule.ADOQueryProgramacaoServico_Cadastro.Active := false;
      FrmDataModule.ADOQueryProgramacaoServico_Cadastro.Parameters.Items[0].Value:= CodigoProgramacaoDiaria;
      FrmDataModule.ADOQueryProgramacaoServico_Cadastro.Active := true;
      FrmPrincipal.deleteQuery(FrmDataModule.ADOQueryProgramacaoServico_Cadastro,'Serviços');
      //Inserir os Serviços
      for i := 1 to RLServicos.RowCount - 1 do
      begin
        if RLServicos.Cells[0,i] = ' ' then
        begin
          try
            FrmDataModule.ADOQueryInserirServico.Insert;
            FrmDataModule.DataSourceInserirServico.DataSet.
            FieldByName('CodigoProgramacaoDiaria').AsInteger:= CodigoProgramacaoDiaria;
            FrmDataModule.DataSourceInserirServico.DataSet.
            FieldByName('CampoSelecao').AsString:= (RLServicos.Cells[1,i]);
            FrmDataModule.DataSourceInserirServico.DataSet.
            FieldByName('TextoBreveOP').AsString:= (RLServicos.Cells[2,i]);
            FrmDataModule.DataSourceInserirServico.DataSet.
            FieldByName('TextoBreveOM').AsString:= (RLServicos.Cells[3,i]);
            FrmDataModule.DataSourceInserirServico.DataSet.
            FieldByName('OrdemManutencao').AsString:= (RLServicos.Cells[4,i]);
            FrmDataModule.DataSourceInserirServico.DataSet.
            FieldByName('Operacao').AsString:= (RLServicos.Cells[5,i]);
            FrmDataModule.DataSourceInserirServico.DataSet.
            FieldByName('CentroTrabalhoOP').AsString:= (RLServicos.Cells[6,i]);
            FrmDataModule.ADOQueryInserirServico.Post;
          except

          end;
        end;
      end;
    end;
    FrmPrincipal.ProgressBarAtualizar;
    try
    //====================================================================
    NumCancelados:= FrmPrincipal.CalcNumCanceladosAprovado(CodigoProgramacaoDiaria,0);
    NumAprovados:= FrmPrincipal.CalcNumCanceladosAprovado(CodigoProgramacaoDiaria,1);
    NumExecutantes:= FrmPrincipal.CalcNumExecutantes(CodigoProgramacaoDiaria);
    //Gravar resultados
    FrmDataModule.ADOQueryConsultaProgramacao_ID.Active := false;
    FrmDataModule.ADOQueryConsultaProgramacao_ID.Parameters.Items[0].Value:= CodigoProgramacaoDiaria;
    FrmDataModule.ADOQueryConsultaProgramacao_ID.Active := true;
    //====================================================================
    FrmDataModule.ADOQueryConsultaProgramacao_ID.Edit;
    FrmDataModule.DataSourceConsultaProgramacao_ID.DataSet.
    FieldByName('NumExecutantes').AsInteger:= NumExecutantes;
    FrmDataModule.DataSourceConsultaProgramacao_ID.DataSet.
    FieldByName('NumCancelados').AsInteger:= NumCancelados;
    FrmDataModule.DataSourceConsultaProgramacao_ID.DataSet.
    FieldByName('NumAprovados').AsInteger:= NumAprovados;
    FrmDataModule.ADOQueryConsultaProgramacao_ID.Post;
    finally
      if ImportarTudo = false then
        actCalcelarProgramacao.Execute;
    end;
  end;
  if ((existeExecutante=false)OR(existeServico=false)) then
  begin
    myString:= 'Necessário inserir pelo menos um Excecutante e um Serviço.'+#13+
    'Operaçăo cancelada!';
    MessageBox(0, StringToWideChar(myString,wideChars,100),
    'Colibri', MB_ICONINFORMATION);
  end;
end;

procedure TFrmProgramacaoDiaria.incluirExecutante(
  NomeExecutante,Origem,Funcao,Empresa,
  codigoSAP,CPF,RequisitantePT,RT,TipoEmbarque,txtDestino,RT_CentroCusto: String);
  var
    numLinhas,i: Integer;
    DataProcura,Itinerario: String;
    Executante: TExecutanteProgramado;
begin
  //Verificar primeiro se o executante já foi programado para esta data
  DataProcura:= FrmPrincipal.corrigirData(DateTimePickerProgramacao2.Date);
  Executante:= executanteProgramado(NomeExecutante,Funcao,codigoSAP,CPF,DataProcura,txtDestino);

  numLinhas:= RLExecutantes.RowCount;
  RLExecutantes.RowCount:= numLinhas+1;
  //Preencher valores
  RLExecutantes.Cells[0,numLinhas]:= '  ';
  RLExecutantes.Cells[1,numLinhas]:= (NomeExecutante);
  RLExecutantes.Cells[2,numLinhas]:= (Origem);
  RLExecutantes.Cells[3,numLinhas]:= (Funcao);
  RLExecutantes.Cells[4,numLinhas]:= (Empresa);
  RLExecutantes.Cells[5,numLinhas]:= (codigoSAP);
  RLExecutantes.Cells[6,numLinhas]:= (CPF);
  RLExecutantes.Cells[7,numLinhas]:= (RequisitantePT);
  RLExecutantes.Cells[9,numLinhas]:= (RT);
  RLExecutantes.Cells[10,numLinhas]:= (TipoEmbarque);
  RLExecutantes.Cells[11,numLinhas]:= Executante.StatusProgramacao;
  RLExecutantes.Cells[12,numLinhas]:= Executante.MotivoProgramacao;
  RLExecutantes.Cells[13,numLinhas]:= Executante.PalavraChaveProgramacao;
  RLExecutantes.Cells[14,numLinhas]:= Executante.AvaliadoPorProgramacao;
  RLExecutantes.Cells[15,numLinhas]:= Executante.DataAvaliacaoProgramacao;
  RLExecutantes.Cells[16,numLinhas]:= Executante.ComputadorProgramacao;

  if Executante.booleanProgramado then
  begin
    Itinerario:= '';
    for I := 0 to Executante.ListaDestinos.Count-1 do
    begin
      if i > 0 then
        Itinerario:= Itinerario + ',';
      Itinerario:= Itinerario + Executante.ListaDestinos[i];
    end;
    RLExecutantes.Cells[8,numLinhas]:= (Itinerario);
  end
  else
    RLExecutantes.Cells[8,numLinhas]:= 'NADA';
end;

procedure TFrmProgramacaoDiaria.incluirServico(
ServicoPT,TextoBreveOP,TextoBreveOM,OrdemManutencao,Operacao,CentroTrabalhoOP,selecao: String);
  var
