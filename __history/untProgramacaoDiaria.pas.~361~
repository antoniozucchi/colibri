        if DestinoADD = txtDestino then
        begin
          Result.MotivoProgramacao:= FrmDataModule.DataSourceTemporarioDBColibri.
          DataSet.FieldByName('MotivoProgramacao').AsString;
          Result.PalavraChaveProgramacao:= FrmDataModule.DataSourceTemporarioDBColibri.
