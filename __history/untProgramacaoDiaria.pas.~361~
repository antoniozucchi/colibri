function TFrmProgramacaoDiaria.executanteProgramado(NomeExecutante,Funcao,codigoSAP,CPF,
  dataProcura,txtDestino: String): TExecutanteProgramado;
  var
    CodigoProgramacaoDiaria: Integer;
    SQLBase,DestinoADD,StatusProgramacao: String;
begin
  Result.ListaDestinos:= TStringList.Create;
  Result.ListaDestinos.Clear;
  if (codigoSAP <> 'NA') then
  begin
    FrmDataModule.ADOQueryConsultaExecutante_DataCodigoSAP.Active:= false;
    FrmDataModule.ADOQueryConsultaExecutante_DataCodigoSAP.Parameters.Items[0].Value:= codigoSAP;
    FrmDataModule.ADOQueryConsultaExecutante_DataCodigoSAP.Parameters.Items[1].Value:= dataProcura;
    FrmDataModule.ADOQueryConsultaExecutante_DataCodigoSAP.Active:= true;

    if not FrmDataModule.ADOQueryConsultaExecutante_DataCodigoSAP.IsEmpty then
    begin
      FrmDataModule.ADOQueryConsultaExecutante_DataCodigoSAP.First;
      while not FrmDataModule.ADOQueryConsultaExecutante_DataCodigoSAP.Eof do
      begin
        CodigoProgramacaoDiaria:= FrmDataModule.DataSourceConsultaExecutante_DataCodigoSAP.
        DataSet.FieldByName('CodigoProgramacaoDiaria').AsInteger;
        FrmDataModule.ADOQueryConsultaProgramacao_ID.Active:= false;
        FrmDataModule.ADOQueryConsultaProgramacao_ID.Parameters.Items[0].Value:=
        CodigoProgramacaoDiaria;
        FrmDataModule.ADOQueryConsultaProgramacao_ID.Active:= true;
        //=================================================
        StatusProgramacao:= FrmDataModule.DataSourceConsultaExecutante_DataCodigoSAP.
        DataSet.FieldByName('StatusProgramacao').AsString;
        DestinoADD:= FrmDataModule.DataSourceConsultaProgramacao_ID.DataSet.
        FieldByName('txtDestino').AsString;
        if StatusProgramacao = 'Aprovado' then
        begin
          Result.ListaDestinos.Add(DestinoADD);
          Result.booleanProgramado:= true;
        end;
        //=================================================
        if DestinoADD = txtDestino then
        begin
          Result.MotivoProgramacao:= FrmDataModule.DataSourceConsultaExecutante_DataCodigoSAP.
          DataSet.FieldByName('MotivoProgramacao').AsString;
          Result.PalavraChaveProgramacao:= FrmDataModule.DataSourceConsultaExecutante_DataCodigoSAP.
          DataSet.FieldByName('PalavraChaveProgramacao').AsString;
          //========================================================
          Result.StatusProgramacao:= FrmDataModule.DataSourceConsultaExecutante_DataCodigoSAP.
          DataSet.FieldByName('StatusProgramacao').AsString;
          Result.AvaliadoPorProgramacao:= FrmDataModule.DataSourceConsultaExecutante_DataCodigoSAP.
          DataSet.FieldByName('AvaliadoPorProgramacao').AsString;
          Result.DataAvaliacaoProgramacao:= FrmDataModule.DataSourceConsultaExecutante_DataCodigoSAP.
          DataSet.FieldByName('DataAvaliacaoProgramacao').AsString;
          Result.ComputadorProgramacao:= FrmDataModule.DataSourceConsultaExecutante_DataCodigoSAP.
          DataSet.FieldByName('ComputadorProgramacao').AsString;
        end;
        //=================================================
        FrmDataModule.ADOQueryConsultaExecutante_DataCodigoSAP.Next;
      end;
    end
    else
    begin
      Result.booleanProgramado:= false;
    end;
  end
  else if CPF <> '000.000.000-00' then
  begin
    FrmDataModule.ADOQueryConsultaExecutante_Documento_Data.Active:= false;
    FrmDataModule.ADOQueryConsultaExecutante_Documento_Data.Parameters.Items[0].Value:= CPF;
    FrmDataModule.ADOQueryConsultaExecutante_Documento_Data.Parameters.Items[1].Value:= dataProcura;
    FrmDataModule.ADOQueryConsultaExecutante_Documento_Data.Active:= true;

    if not FrmDataModule.ADOQueryConsultaExecutante_Documento_Data.IsEmpty then
    begin
      FrmDataModule.ADOQueryConsultaExecutante_Documento_Data.First;
      while not FrmDataModule.ADOQueryConsultaExecutante_Documento_Data.Eof do
      begin
        CodigoProgramacaoDiaria:= FrmDataModule.DataSourceConsultaExecutante_Documento_Data.
        DataSet.FieldByName('CodigoProgramacaoDiaria').AsInteger;
        FrmDataModule.ADOQueryConsultaProgramacao_ID.Active:= false;
        FrmDataModule.ADOQueryConsultaProgramacao_ID.Parameters.Items[0].Value:=
        CodigoProgramacaoDiaria;
        FrmDataModule.ADOQueryConsultaProgramacao_ID.Active:= true;
        //=================================================
        StatusProgramacao:= FrmDataModule.DataSourceConsultaExecutante_Documento_Data.
        DataSet.FieldByName('StatusProgramacao').AsString;
        DestinoADD:= FrmDataModule.DataSourceConsultaProgramacao_ID.DataSet.
        FieldByName('txtDestino').AsString;
        if StatusProgramacao = 'Aprovado' then
        begin
          Result.ListaDestinos.Add(DestinoADD);
          Result.booleanProgramado:= true;
        end;
        //=================================================
        if DestinoADD = txtDestino then
        begin
          Result.MotivoProgramacao:= FrmDataModule.DataSourceConsultaExecutante_Documento_Data.
          DataSet.FieldByName('MotivoProgramacao').AsString;
          Result.PalavraChaveProgramacao:= FrmDataModule.DataSourceConsultaExecutante_Documento_Data.
          DataSet.FieldByName('PalavraChaveProgramacao').AsString;
          //========================================================
          Result.StatusProgramacao:= FrmDataModule.DataSourceConsultaExecutante_Documento_Data.
          DataSet.FieldByName('StatusProgramacao').AsString;
          Result.AvaliadoPorProgramacao:= FrmDataModule.DataSourceConsultaExecutante_Documento_Data.
          DataSet.FieldByName('AvaliadoPorProgramacao').AsString;
          Result.DataAvaliacaoProgramacao:= FrmDataModule.DataSourceConsultaExecutante_Documento_Data.
