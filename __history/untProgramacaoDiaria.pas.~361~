procedure TFrmProgramacaoDiaria.actCarregarServicoExecute(Sender: TObject);
  var
    TipoEtapaServicoOP,Destino,
    ServicoPT,TextoBreveOP,TextoBreveOM,OrdemManutencao,Operacao,
    ServicoPadrao,CentroTrabalhoOP: String;
begin
  ListaServicoNaoEncontrado:= TStringList.Create;
  ListaServicoNaoEncontrado.Clear;
  RLServicos.FixedRows:= 0;
  RLServicos.RowCount:= 1;
  TipoEtapaServicoOP:= ComboBoxTipoEtapaServico.Text;
  Destino:= ComboBoxDestino.Text;
  //==========================================================
  //Carregar serviço padrăo
  if booleanModoInserir then
  begin
    ServicoPadrao:= FrmPrincipal.incluirServicoPadrao(TipoEtapaServicoOP);
    incluirServico('',ServicoPadrao,'','','','',' ');
  end;
  //==========================================================
  try
    RLServicos.FixedRows:= 1;
  except
    RLServicos.FixedRows:= 0;
    RLServicos.RowCount:= 1;
  end;
  // Atualizar ProgressBar
  FrmPrincipal.AutoFitGrade(RLServicos);
  //========================================================================
  //Seleçăo de Serviços
  if btnInserirEditarProgramacao.Action = actGravarProgramacao then
  begin
    FrmDataModule.ADOQueryProgramacaoServico_Cadastro.First;
    while not FrmDataModule.ADOQueryProgramacaoServico_Cadastro.Eof do
    begin
      ServicoPT:= FrmDataModule.DataSourceProgramacaoServico_Cadastro.DataSet.
      FieldByName('CampoSelecao').AsString;
      TextoBreveOP:= FrmDataModule.DataSourceProgramacaoServico_Cadastro.DataSet.
      FieldByName('TextoBreveOP').AsString;
      TextoBreveOM:= FrmDataModule.DataSourceProgramacaoServico_Cadastro.DataSet.
      FieldByName('TextoBreveOM').AsString;
      OrdemManutencao:= FrmDataModule.DataSourceProgramacaoServico_Cadastro.DataSet.
      FieldByName('OrdemManutencao').AsString;
      Operacao:= FrmDataModule.DataSourceProgramacaoServico_Cadastro.DataSet.
      FieldByName('Operacao').AsString;
      CentroTrabalhoOP:= FrmDataModule.DataSourceProgramacaoServico_Cadastro.DataSet.
      FieldByName('CentroTrabalhoOP').AsString;
      if FrmPrincipal.selecionarServico(RLServicos,ServicoPT,TextoBreveOP,OrdemManutencao) = false then
      begin
        ListaServicoNaoEncontrado.Add(TextoBreveOP+'/ OM: '+OrdemManutencao+'/ PT: '+ServicoPT);
        incluirServico(ServicoPT,TextoBreveOP,TextoBreveOM,OrdemManutencao,Operacao,CentroTrabalhoOP,' ');
        FrmPrincipal.selecionarServico(RLServicos,ServicoPT,TextoBreveOP,OrdemManutencao);
      end;
      FrmDataModule.ADOQueryProgramacaoServico_Cadastro.Next;
    end;
    //========================================================================
    if ListaServicoNaoEncontrado.Count > 0 then
    begin
      actServicosNaoEncontrados.Enabled:= true;
    end
    else
    begin
      actServicosNaoEncontrados.Enabled:= false;
    end;
  end;
end;

