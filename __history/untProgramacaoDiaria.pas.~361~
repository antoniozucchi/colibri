  StatusBarDisponivelServicos.Panels[1].Text:=
  'N° Registros: '+(IntToStr(RLServicos.RowCount-1));
  FrmPrincipal.AutoFitStatusBar(StatusBarDisponivelServicos);
end;

function TFrmProgramacaoDiaria.selecionarExecutante(NomeExecutante,CodigoSAP,Origem,
Funcao,Empresa: String): Boolean;
  var
    i: Integer;
begin
  Result:= false;
  for i := 1 to RLExecutantes.RowCount-1 do
  begin
    if ((CodigoSAP=(RLExecutantes.Cells[5,i]))AND(CodigoSAP<>'NA')) then
    begin
      RLExecutantes.Cells[0,i]:= ' ';
      RLExecutantes.Cells[2,i]:= (Origem);
      Result:= true;
      Break;
    end
    else if ((NomeExecutante=(RLExecutantes.Cells[1,i]))AND(NomeExecutante<>'')) then
    begin
      RLExecutantes.Cells[0,i]:= ' ';
      RLExecutantes.Cells[2,i]:= (Origem);
      RLExecutantes.Cells[3,i]:= (Funcao);
      RLExecutantes.Cells[4,i]:= (Empresa);
      Result:= true;
      Break;
    end;
  end;
end;

