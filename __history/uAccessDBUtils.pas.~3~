function BuildInParams(const ParamPrefix: string; const IDs: TArray<Integer>): string;
var
  i: Integer;
begin
  Result := '';
  for i := 0 to High(IDs) do
  begin
    if Result <> '' then
      Result := Result + ',';
    Result := Result + ':' + ParamPrefix + IntToStr(i);
  end;
end;

procedure BindInParams(Qry: TADOQuery; const ParamPrefix: string; const IDs: TArray<Integer>);
var
  i: Integer;
begin
  for i := 0 to High(IDs) do
    Qry.Parameters.ParamByName(ParamPrefix + IntToStr(i)).Value := IDs[i];
end;

// Pega os IDs marcados no TCheckListBox.
// Preferência: carregar o checklist com AddObject(..., TObject(NativeInt(ID))).
// Fallback: tenta extrair o inteiro do começo do texto (ex: "123 - Projeto X").
function GetSelectedProjectIDsFromDB(AConn: TADOConnection): TArray<Integer>;
var
  Qry: TADOQuery;
  L: TList<Integer>;
begin
  L := TList<Integer>.Create;
  Qry := TADOQuery.Create(nil);
  try
    Qry.Connection := AConn;
    Qry.SQL.Text :=
      'SELECT idProjeto ' +
      'FROM tblProjeto ' +
      'WHERE booleanSelecao = true';
    Qry.Open;

    while not Qry.Eof do
    begin
      L.Add(Qry.FieldByName('idProjeto').AsInteger);
      Qry.Next;
    end;

    if L.Count = 0 then
      raise Exception.Create('Nenhum projeto selecionado para exportação.');

    Result := L.ToArray;
  finally
    Qry.Free;
    L.Free;
  end;
end;


procedure ExecSQL_NotIn(Qry: TADOQuery; const SQLText, ParamPrefix: string; const IDs: TArray<Integer>);
begin
  Qry.Close;
  Qry.SQL.Clear;
  Qry.Parameters.Clear;
  Qry.SQL.Text := SQLText;
  BindInParams(Qry, ParamPrefix, IDs);
  Qry.ExecSQL;
end;

