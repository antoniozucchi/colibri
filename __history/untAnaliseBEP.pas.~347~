procedure TFrmAnaliseBEP.actExportarExcelExecute(Sender: TObject);
  var
    vaIn, vaOut:  OleVariant;
begin
  if baixarExcel then
  begin
    try
      ((WebBrowser1.Document as IHTMLDocument2).body as IHTMLElement2).focus();
      WebBrowser1.OleObject.Document.GetElementByID('ctl00_ContentPlaceHolder1_btnExportarTodos').click;
      FrmPrincipal.ProgressBarIncremento(1);
    except
      TimerExcel.Enabled:= false;
    end;
  end
  else
  begin
    try
      TipoEvento:= 0;
      FrmPrincipal.ProgressBarIncremento(1);
      WebBrowser1.ExecWB(OLECMDID_SELECTALL, OLECMDEXECOPT_PROMPTUSER, vaIn, vaOut);
      WB_Copy(webbrowser1);
