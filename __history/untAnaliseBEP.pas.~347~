procedure TFrmAnaliseBEP.actSAPExecute(Sender: TObject);
  var
    NotaManutencao,OrdemManutencao,SQLBase,Pendencia: String;
begin
  NotaManutencao:= FrmDataModule.DataSourceAnaliseBEP.DataSet.FieldByName('NotaManutencao').AsString;
  OrdemManutencao:= FrmDataModule.DataSourceAnaliseBEP.DataSet.FieldByName('OrdemManutencao').AsString;
  if NotaManutencao <> '' then
  begin
    SQLBase:= 'SELECT tblCarteiraTrabalho.* FROM tblCarteiraTrabalho '+
    'WHERE ((NotaManutencao LIKE '+NotaManutencao+'));';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    if not FrmDataModule.ADOQueryAnaliseBEP.IsEmpty then
    begin
      FrmDataModule.ADOQueryAnaliseBEP.Edit;
      OrdemManutencao:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('OrdemManutencao').AsString;
      FrmDataModule.DataSourceAnaliseBEP.DataSet.FieldByName('OrdemManutencao').AsString:=
      OrdemManutencao;
      Pendencia:= DBMemoPendencia.Text+#13+
      FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('TextoBreveOM').AsString+#13+
      FrmPrincipal.verificaTextoLongoCarteira(OrdemManutencao);

      FrmDataModule.DataSourceAnaliseBEP.DataSet.FieldByName('Pendencia').AsString:= Pendencia;

      FrmDataModule.ADOQueryAnaliseBEP.Post;
    end;
  end
  else if OrdemManutencao <> '' then
  begin
    SQLBase:= 'SELECT tblCarteiraTrabalho.* FROM tblCarteiraTrabalho '+
    'WHERE ((OrdemManutencao LIKE '+OrdemManutencao+'));';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    if not FrmDataModule.ADOQueryAnaliseBEP.IsEmpty then
    begin
      FrmDataModule.ADOQueryAnaliseBEP.Edit;
      NotaManutencao:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('NotaManutencao').AsString;
      FrmDataModule.DataSourceAnaliseBEP.DataSet.FieldByName('NotaManutencao').AsString:=
      NotaManutencao;
      Pendencia:= DBMemoPendencia.Text+#13+
      FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.FieldByName('TextoBreveOM').AsString+#13+
      FrmPrincipal.verificaTextoLongoCarteira(OrdemManutencao);
      FrmDataModule.DataSourceAnaliseBEP.DataSet.FieldByName('Pendencia').AsString:= Pendencia;
      FrmDataModule.ADOQueryAnaliseBEP.Post;
    end;
  end
  else
    MessageBox(0,PChar('Necessário informar a "Nota de Manutençăo" ou a "Ordem de Manutençăo"'),'Colibri',MB_ICONEXCLAMATION);
end;

