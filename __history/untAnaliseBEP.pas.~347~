procedure TFrmAnaliseBEP.actConfigFiltroExecute(Sender: TObject);
  var
    PalavraLista,PalavraBusca: String;
    i: Integer;
begin
  PalavraBusca:= '';
  PalavraLista:= '';
  FrmDataModule.ADOQueryTemporarioDBOperacao.Close;
  FrmDataModule.ADOQueryTemporarioDBOperacao.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBOperacao.SQL.Add(
  'SELECT tblTarefa.* FROM tblTarefa '+
  'WHERE ((BooleanSelecao = True));');
  FrmDataModule.ADOQueryTemporarioDBOperacao.Open;
  while not FrmDataModule.ADOQueryTemporarioDBOperacao.Eof  do
  begin
    PalavraLista:= FrmDataModule.DataSourceTemporarioDBOperacao.DataSet.FieldByName('Tarefa').AsString;
    if PalavraBusca <> '' then
      PalavraBusca:= PalavraBusca+';'+PalavraLista
    else
      PalavraBusca:= PalavraLista;

    FrmDataModule.ADOQueryTemporarioDBOperacao.Next;
  end;
  FrmPrincipal.buscaFiledGrid1('Tarefa',PalavraBusca,'Contem',ColunasLayoutAnaliseBEP,4,false);
  //============================================================================
  PalavraBusca:= '';
  PalavraLista:= '';
  FrmDataModule.ADOQueryTemporarioDBOperacao.Close;
  FrmDataModule.ADOQueryTemporarioDBOperacao.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBOperacao.SQL.Add(
  'SELECT tblResponsavel.* FROM tblResponsavel '+
  'WHERE ((BooleanSelecao = True));');
  FrmDataModule.ADOQueryTemporarioDBOperacao.Open;
  while not FrmDataModule.ADOQueryTemporarioDBOperacao.Eof  do
  begin
    PalavraLista:= FrmDataModule.DataSourceTemporarioDBOperacao.DataSet.FieldByName('Responsavel').AsString;
    if PalavraBusca <> '' then
      PalavraBusca:= PalavraBusca+';'+PalavraLista
    else
      PalavraBusca:= PalavraLista;

    FrmDataModule.ADOQueryTemporarioDBOperacao.Next;
  end;
  FrmPrincipal.buscaFiledGrid1('Responsavel',PalavraBusca,'Contem',ColunasLayoutAnaliseBEP,4,false);
  //=============================================================================
    //Plataformas
  PalavraBusca:= '';
  for I := 0 to CheckListBoxPlataforma.Count-1 do
  begin
    if CheckListBoxPlataforma.Checked[i] then
    begin
      PalavraLista:= CheckListBoxPlataforma.Items[i];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('Plataforma',PalavraBusca,'Contem',ColunasLayoutAnaliseBEP,4,false);
end;

