procedure TFrmAnaliseBEP.actCheckPlataformaExecute(Sender: TObject);
  var
    ListaGroup: TStringList;
begin
  //================================================================
  ListaGroup:=TStringList.Create;
  FrmDataModule.ADOQueryTemporarioDBOperacao.Close;
  FrmDataModule.ADOQueryTemporarioDBOperacao.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBOperacao.SQL.Add(
  'SELECT Plataforma FROM tblAnaliseBEP '+
  'GROUP BY Plataforma ORDER BY Plataforma;');
  FrmDataModule.ADOQueryTemporarioDBOperacao.Open;
  while not FrmDataModule.ADOQueryTemporarioDBOperacao.Eof do
  begin
    ListaGroup.Add(FrmDataModule.ADOQueryTemporarioDBOperacao.FieldByName('Plataforma').AsString);
    FrmDataModule.ADOQueryTemporarioDBOperacao.Next;
  end;
  FrmPrincipal.SetupCheckListSQL1('Plataforma','',CheckListBoxPlataforma,
  ListaGroup);
end;

