procedure TFrmAnaliseBEP.actImportarCopiaExecute(Sender: TObject);
var
  i,matrizLinha,ARow,CorColuna,Contar: Integer;
  Realizacao, Plataforma, Tarefa,Poco,Duto,Dias,Vencimento,Celula: String;
begin
  {OpenDialog1.Filter := 'Microsoft Excel |*.xlsx|Microsoft Excel 97-2003|*.xls';
  OpenDialog1.DefaultExt := '*.xlsx';
  if OpenDialog1.Execute then
  begin
    ExcelPagina := CreateOleObject('Excel.Application');
    ExcelPagina.Workbooks.Open(OpenDialog1.FileName);
    SheetPagina := ExcelPagina.WorkSheets[1];
    ExcelPagina.visible:= true;
  end; }
  FrmDataModule.ADOQueryImportarBEP.Active:= false;
  FrmDataModule.ADOQueryImportarBEP.Active:= true;
  try
    try
      ARow:= 1;
      Contar:= 0;
      //Procurar linha inicial
      for i := ARow to 100 do
      begin
        Plataforma:= ExcelPagina.Workbooks[1].Sheets[1].Cells[i,1];
        if Plataforma = 'Instalaçăo' then
          Contar:= Contar+1;
        if Contar = 2 then
        begin
          ARow:= i+1;
          break
        end;
      end;
      // ============================================
      //Verificar a ultima Linha
      // ============================================
      matrizLinha:= (SheetPagina.Cells.SpecialCells(11).Row)-4;
      // Inicializar ProgressBar
      FrmPrincipal.ProgressBarIncializa(matrizLinha-ARow,
      'Importando dados da página BEP...');
      // ============================================
      // Preencher as planilhas
      // ============================================
      for i := ARow to matrizLinha do
      begin
        Celula:=      'G'+IntToStr(i);
        Plataforma:=  ExcelPagina.Workbooks[1].Sheets[1].Cells[i,1];
        Poco:=        ExcelPagina.Workbooks[1].Sheets[1].Cells[i,2];
        Duto:=        ExcelPagina.Workbooks[1].Sheets[1].Cells[i,3];
        Tarefa:=      ExcelPagina.Workbooks[1].Sheets[1].Cells[i,4];
        Realizacao:=  ExcelPagina.Workbooks[1].Sheets[1].Cells[i,5];
        Vencimento:=  ExcelPagina.Workbooks[1].Sheets[1].Cells[i,6];
        Dias:=        ExcelPagina.Workbooks[1].Sheets[1].Cells[i,7];
        CorColuna:=   SheetPagina.Range[Celula].Interior.Color;

        GravarRegistro(CorColuna,Plataforma,Poco,Duto,Tarefa,Realizacao,Vencimento,Dias);
        // Incremento ProgressBar
        FrmPrincipal.ProgressBarIncremento(1);
        Application.ProcessMessages;
      end;
      // Atualizar ProgressBar
      FrmPrincipal.ProgressBarAtualizar;
    finally
      actProcurarAnaliseBep.Execute;
      //Fechar Excel
      ExcelPagina.Application.DisplayAlerts := False; // Alle Rückfragen ausstellen
      ExcelPagina.Quit;
      ExcelPagina := Unassigned;
      FreeAndNil(ExcelPagina);
      ExcelPagina := 0;
    end;
  except
    actProcurarAnaliseBep.Execute;
    // Atualizar ProgressBar
    FrmPrincipal.ProgressBarAtualizar;
    //Fechar Excel
    ExcelPagina.Application.DisplayAlerts := False; // Alle Rückfragen ausstellen
    ExcelPagina.Quit;
    ExcelPagina := Unassigned;
    FreeAndNil(ExcelPagina);
    ExcelPagina := 0;
  end;
  actCheckPlataforma.Execute;
end;

