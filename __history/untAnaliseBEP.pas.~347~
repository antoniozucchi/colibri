procedure TFrmAnaliseBEP.GravarRegistro(CorColuna: Integer; Plataforma, Poco, Duto, Tarefa,
  Realizacao, Vencimento, Dias: String);
begin
  if ExisteRegistro(Plataforma,Tarefa,Poco,Duto) then
  begin
    try
      // Editar registro existente na tabela de dados
      FrmDataModule.ADOQueryExisteBEP.Edit;
      // Preencher as colunas do registro na tabela de dados
      FrmDataModule.DataSourceExisteBEP.DataSet.
      FieldByName('Duto').AsString := Duto;
      FrmDataModule.DataSourceExisteBEP.DataSet.
      FieldByName('Realizacao').AsString := Realizacao;
      FrmDataModule.DataSourceExisteBEP.DataSet.
      FieldByName('Vencimento').AsString := Vencimento;
      FrmDataModule.DataSourceExisteBEP.DataSet.
      FieldByName('Dias').AsString := Dias;
      FrmDataModule.DataSourceExisteBEP.DataSet.
      FieldByName('CorColuna').AsInteger := CorColuna;

      //Usuário
      FrmDataModule.DataSourceExisteBEP.DataSet.
      FieldByName('ImportadoPor').asString:= FrmPrincipal.logChave;
      FrmDataModule.DataSourceExisteBEP.DataSet.
      FieldByName('DataImportacao').AsDateTime:= now;
      FrmDataModule.DataSourceExisteBEP.DataSet.
      FieldByName('Computador').AsString:= FrmPrincipal.logMaquina;

      FrmDataModule.ADOQueryExisteBEP.Post;
    except
      FrmDataModule.ADOQueryExisteBEP.Cancel;
    end;
  end
  else
  begin
    try
      // Inserir novo registro na tabela de dados
      FrmDataModule.ADOQueryImportarBEP.Insert;
      // Preencher as colunas do registro na tabela de dados
      FrmDataModule.DataSourceImportarBEP.DataSet.
      FieldByName('Plataforma').AsString := Plataforma;
      FrmDataModule.DataSourceImportarBEP.DataSet.
      FieldByName('Poco').AsString := Poco;
