procedure TFrmAnaliseBEP.WebBrowser1ProgressChange(ASender: TObject; Progress,
  ProgressMax: Integer);
begin
{Ele faz um rotina para saber se o valor Maximo do
Progressbar é maior que 1 e o valor minimo tbem
se for, entăo ele faz a rotina}
  If (Progress>=1) and (ProgressMax>1) then
  begin
    //Ele tira uma valor percentual para colocar
    //no Progressbar
    ProgressBar1.Position := Round((Progress * 100) Div ProgressMax);
    ProgressBar1.Visible  := True;
  end
  else
  begin
    ProgressBar1.Position := 1;
    ProgressBar1.Visible  := False;
  end;
end;

