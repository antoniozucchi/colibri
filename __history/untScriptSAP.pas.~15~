function TFrmScriptSAP.getElementoPEP(LocalInstalacao: String): String;
  var
    ListaLocal: TStringList;
begin
  ListaLocal:= TStringList.Create;
  ListaLocal.delimiter:= '.';
  ListaLocal.StrictDelimiter:=true;

  ListaLocal.Clear;
  ListaLocal.DelimitedText:= LocalInstalacao;
  LocalInstalacao:= ListaLocal[0];


end;

procedure TFrmScriptSAP.introducao;
begin
  MemoScript.Lines.Add('If Not IsObject(application) Then');
  MemoScript.Lines.Add('   Set SapGuiAuto  = GetObject("SAPGUI")');
  MemoScript.Lines.Add('   Set application = SapGuiAuto.GetScriptingEngine');
  MemoScript.Lines.Add('End If');
  MemoScript.Lines.Add('If Not IsObject(connection) Then');
  MemoScript.Lines.Add('   Set connection = application.Children(0)');
  MemoScript.Lines.Add('End If');
  MemoScript.Lines.Add('If Not IsObject(session) Then');
  MemoScript.Lines.Add('   Set session    = connection.Children(0)');
  MemoScript.Lines.Add('End If');
  MemoScript.Lines.Add('If IsObject(WScript) Then');
  MemoScript.Lines.Add('   WScript.ConnectObject session,     "on"');
  MemoScript.Lines.Add('   WScript.ConnectObject application, "on"');
  MemoScript.Lines.Add('End If');
  MemoScript.Lines.Add('session.findById("wnd[0]").maximize');

end;

procedure TFrmScriptSAP.WMMDIACTIVATE(var msg: TWMMDIACTIVATE);
var
  active: TWinControl;
  idx: Integer;
begin
  active := FindControl(msg.ActiveWnd) ;

  if Assigned(active) then
  begin
    idx := FrmPrincipal.mdiChildrenTabs.Tabs.IndexOfObject(TObject(msg.ActiveWnd));
    FrmPrincipal.mdiChildrenTabs.Tag := -1;
    FrmPrincipal.mdiChildrenTabs.TabIndex := idx;
    FrmPrincipal.mdiChildrenTabs.Tag := 0;
  end;
end;

