procedure TFrmScriptSAP.actScriptSAPExecute(Sender: TObject);
  var
    Excel, Sheet: Variant;
    Ordem1,Ordem2: String;
    i,matrizLinha,naoBranco,ARow,ACol,Inicio: Integer;
begin
  OpenDialog1.Filter := 'Microsoft Excel |*.xlsx|Microsoft Excel 97-2003|*.xls';
  OpenDialog1.DefaultExt := '*.xlsx';
  if OpenDialog1.Execute then
  begin
    try
      ARow:= 2;
      ACol:= 1;
      try
        Excel := CreateOleObject('Excel.Application');
      except
        MessageBox(0,'Verifique se o Microsoft Office Excel esta instalado na sua máquina.',
        'Excel', MB_ICONERROR);
      end;
      // Abrir o arquivo
      try
        Excel.Workbooks.Open(OpenDialog1.FileName);
      except
        MessageBox(0,'Arquivo năo encontrado, verifique o endereço do arquivo!',
        'Excel', MB_ICONERROR);
      end;
      // Abrir a primeira planilha do arquivo
      Sheet := Excel.WorkSheets[1];
      //Verificar a ultima Linha
      // ============================================
      i:= 1;
      matrizLinha:= i;
      naoBranco:= Length(Excel.Workbooks[1].Sheets[1].Cells[ARow, ACol]);
      while (naoBranco <> 0) do
      begin
        matrizLinha:= ARow + i;
        naoBranco:= Length(Excel.Workbooks[1].Sheets[1].Cells[ARow+i,ACol]);
        i:= i + 1;
      end;
      matrizLinha:= matrizLinha-1;
      // Inicializar ProgressBar
      MemoScript.Lines.Clear;
      FrmPrincipal.ProgressBarIncializa(matrizLinha,'Gerando Script SAP, N° total de Linhas: '+
      IntToStr(matrizLinha));
      introducao;
      actInfoTabela.Execute;
      i:= ARow;
      Inicio:= ARow;
      Ordem1:= Excel.Workbooks[1].Sheets[1].Cells[2,1];
      while i <= matrizLinha do
      begin
        if Interromper and (Application.MessageBox(PChar('Deseja realmente cancelar o processo?'),
        '.::ATENÇĂO::.',36) = 6) then
        begin
          FrmPrincipal.ProgressBarAtualizar;
          Excel.Application.DisplayAlerts := False;
          Excel.Quit;
          Excel := Unassigned;
          FreeAndNil(Excel);
          Excel := 0;
          Interromper := False;
          actInterromper.Enabled:= false;
          break;
        end
        else
        begin
          Interromper := False;
          actInterromper.Enabled:= true;
        end;
        //==================================================================
        //GERAR LINHA
        if RadioGroupSAP.ItemIndex = 6 then
        begin
          Ordem2:= Excel.Workbooks[1].Sheets[1].Cells[i,1];
          if Ordem1 <> Ordem2 then
          begin
            preencherScript(Excel,i,Inicio,i-1);
            Inicio:= i;
            Ordem1:= Ordem2;
          end
          else if ((i = matrizLinha)and(Ordem1 = Ordem2)) then
            preencherScript(Excel,i,Inicio,i);
        end
        else
          preencherScript(Excel,i,0,0);
        StringGridTabela.RowCount:= StringGridTabela.RowCount+1;
        i:= i+1;
        FrmPrincipal.ProgressBarIncremento(1);
        Application.ProcessMessages;
        //==================================================================
      end;
      // Atualizar ProgressBar
      FrmPrincipal.ProgressBarAtualizar;
      StatusBarResultado.Panels[0].Text:= 'N° Registros: '+IntToStr(StringGridTabela.RowCount-1);
      try
        StringGridTabela.FixedRows:= 1;
      except
      end;
      //Fechar Excel
      Excel.Application.DisplayAlerts := False; // Alle Rückfragen ausstellen
      Excel.Quit;
      Excel := Unassigned;
      FreeAndNil(Excel);
      Excel := 0;
      actInterromper.Enabled:= false;
      FrmPrincipal.AutoFitStatusBar(StatusBarResultado);
    except
      MessageBox(0,'Operaçăo cancelada!','Script SAP', MB_ICONERROR);
      StatusBarResultado.Panels[0].Text:= 'N° Registros: '+IntToStr(StringGridTabela.RowCount-1);
      try
        Excel.Application.DisplayAlerts := False;
        Excel.Quit;
        Excel := Unassigned;
        FreeAndNil(Excel);
        Excel := 0;
      except
      end;
    end;
  end;
end;

