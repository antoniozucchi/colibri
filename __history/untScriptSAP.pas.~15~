function TFrmScriptSAP.criarLinha(Texto: String; ACol,ARow,LimiteCaracter,TipoNumTxt: Integer; testeBoolean: Boolean): String;
  var
    TextoCorrigido: String;
    NumTxt: Integer;
begin
  if testeBoolean then
  begin
    if AnsiUpperCase(Texto) = 'X' then
    begin
      Result:= 'X';
      StringGridTabela.Cells[ACol,ARow]:= Result;
    end
    else
    begin
      Result:= '';
      StringGridTabela.Cells[ACol,ARow]:= '';
    end;
  end
  else
  begin
    NumTxt:= FrmPrincipal.isNumeric(Texto);
    if (NumTxt >= TipoNumTxt)or(TipoNumTxt=0) then
    begin
      TextoCorrigido:= RemoveSujeira(Texto);
      Result:= LimitarStrRight(TextoCorrigido,LimiteCaracter);
      StringGridTabela.Cells[ACol,ARow]:= Result;
    end
    else
      Result:= '';
  end;
end;

function TFrmScriptSAP.LimitarStrRight(S: string; Len: Integer): string;
var
  L : Integer;
begin
  L := Length(S);
  if L <= Len then
    Result := S
  else
    Result := Copy(S, L + 1 - Len, Len);
end;

