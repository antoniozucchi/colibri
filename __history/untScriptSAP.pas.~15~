function TFrmScriptSAP.RemoveSujeira(str: String): String;
  var
    i: Integer;
    st: String;
begin
  st:= '';
  for I := 1 to length(str) do
  begin
    if (str[i] <> '"') then
    begin
      st:= st+str[i];
    end;
  end;
  Result:= st;
end;

