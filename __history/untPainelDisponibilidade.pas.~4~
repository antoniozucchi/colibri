procedure TFrmPainelDisponibilidade.actDesenharExecute(Sender: TObject);
  var
    TipoLinha: String;
    i: Integer;
begin
  RChartDesenho.ClearGraf;
  RChartDesenho.TextAlignment:= taCenter;
  RChartDesenho.Brush.Color:= clWhite;
  RChartDesenho.Brush.Style:= bsClear;
  RChartDesenho.FillColor:= clWhite;
  FrmDataModule.DataSourcePainelSinal.Enabled:= false;
  FrmDataModule.ADOQueryPainelSinal.First;
  FrmDataModule.DataSourcePainelLinha.Enabled:= false;
  FrmDataModule.ADOQueryPainelLinha.First;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryPainelSinal.RecordCount,'Sinal...');
  MatrizSinal:= nil;
  SetLength(MatrizSinal, 4);
  for i := 0 to High(MatrizSinal) do
    SetLength(MatrizSinal[i], FrmDataModule.ADOQueryPainelSinal.RecordCount);
  //============================================================
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryPainelLinha.RecordCount,'Linha...');
  while not FrmDataModule.ADOQueryPainelLinha.Eof do
  begin
    TipoLinha:= FrmDataModule.ADOQueryPainelLinha.FieldByName('TipoLinha').AsString;
    if TipoLinha = '' then
    begin
      RChartDesenho.DataColor:= clBlack;
      RChartDesenho.LineWidth:= 1;
      RChartDesenho.PenStyle:= psDot;
    end;
    RChartDesenho.MoveTo(
    FrmDataModule.ADOQueryPainelLinha.FieldByName('X1').AsInteger,
    FrmDataModule.ADOQueryPainelLinha.FieldByName('Y1').AsInteger);
    RChartDesenho.DrawTo(
    FrmDataModule.ADOQueryPainelLinha.FieldByName('X2').AsInteger,
    FrmDataModule.ADOQueryPainelLinha.FieldByName('Y2').AsInteger);
    FrmDataModule.ADOQueryPainelLinha.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmPrincipal.ProgressBarAtualizar;
  i:=0;
  while not FrmDataModule.ADOQueryPainelSinal.Eof do
  begin
    MatrizSinal[0,i]:= FrmDataModule.ADOQueryPainelSinal.FieldByName('X1').AsString;
    MatrizSinal[1,i]:= FrmDataModule.ADOQueryPainelSinal.FieldByName('Y1').AsString;
    MatrizSinal[2,i]:= FrmDataModule.ADOQueryPainelSinal.FieldByName('TAG').AsString;
    MatrizSinal[3,i]:= FrmDataModule.ADOQueryPainelSinal.FieldByName('LocalInstalacao').AsString;
    //==============================================================
    sinalTeste(
    FrmDataModule.ADOQueryPainelSinal.FieldByName('X1').AsInteger,
    FrmDataModule.ADOQueryPainelSinal.FieldByName('Y1').AsInteger,
    FrmDataModule.ADOQueryPainelSinal.FieldByName('TAG').AsString,
    FrmDataModule.ADOQueryPainelSinal.FieldByName('LocalInstalacao').AsString);
    FrmDataModule.ADOQueryPainelSinal.Next;
    FrmPrincipal.ProgressBarIncremento(1);
    i:= i+1;
  end;
  FrmPrincipal.ProgressBarAtualizar;
  FrmDataModule.DataSourcePainelSinal.Enabled:= true;
  FrmDataModule.ADOQueryPainelSinal.First;
  FrmDataModule.DataSourcePainelLinha.Enabled:= true;
  FrmDataModule.ADOQueryPainelLinha.First;
  actZoomFit.Execute;
end;

procedure TFrmPainelDisponibilidade.actExcelExecute(Sender: TObject);
begin
  FrmPrincipal.ExcelStringGrid(StringGridSAP,'Informaçőes','','',1);
end;

procedure TFrmPainelDisponibilidade.actImagemExecute(Sender: TObject);
begin
  SavePictureDialog1.FileName:= PanelTitulo.Caption+'.wmf';
  if SavePictureDialog1.Execute then
    RChartDesenho.CopyToWMF(SavePictureDialog1.FileName,false);
end;

procedure TFrmPainelDisponibilidade.actImprimirExecute(Sender: TObject);
begin
  if not Assigned(FrmPreview) then
    FrmPreview:=TFrmPreview.Create(Application)
  else
    FrmPreview.Show;
  try
    FrmPreview.ListaTituloRelatorio:= TStringList.Create;
    FrmPreview.ListaTituloRelatorio.Add('Painel de Equipamentos Críticos');
    FrmPreview.RadioGroupRelatorio.ItemIndex:= 6;
    FrmPreview.PrintPreview.PrintJobTitle:= 'Painel de Equipamentos Críticos';
    FrmPreview.GeneratePages;
  except
    RChartDesenho.Align:= alClient;
  end;
end;

