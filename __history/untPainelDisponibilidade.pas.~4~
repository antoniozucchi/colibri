procedure TFrmPainelDisponibilidade.RChartDesenhoZoomPan(Sender: TObject);
  var
    rangeXLow,rangeXHigh,rangeYHigh,rangeYlow,rangeX,rangeY: Double;
    YLow,YHigh,XLow,XHigh,CentroX,CentroY,Largura,Altura: Double;
begin
  with RChartDesenho do
  begin
    rangeXHigh:= Scale1X.RangeHigh;
    rangeXLow:= Scale1X.RangeLow;
    rangeYHigh:= Scale1Y.RangeHigh;
    rangeYlow:= Scale1Y.RangeLow;
    rangeX:= rangeXHigh-rangeXLow;
    rangeY:= rangeYHigh-rangeYLow;
    Largura:= (Width-LRim-RRim);
    Altura:= (Height -TRim-BRim);
    //====================================
    if rangeX > rangeY*(Largura/Altura) then
      rangeY:= rangeX/(Largura/Altura)
    else
      rangeX:= rangeY*(Largura/Altura);
    //=====================================
    CentroX:= ((rangeXHigh-rangeXLow)/2)+rangeXLow;
    CentroY:= ((rangeYHigh-rangeYLow)/2)+rangeYLow;
    XLow:= CentroX-(rangeX/2);
    XHigh:= CentroX+(rangeX/2);
    YLow:= CentroY-(rangeY/2);
    YHigh:= CentroY+(rangeY/2);
    setRange(0,XLow,YLow,XHigh,YHigh);
  end;
end;

procedure TFrmPainelDisponibilidade.sinalTeste(X, Y: Integer; TAGBusca,LocalInstalacao: String);
  var
    SQLString,SQLBase,DataProcura: String;
begin
  DataProcura:= FormatDateTime('mm/dd/yyyy',StartOfTheMonth(now));
  RChartDesenho.DataColor:= clBlack;
  RChartDesenho.LineWidth:= 1;
  RChartDesenho.PenStyle:= psSolid;
  RChartDesenho.Brush.Style:= bsSolid;
  SQLString:= '';
  SQLString:= FrmPrincipal.palavraBusca(SQLString,'DenominacaoLocalInstalacao',
  'Contem',TAGBusca);
  SQLBase:= 'SELECT tblCarteiraTrabalho.* FROM tblCarteiraTrabalho '+
  'WHERE (((DataBaseInicio < #'+DataProcura+
  '#)AND(TipoAtvMnt LIKE "Z02")AND(LocalInstalacao LIKE '+
  QuotedStr(LocalInstalacao+'%')+'))AND('+SQLString+'));';
  FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
