  begin
    RChartDesenho.Brush.Color:= clFuchsia;
    RChartDesenho.FillColor:= clFuchsia;
  end
  else
  begin
    RChartDesenho.Brush.Color:= clGray;
    RChartDesenho.FillColor:= clGray;
  end;
  RChartDesenho.Ellipse(X,Y,14,14);
  //Verificar Fora de Operaçăo
  SQLString:= '';
  SQLString:= FrmPrincipal.palavraBusca(SQLString,'DenominacaoLocalInstalacao',
  'Contem',TAGBusca);
  SQLBase:= 'SELECT tblNotaManutencao.* FROM tblNotaManutencao '+
  FrmPrincipal.filtroFO+
  'AND((LocalInstalacao LIKE '+QuotedStr(LocalInstalacao+'%')+'))AND'+SQLString+';';
