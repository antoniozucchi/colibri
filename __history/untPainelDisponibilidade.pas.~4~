  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
  FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
  if not FrmDataModule.ADOQueryTemporarioDBMemoria.IsEmpty then
  begin
    RChartDesenho.Brush.Color:= clRed;
    RChartDesenho.FillColor:= clRed;
  end
  else//Verificar Restriçăo Operacional
  begin
    SQLString:= '';
    SQLString:= FrmPrincipal.palavraBusca(SQLString,'DenominacaoLocalInstalacao',
    'Contem',TAGBusca);
    SQLBase:= 'SELECT tblCarteiraTrabalho.* FROM tblCarteiraTrabalho '+
    'WHERE ((TextoBreveOM LIKE "RO:%")'+
    'AND(StatusUsuarioOM NOT LIKE "%AENT%")'+
    'AND(LocalInstalacao LIKE '+
    QuotedStr(LocalInstalacao+'%')+'))AND'+SQLString+';';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    if not FrmDataModule.ADOQueryTemporarioDBMemoria.IsEmpty then
    begin
      RChartDesenho.Brush.Color:= clYellow;
      RChartDesenho.FillColor:= clYellow;
    end
    else
    begin
      SQLString:= '';
      SQLString:= FrmPrincipal.palavraBusca(SQLString,'DenominacaoLocalInstalacao',
      'Contem',TAGBusca);
      SQLBase:= 'SELECT tblCarteiraTrabalho.* FROM tblCarteiraTrabalho '+
      'WHERE ((LocalInstalacao LIKE '+QuotedStr(LocalInstalacao+'%')+'))AND'+SQLString+';';
      FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
      FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
      FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
