procedure TFrmPainelDisponibilidade.RChartDesenhoMouseDown(Sender: TObject;
  Button: TMouseButton; Shift: TShiftState; X, Y: Integer);
  var
    posX,posY: Double;
    i,j,NoX,NoY,ers,Linha: Integer;
    SQLString,SQLBase,Filtro,LocalInstalacao: String;
    ListaFiltro: TStringList;
    Passou: Boolean;
begin
  try
    Passou:= false;
    posX:= RChartDesenho.MousePosX;
    posY:= RChartDesenho.MousePosY;
    ers:= 10;
    for j := 0 to StatusBar1.Panels.Count-1 do
      StatusBar1.Panels[j].Text:= '';
    for I := 0 to High(MatrizSinal[0]) do
    begin
      NoX:= StrToInt(MatrizSinal[0,i]);
      NoY:= StrToInt(MatrizSinal[1,i]);
      if (NoX<=posX+ers)AND(NoX>=posX-ers)AND
      (NoY<=posY+ers)AND(NoY>=posY-ers) then
      begin
        ListaFiltro:= FrmPrincipal.incialListaBusca(MatrizSinal[2,i]);
        LocalInstalacao:= MatrizSinal[3,i];
        Filtro:= 'Filtro: ';
        for j := 0 to ListaFiltro.Count-1 do
        begin
          StatusBar1.Panels[j].Text:= ListaFiltro[j];
          if Filtro <> 'Filtro: ' then
            Filtro:= Filtro+';'+ListaFiltro[j]
          else
            Filtro:= Filtro+ListaFiltro[j];
        end;
        FrmPrincipal.AutoFitStatusBar(StatusBar1);
        if btnSAP.Down then
        begin
          Passou:= true;
          StringGridSAP.RowCount:= 1;
          StringGridSAP.ColCount:= 10;
          StringGridSAP.Cells[0,0]:= 'Tipo';
          StringGridSAP.Cells[1,0]:= 'Tipo de Etapa de Serviço';
          StringGridSAP.Cells[2,0]:= 'Texto Breve OM';
          StringGridSAP.Cells[3,0]:= 'Inicio Avaria';
          StringGridSAP.Cells[4,0]:= 'Data Base Inicio';
          StringGridSAP.Cells[5,0]:= 'Ordem';
          StringGridSAP.Cells[6,0]:= 'Nota';
          StringGridSAP.Cells[7,0]:= 'Denominaçăo Local Instalaçăo';
          StringGridSAP.Cells[8,0]:= 'Status Usuário [OM]';
          StringGridSAP.Cells[9,0]:= 'Tipo Atv.Mnt.';
          //EQUIPAMENTOS FORA DE OPERAÇĂO
          SQLString:= '';
          SQLString:= FrmPrincipal.palavraBusca(SQLString,'DenominacaoLocalInstalacao',
          'Contem',MatrizSinal[2,i]);
          SQLString:= 'AND'+SQLString;
          FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
          FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
          FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(
          'SELECT tblNotaManutencao.* FROM tblNotaManutencao '+ FrmPrincipal.filtroFO+
          'AND ((LocalInstalacao LIKE '+ QuotedStr(LocalInstalacao+'%')+'))'+SQLString+';');
          FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
          if not FrmDataModule.ADOQueryTemporarioDBMemoria.IsEmpty then
          begin
            while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
            begin
              Linha:= StringGridSAP.RowCount;
              StringGridSAP.RowCount:= Linha+1;
              StringGridSAP.Cells[0,Linha]:= 'FO';
              StringGridSAP.Cells[1,Linha]:=
              FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
              FieldByName('txtTipoEtapaServico').AsString;
              StringGridSAP.Cells[2,Linha]:=
              FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
              FieldByName('TextoBreveNOTA').AsString;
              StringGridSAP.Cells[3,Linha]:=
              FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
              FieldByName('InicioAvaria').AsString;
              StringGridSAP.Cells[4,Linha]:= '';
              StringGridSAP.Cells[5,Linha]:=
              FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
              FieldByName('OrdemManutencao').AsString;
              StringGridSAP.Cells[6,Linha]:=
              FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
              FieldByName('NotaManutencao').AsString;
              StringGridSAP.Cells[7,Linha]:=
              FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
              FieldByName('DenominacaoLocalInstalacao').AsString;
              StringGridSAP.Cells[8,Linha]:='Busca por Nota IW28';
              StringGridSAP.Cells[9,Linha]:='Busca por Nota IW28';
              FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
            end;
          end;
          //EQUIPAMENTO COM RESTRIÇĂO OPERACIONAL
          SQLString:= '';
          SQLString:= FrmPrincipal.palavraBusca(SQLString,'DenominacaoLocalInstalacao',
          'Contem',MatrizSinal[2,i]);
          SQLString:= 'AND'+SQLString;
          SQLBase:=
          'SELECT OrdemManutencao,txtTipoEtapaServicoOM,'+
          'DataBaseInicio,TextoBreveOM,'+
          'NotaManutencao,DenominacaoLocalInstalacao, '+
          'LocalInstalacao,StatusUsuarioOM FROM tblCarteiraTrabalho '+
          'GROUP BY OrdemManutencao,txtTipoEtapaServicoOM,'+
          'DataBaseInicio,TextoBreveOM, '+
          'NotaManutencao,DenominacaoLocalInstalacao,'+
          'LocalInstalacao,StatusUsuarioOM '+
          'HAVING ((tblCarteiraTrabalho.TextoBreveOM LIKE "RO:%")'+
          'AND(tblCarteiraTrabalho.StatusUsuarioOM NOT LIKE "%AENT%")'+
          'AND(LocalInstalacao LIKE '+
          QuotedStr(LocalInstalacao+'%')+'))'+SQLString+';';
          FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
          FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
          FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
          FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
          if not FrmDataModule.ADOQueryTemporarioDBMemoria.IsEmpty then
          begin
            while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
            begin
              Linha:= StringGridSAP.RowCount;
              StringGridSAP.RowCount:= Linha+1;
              StringGridSAP.Cells[0,Linha]:= 'RO';
              StringGridSAP.Cells[1,Linha]:=
              FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
              FieldByName('txtTipoEtapaServicoOM').AsString;
              StringGridSAP.Cells[2,Linha]:=
              FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
              FieldByName('TextoBreveOM').AsString;
              StringGridSAP.Cells[3,Linha]:= '';
              StringGridSAP.Cells[4,Linha]:=
              FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
              FieldByName('DataBaseInicio').AsString;
              StringGridSAP.Cells[5,Linha]:=
              FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
