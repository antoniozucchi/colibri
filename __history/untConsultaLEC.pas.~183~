procedure TFrmConsultaLEC.actSAPSelecionadoExecute(Sender: TObject);
    var
    BuscaTAG,SQLBase,SQLString,BuscaLocal,BuscaInstalacao: String;
    BooleanLocalInstalacao,BooleanItemManutencao: Boolean;
    idLECLista: Integer;
begin
  idLECLista:= FrmDataModule.DataSourceLECLista.DataSet.FieldByName('idLECLista').AsInteger;
  //Busca Instala誽o
  BuscaInstalacao:= FrmPrincipal.palavraBusca('','Plataforma','Contem',
  FrmDataModule.DataSourceLECLista.DataSet.FieldByName('InstalacaoBusca').AsString,'AND');
  if BuscaInstalacao<>'' then
    BuscaInstalacao:= ')AND'+BuscaInstalacao
  else
    BuscaInstalacao:= ')';
  BooleanLocalInstalacao:= false;
  //Busca TAG
  BuscaTAG:= FrmDataModule.DataSourceLECLista.DataSet.FieldByName('TAG').AsString;
  SQLString:= FrmPrincipal.palavraBusca('','DenominacaoLocalInstalacao','Contem',BuscaTAG,'AND');
  SQLString:= FrmPrincipal.palavraBusca(SQLString,'LocalInstalacao','Contem',BuscaTAG,'OR');
  if SQLString <> '' then
  begin
    SQLBase:= 'SELECT tblLocalInstalacao.* FROM tblLocalInstalacao '+
    'WHERE (('+SQLString+BuscaInstalacao+');';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    BuscaLocal:= '';
    //=========================================================
    FrmDataModule.ADOQueryLECLocalInstalacao.Active:= false;
    FrmDataModule.ADOQueryLECLocalInstalacao.Parameters.Items[0].Value:= idLECLista;
    FrmDataModule.ADOQueryLECLocalInstalacao.Active:= true;
    while not FrmDataModule.ADOQueryLECLocalInstalacao.Eof do
      FrmDataModule.ADOQueryLECLocalInstalacao.Delete;
    //=========================================================
    while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
    begin
      if BuscaLocal = '' then
        BuscaLocal:= FrmDataModule.ADOQueryTemporarioDBMemoria.
        FieldByName('LocalInstalacao').AsString
      else
        BuscaLocal:= BuscaLocal+';'+FrmDataModule.ADOQueryTemporarioDBMemoria.
        FieldByName('LocalInstalacao').AsString;
      //=============================================================
      FrmDataModule.ADOQueryLECLocalInstalacao.Insert;
      FrmDataModule.ADOQueryLECLocalInstalacao.FieldByName('LocalInstalacao').AsString:=
      FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('LocalInstalacao').AsString;
      FrmDataModule.ADOQueryLECLocalInstalacao.FieldByName('DenominacaoLocalInstalacao').AsString:=
      FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('DenominacaoLocalInstalacao').AsString;
      FrmDataModule.ADOQueryLECLocalInstalacao.FieldByName('ImpactoFalha').AsString:=
      FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('ImpactoFalha').AsString;
      FrmDataModule.ADOQueryLECLocalInstalacao.Post;
      //=============================================================
      BooleanLocalInstalacao:= true;
      FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
    end;
  end;
  BooleanItemManutencao:= CriarLECItemManutncao(idLECLista,BuscaLocal);
  //==========================================================================
  FrmDataModule.ADOQueryLECLista.Edit;
  FrmDataModule.ADOQueryLECLista.FieldByName('BooleanLocalInstalacao').AsBoolean:= BooleanLocalInstalacao;
  FrmDataModule.ADOQueryLECLista.FieldByName('BooleanItemManutencao').AsBoolean:= BooleanItemManutencao;
  FrmDataModule.ADOQueryLECLista.Post;
  //==========================================================================
end;

