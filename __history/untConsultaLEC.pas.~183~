procedure TFrmConsultaLEC.actItemManutencaoExecute(Sender: TObject);
  var
    SQLBase,LocalInstalacao: String;
begin
  FrmDataModule.DataSourceLocalInstalacaoSAP.Enabled:= false;
  FrmDataModule.ADOQueryLocalInstalacaoSAP.First;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryLocalInstalacaoSAP.RecordCount,'Plano de Manuten誽o...');
  while not FrmDataModule.ADOQueryLocalInstalacaoSAP.Eof do
  begin
    LocalInstalacao:= FrmDataModule.DataSourceLocalInstalacaoSAP.DataSet.
    FieldByName('LocalInstalacao').AsString;
    SQLBase:= 'SELECT tblItemManutencao.* FROM tblItemManutencao '+
    'WHERE (LocalInstalacao LIKE '+QuotedStr(LocalInstalacao)+');';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    if not FrmDataModule.ADOQueryTemporarioDBMemoria.IsEmpty then
    begin
      FrmDataModule.ADOQueryLocalInstalacaoSAP.Edit;
      FrmDataModule.ADOQueryLocalInstalacaoSAP.FieldByName('BooleanItem').AsBoolean:= true;
      FrmDataModule.ADOQueryLocalInstalacaoSAP.Post;
    end
    else
    begin
      FrmDataModule.ADOQueryLocalInstalacaoSAP.Edit;
      FrmDataModule.ADOQueryLocalInstalacaoSAP.FieldByName('BooleanItem').AsBoolean:= false;
      FrmDataModule.ADOQueryLocalInstalacaoSAP.Post;
    end;
    FrmPrincipal.ProgressBarIncremento(1);
    FrmDataModule.ADOQueryLocalInstalacaoSAP.Next;
  end;
  FrmPrincipal.ProgressBarAtualizar;
  FrmDataModule.ADOQueryLocalInstalacaoSAP.First;
  FrmDataModule.DataSourceLocalInstalacaoSAP.Enabled:= true;
end;

