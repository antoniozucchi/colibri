procedure TFrmConsultaLEC.actExcluirLocalLECExecute(Sender: TObject);
    var
    BuscaLocal: String;
    BooleanItemManutencao: Boolean;
    idLECLista: Integer;
begin
  if Application.MessageBox(PChar('Deseja excluir todos os registros selecionados?'),'.::ATENЫO::.',36) = 6 then
  begin
    idLECLista:= FrmDataModule.DataSourceLECLista.DataSet.FieldByName('idLECLista').AsInteger;
    FrmDataModule.ADOQueryLECLocalInstalacao.First;
    while not FrmDataModule.ADOQueryLECLocalInstalacao.Eof do
    begin
      if FrmDataModule.ADOQueryLECLocalInstalacao.FieldByName('BooleanSelecao').AsBoolean then
        FrmDataModule.ADOQueryLECLocalInstalacao.Delete
      else
        FrmDataModule.ADOQueryLECLocalInstalacao.Next;
    end;
    //==============================================================
    FrmDataModule.ADOQueryLECLocalInstalacao.First;
    while not FrmDataModule.ADOQueryLECLocalInstalacao.Eof do
    begin
      if BuscaLocal = '' then
        BuscaLocal:= FrmDataModule.ADOQueryLECLocalInstalacao.
        FieldByName('LocalInstalacao').AsString
      else
        BuscaLocal:= BuscaLocal+';'+FrmDataModule.ADOQueryLECLocalInstalacao.
        FieldByName('LocalInstalacao').AsString;
      FrmDataModule.ADOQueryLECLocalInstalacao.Next;
    end;
    FrmDataModule.ADOQueryLECLocalInstalacao.First;
    //==============================================================
    BooleanItemManutencao:= CriarLECItemManutncao(idLECLista,BuscaLocal);
    FrmDataModule.ADOQueryLECLista.Edit;
    FrmDataModule.ADOQueryLECLista.FieldByName('BooleanItemManutencao').AsBoolean:= BooleanItemManutencao;
    FrmDataModule.ADOQueryLECLista.Post;
    //===============================================================
  end;
end;

procedure TFrmConsultaLEC.actExecutarScriptExecute(Sender: TObject);
begin
  FrmPrincipal.SaveDialog1.Filter := 'Visual Script|*.vbs';
  FrmPrincipal.SaveDialog1.DefaultExt := '*.vbs';
  FrmPrincipal.SaveDialog1.FileName:= 'Script';
  if FrmPrincipal.SaveDialog1.Execute then
  begin
    MemoScript.Lines.SaveToFile(FrmPrincipal.SaveDialog1.FileName);
    ShellExecute(0,'open',PChar(FrmPrincipal.SaveDialog1.FileName),'','',SW_SHOWNORMAL);
  end;
end;

procedure TFrmConsultaLEC.actFiltroInserirExecute(Sender: TObject);
begin
  case PageControlGeral.TabIndex of
    0:
    begin
      FrmPrincipal.inserirProcura(DBGridSAP,ColunasLayoutSAP);
      actProcurarSAP.Execute;
    end;
  end;

  if (FrmPrincipal.PanelFiltrosTabela.Visible)AND(FrmPrincipal.PanelAjuda1.Visible) then
    actFiltrosTabela.Execute;
end;

procedure TFrmConsultaLEC.actFiltrosExecute(Sender: TObject);
  var
    PalavraLista,PalavraBusca: String;
    i: Integer;
begin
  //Sistemas
  FrmPrincipal.configurarCheckListBox(CheckListBoxSistemaFiltro,DBGridSAP,ColunasLayoutSAP,true);
  //Plataformas
  PalavraBusca:= '';
  for I := 0 to CheckListBoxPlataforma.Count-1 do
  begin
    if CheckListBoxPlataforma.Checked[i] then
    begin
      PalavraLista:= CheckListBoxPlataforma.Items[i];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('Plataforma',PalavraBusca,'Contem',ColunasLayoutSAP,4,false);
  actProcurarSAP.Execute;
end;

