  'WHERE ((LocalInstalacao LIKE '+QuotedStr(LocalInstalacao)+'));';
  FrmDataModule.ADOQueryTemporarioDBOperacao.Close;
  FrmDataModule.ADOQueryTemporarioDBOperacao.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBOperacao.SQL.Add(SQLBase);
  FrmDataModule.ADOQueryTemporarioDBOperacao.Open;
  if not FrmDataModule.ADOQueryTemporarioDBOperacao.IsEmpty then
  begin
    FrmDataModule.ADOQueryLocalInstalacaoSAP.Edit;
    FrmDataModule.ADOQueryLocalInstalacaoSAP.FieldByName('BooleanLEC').AsBoolean:= true;
    FrmDataModule.ADOQueryLocalInstalacaoSAP.Post;
  end
  else
  begin
    FrmDataModule.ADOQueryLocalInstalacaoSAP.Edit;
    FrmDataModule.ADOQueryLocalInstalacaoSAP.FieldByName('BooleanLEC').AsBoolean:= false;
    FrmDataModule.ADOQueryLocalInstalacaoSAP.Post;
  end;
