procedure TFrmConsultaLEC.DBGridSAPDrawColumnCell(Sender: TObject;
  const Rect: TRect; DataCol: Integer; Column: TColumn; State: TGridDrawState);
  var
    BooleanCritico,BooleanLEC:Boolean;
begin
  FrmPrincipal.GridZebrado(DBGridSAP,ColunasLayoutSAP,State,Rect,DataCol,Column);
  if (Column.Field.FieldName = 'BooleanCritico') then
  begin
    if (FrmDataModule.DataSourceLocalInstalacaoSAP.DataSet.
    FieldByName('BooleanCritico').AsBoolean) then
    begin
      TDBGrid(Sender).Canvas.FillRect(Rect);
      FrmPrincipal.ImageList1.Draw(TDBGrid(Sender).Canvas, Rect.Left +10,Rect.Top + 1, 154);
    end
    else
    begin
      TDBGrid(Sender).Canvas.FillRect(Rect);
      FrmPrincipal.ImageList1.Draw(TDBGrid(Sender).Canvas, Rect.Left +10,Rect.Top + 1, 155);
    end;
  end
  else if (Column.Field.FieldName = 'ImpactoFalha') then
  begin
    BooleanCritico:= FrmDataModule.DataSourceLocalInstalacaoSAP.DataSet.FieldByName('BooleanCritico').AsBoolean;
    BooleanLEC:= FrmDataModule.DataSourceLocalInstalacaoSAP.DataSet.FieldByName('BooleanLEC').AsBoolean;
    if (BooleanCritico=true)AND(BooleanLEC=true) then
    begin
      DBGridSAP.Canvas.Brush.Color:= clLime;
      DBGridSAP.Font.Color:= clBlack;
      DBGridSAP.Canvas.FillRect(Rect);
      DBGridSAP.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if (BooleanCritico=true)AND(BooleanLEC=false) then
    begin
      DBGridSAP.Canvas.Brush.Color:= clRed;
      DBGridSAP.Font.Color:= clBlack;
      DBGridSAP.Canvas.FillRect(Rect);
      DBGridSAP.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if (BooleanCritico=false)AND(BooleanLEC=true) then
    begin
      DBGridSAP.Canvas.Brush.Color:= clFuchsia;
      DBGridSAP.Font.Color:= clBlack;
      DBGridSAP.Canvas.FillRect(Rect);
      DBGridSAP.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else
    begin
      DBGridSAP.Canvas.Brush.Color:= clSilver;
      DBGridSAP.Font.Color:= clBlack;
      DBGridSAP.Canvas.FillRect(Rect);
      DBGridSAP.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end;
  end;
end;

