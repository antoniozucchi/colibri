procedure TFrmConsultaLEC.actProcurarItemManutencaoExecute(Sender: TObject);
  var
    SQLBase,DescricaoItem,DenominacaoLocalInstalacao,LocalInstalacao,
    CentroTrabalho,ItemManutencao,PlanoManutencao,TipoEtapaServico: String;
    Linha: Integer;
begin
  try
    LocalInstalacao:= FrmDataModule.DataSourceLocalInstalacaoSAP.DataSet.FieldByName('LocalInstalacao').AsString;
    if ((LocalInstalacao <> '')AND(RLItemManutencao.Visible)) then
    begin
      SQLBase:= 'SELECT tblItemManutencao.* FROM tblItemManutencao '+
      'WHERE (LocalInstalacao LIKE '+QuotedStr(LocalInstalacao)+');';
      FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
      FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
      FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
      FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
      RLItemManutencao.RowCount:= 1;
      Linha:= 1;
      if FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount > 0 then
      begin
        FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount,'Item de Manuten誽o...');
        while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
        begin
          DescricaoItem:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
          FieldByName('DescricaoItem').AsString;
          DenominacaoLocalInstalacao:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
          FieldByName('DenominacaoLocalInstalacao').AsString;
          CentroTrabalho:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
          FieldByName('CentroTrabalho').AsString;
          ItemManutencao:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
          FieldByName('ItemManutencao').AsString;
          PlanoManutencao:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
          FieldByName('PlanoManutencao').AsString;
          TipoEtapaServico:= FrmDataModule.DataSourceTemporarioDBMemoria.DataSet.
          FieldByName('TipoEtapaServico').AsString;
          RLItemManutencao.RowCount:= RLItemManutencao.RowCount+1;
          RLItemManutencao.Cells[0,Linha]:= DescricaoItem;
          RLItemManutencao.Cells[1,Linha]:= DenominacaoLocalInstalacao;
          RLItemManutencao.Cells[2,Linha]:= CentroTrabalho;
          RLItemManutencao.Cells[3,Linha]:= ItemManutencao;
          RLItemManutencao.Cells[4,Linha]:= PlanoManutencao;
          RLItemManutencao.Cells[5,Linha]:= TipoEtapaServico;
          Linha:=RLItemManutencao.RowCount;
          FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
          FrmPrincipal.ProgressBarIncremento(1);
        end;
        FrmPrincipal.ProgressBarAtualizar;
        FrmPrincipal.AutoFitGrade(RLItemManutencao);
      end;
    end;
  except
    RLItemManutencao.RowCount:= 1;
    FrmPrincipal.ProgressBarAtualizar;
  end;
end;

