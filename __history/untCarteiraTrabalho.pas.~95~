procedure TFrmCarteiraTrabalho.edtProcuraTextoLongoOMKeyPress(Sender: TObject;
  var Key: Char);
  var
    SQLBase,SQLString,palavraBusca: String;
begin
  if (Key = #13) then
  begin
    if (edtProcuraTextoLongoOM.Text = '') then
      actLimparFiltros.Execute
    else
    begin
      SQLString:= '';
      SQLString:= FrmPrincipal.palavraBusca(SQLString,'TextoLongoCarteira',
      'Contem',edtProcuraTextoLongoOM.Text,'AND');
      if SQLString <> '' then
      begin
        SQLString:= 'WHERE'+SQLString;
      end;
      SQLBase:= 'SELECT tblTextoLongoCarteira.* FROM tblTextoLongoCarteira '+
      SQLString+';';
      FrmPrincipal.ProcuraQuery(SQLBase,FrmDataModule.ADOQueryTemporarioDBMemoria,StatusBar1);
      if not FrmDataModule.ADOQueryTemporarioDBMemoria.IsEmpty then
      begin
        PalavraBusca:= '';
        FrmDataModule.ADOQueryTemporarioDBMemoria.First;
        while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
        begin
          if PalavraBusca <> '' then
          PalavraBusca:= PalavraBusca+';'+FrmDataModule.DataSourceTemporarioDBMemoria.
          DataSet.FieldByName('OrdemManutencao').AsString
        else
          PalavraBusca:= FrmDataModule.DataSourceTemporarioDBMemoria.
          DataSet.FieldByName('OrdemManutencao').AsString;
          FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
        end;
      end;
      actLimparFiltros.Execute;
      case RadioGroupVisualizar.ItemIndex of
        0: FrmPrincipal.buscaFiledGrid1('OrdemManutencao',palavraBusca,'Exato',ColunasOM,4,false);
        1: FrmPrincipal.buscaFiledGrid1('OrdemManutencao',palavraBusca,'Exato',ColunasOP,4,false);
      end;
      actProcurar.Execute;
    end;
  end;
end;

function TFrmCarteiraTrabalho.filtroStatus: String;
  var
    SQLString,DataProcuraIncio,DataProcuraFim: String;
begin
  DataProcuraIncio:= FrmPrincipal.corrigirData(DateBaseInicioPicker.Date);
  DataProcuraFim:= FrmPrincipal.corrigirData(DateBaseFimPicker.Date);
  SQLString:= '';
  case RadioGroupVisualizar.ItemIndex of
    0: SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasOM,false);
    else SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasOP,false);
  end;
  if DateBaseInicioPicker.Checked then
  begin
    if (SQLString <> '') then
      SQLString:= SQLString+'AND';
    SQLString:= SQLString+'((DataBaseInicio >= #'+DataProcuraIncio+'#))';
  end;
  if DateBaseFimPicker.Checked then
  begin
    if (SQLString <> '') then
      SQLString:= SQLString+'AND';
    SQLString:= SQLString+'((DataBaseFim <= #'+DataProcuraFim+'#))';
  end;
  //teste de query
  if (SQLString <> '')AND(RadioGroupVisualizar.ItemIndex = 1) then
    SQLString:= ' WHERE '+SQLString
  else if (SQLString <> '')AND(RadioGroupVisualizar.ItemIndex=0) then
    SQLString:= ' HAVING '+SQLString;
  Result:= SQLString;
end;

