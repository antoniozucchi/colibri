procedure TFrmCarteiraTrabalho.actFiltroCheckListExecute(Sender: TObject);
  var
    ListaBusca: TStringList;
    PalavraLista,PalavraBusca: String;
    i: Integer;
begin
  case RadioGroupVisualizar.ItemIndex of
    0: FrmPrincipal.LimparColunasFiltro(DBGridCarteiraOM,ColunasOM);
    else FrmPrincipal.LimparColunasFiltro(DBGridCarteiraOP,ColunasOP);
  end;
  ListaBusca:= TStringList.Create;
  ListaBusca.delimiter:= ':';
  ListaBusca.StrictDelimiter:= False;
  PalavraBusca:= '';
  for I := 0 to CheckListBoxStatusUsuarioOM.Count-1 do
  begin
    if CheckListBoxStatusUsuarioOM.Checked[i] then
    begin
      ListaBusca.DelimitedText:= CheckListBoxStatusUsuarioOM.Items[i];
      PalavraLista:= ListaBusca[0];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  case RadioGroupVisualizar.ItemIndex of
    0: FrmPrincipal.buscaFiledGrid1('StatusUsuarioOM',PalavraBusca,'Contem',ColunasOM,4,false);
    else FrmPrincipal.buscaFiledGrid1('StatusUsuarioOM',PalavraBusca,'Contem',ColunasOP,4,false);
  end;
  //==================================================
  PalavraBusca:= '';
  for I := 0 to CheckListBoxStatusSistemaOM.Count-1 do
  begin
    if CheckListBoxStatusSistemaOM.Checked[i] then
    begin
      ListaBusca.DelimitedText:= CheckListBoxStatusSistemaOM.Items[i];
      PalavraLista:= ListaBusca[0];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  case RadioGroupVisualizar.ItemIndex of
    0: FrmPrincipal.buscaFiledGrid1('StatusSistemaOM',PalavraBusca,'Contem',ColunasOM,4,false);
    else FrmPrincipal.buscaFiledGrid1('StatusSistemaOM',PalavraBusca,'Contem',ColunasOP,4,false);
  end;
  //==================================================
  PalavraBusca:= '';
  if CheckListBoxTextoBreveOM.Checked[0] then//Fora de Operaçăo
    PalavraBusca:= 'FO:';
  if CheckListBoxTextoBreveOM.Checked[1] then//Restriçăo operacional
  begin
    if PalavraBusca <> '' then
      PalavraBusca:= PalavraBusca+';RO:'
    else
      PalavraBusca:= 'RO:'
  end;
  case RadioGroupVisualizar.ItemIndex of
