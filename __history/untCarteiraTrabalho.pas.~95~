function TFrmCarteiraTrabalho.NumPesquisaFiltrados(TipoHH: Integer): TRECDisponibilidade;
  var
    CentroTrabalhoOP1,CentroTrabalhoOP2: String;
    SomaValor,Valor: double;
begin
  Result.ValorTotal:= 0;
  Result.ListaCentroTrabalhoOP:=FrmPrincipal.incialListaBusca('');
  Result.ListaHHPlanejados:=FrmPrincipal.incialListaBusca('');
  SomaValor:= 0;
  Valor:= 0;
  FrmDataModule.ADOQueryCarteiraOP.First;
  CentroTrabalhoOP1:= FrmDataModule.DataSourceCarteiraOP.DataSet.
  FieldByName('CentroTrabalhoOP').AsString;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryCarteiraOP.RecordCount,'Gráfico');
  while not (FrmDataModule.ADOQueryCarteiraOP.Eof) do
  begin
    case TipoHH of
      0://HH Previsto
        Valor:= FrmDataModule.DataSourceCarteiraOP.DataSet.FieldByName('Trabalho').AsFloat-
        FrmDataModule.DataSourceCarteiraOP.DataSet.FieldByName('TrabalhoReal').AsFloat;
      1://HH Planejado
        Valor:= FrmDataModule.DataSourceCarteiraOP.DataSet.FieldByName('Trabalho').AsFloat;
      2://HH Realizado
        Valor:= FrmDataModule.DataSourceCarteiraOP.DataSet.FieldByName('TrabalhoReal').AsFloat;
    end;
    if Valor < 0 then
      Valor:= 0;
    SomaValor:= SomaValor+Valor;
    CentroTrabalhoOP2:= FrmDataModule.DataSourceCarteiraOP.DataSet.
    FieldByName('CentroTrabalhoOP').AsString;
    if CentroTrabalhoOP1<>CentroTrabalhoOP2 then
    begin
      SomaValor:= SomaValor-Valor;
      Result.ListaCentroTrabalhoOP.Add(CentroTrabalhoOP1);
      Result.ListaHHPlanejados.Add(FormatFloat('0.0',SomaValor));
      SomaValor:= Valor;
    end;
    CentroTrabalhoOP1:= CentroTrabalhoOP2;
    FrmDataModule.ADOQueryCarteiraOP.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmPrincipal.ProgressBarAtualizar;
  try
    if (CentroTrabalhoOP1 <> Result.ListaCentroTrabalhoOP[Result.ListaCentroTrabalhoOP.Count-1])then
    begin
      Result.ListaCentroTrabalhoOP.Add(CentroTrabalhoOP1);
      Result.ListaHHPlanejados.Add(FormatFloat('0.0',SomaValor));
    end;
  except
    if CentroTrabalhoOP1 <> '' then
    begin
      Result.ListaCentroTrabalhoOP.Add(CentroTrabalhoOP1);
      Result.ListaHHPlanejados.Add(FormatFloat('0.0',SomaValor));
    end
    else
    begin
      Result.ListaCentroTrabalhoOP.Add('000XXX00');
      Result.ListaHHPlanejados.Add('0.0');
    end;
  end;
  Result.ValorTotal:= SomaValor;
end;

