procedure TFrmCarteiraTrabalho.actProcurarExecute(Sender: TObject);
  var
    SQLString,SQLBase: String;
begin
  SQLString:= filtroStatus;
  try
    case RadioGroupVisualizar.ItemIndex of
      0:
      begin
        SQLBase:= 'SELECT tblCarteiraTrabalho.OrdemManutencao, tblCarteiraTrabalho.Plataforma, '+
        'tblCarteiraTrabalho.txtTipoEtapaServicoOM, tblCarteiraTrabalho.LocalInstalacao, '+
        'tblCarteiraTrabalho.DenominacaoLocalInstalacao, tblCarteiraTrabalho.TextoBreveOM, '+
        'tblCarteiraTrabalho.CentroTrabalhoOM, tblCarteiraTrabalho.DataReferencia, '+
        'tblCarteiraTrabalho.DataBaseInicio, tblCarteiraTrabalho.DataBaseFim, '+
        'tblCarteiraTrabalho.StatusUsuarioOM,tblCarteiraTrabalho.StatusSistemaOM, '+
        'tblCarteiraTrabalho.Sala, tblCarteiraTrabalho.CampoSelecao, '+
        'tblCarteiraTrabalho.PlanoManutencao, tblCarteiraTrabalho.NotaManutencao, '+
        'tblCarteiraTrabalho.Equipamento, tblCarteiraTrabalho.Prioridade, tblCarteiraTrabalho.ImpactoFalha, '+
        'tblCarteiraTrabalho.TotalReal, tblCarteiraTrabalho.TotalPlanejado, '+
        'tblCarteiraTrabalho.TipoAtvMnt,InicioProgramadoOM,FimProgramadoOM,'+
        'tblCarteiraTrabalho.CriadoPor, tblCarteiraTrabalho.DataEntrada, '+
        'tblCarteiraTrabalho.FSCI_FO, tblCarteiraTrabalho.FSMC_FO, tblCarteiraTrabalho.GrupoPlanejamento, '+
        'tblCarteiraTrabalho.BooleanCritico, tblCarteiraTrabalho.Status, tblCarteiraTrabalho.CPO FROM tblCarteiraTrabalho '+

        'GROUP BY tblCarteiraTrabalho.OrdemManutencao, tblCarteiraTrabalho.Plataforma, '+
        'tblCarteiraTrabalho.txtTipoEtapaServicoOM, tblCarteiraTrabalho.LocalInstalacao, '+
        'tblCarteiraTrabalho.DenominacaoLocalInstalacao, tblCarteiraTrabalho.TextoBreveOM, '+
        'tblCarteiraTrabalho.CentroTrabalhoOM, tblCarteiraTrabalho.DataReferencia, '+
        'tblCarteiraTrabalho.DataBaseInicio, tblCarteiraTrabalho.DataBaseFim, '+
        'tblCarteiraTrabalho.StatusUsuarioOM,tblCarteiraTrabalho.StatusSistemaOM, '+
        'tblCarteiraTrabalho.Sala, tblCarteiraTrabalho.CampoSelecao, '+
        'tblCarteiraTrabalho.PlanoManutencao, tblCarteiraTrabalho.NotaManutencao, '+
        'tblCarteiraTrabalho.Equipamento, tblCarteiraTrabalho.Prioridade, tblCarteiraTrabalho.ImpactoFalha, '+
        'tblCarteiraTrabalho.TotalReal, tblCarteiraTrabalho.TotalPlanejado, '+
        'tblCarteiraTrabalho.TipoAtvMnt,InicioProgramadoOM,FimProgramadoOM,'+
        'tblCarteiraTrabalho.CriadoPor, tblCarteiraTrabalho.DataEntrada, '+
        'tblCarteiraTrabalho.FSCI_FO, tblCarteiraTrabalho.FSMC_FO, tblCarteiraTrabalho.GrupoPlanejamento, '+
        'tblCarteiraTrabalho.BooleanCritico, tblCarteiraTrabalho.Status, tblCarteiraTrabalho.CPO ';
        SQLBase:= SQLBase+SQLString+' ORDER BY tblCarteiraTrabalho.Prioridade DESC;';
        FrmPrincipal.ProcuraQuery(SQLBase,FrmDataModule.ADOQueryCarteiraOM,StatusBar1);
      end;
      else
      begin
        if CheckBoxOperacaoSelecionada.Checked then
        begin
          if SQLString<>'' then
            SQLString:= SQLString+'OR((BooleanSelecao = TRUE))'
          else
            SQLString:= ' WHERE ((BooleanSelecao = TRUE))'
        end;
        SQLBase:= 'SELECT tblCarteiraTrabalho.*,(Trabalho-TrabalhoReal) as HHPrevisto FROM tblCarteiraTrabalho'+

        SQLString+' ORDER BY Prioridade DESC, Operacao ASC;';
        FrmPrincipal.ProcuraQuery(SQLBase,FrmDataModule.ADOQueryCarteiraOP,StatusBar1);
      end;
    end;
    FrmPrincipal.AutoFitStatusBar(StatusBar1);
    actConfigPlanilha.Execute;
  Except
    FrmDataModule.ADOQueryCarteiraOM.Active:= false;
    FrmDataModule.ADOQueryCarteiraOM.Active:= TRUE;
    FrmDataModule.ADOQueryCarteiraOP.Active:= false;
    FrmDataModule.ADOQueryCarteiraOP.Active:= TRUE;
    FrmPrincipal.AutoFitStatusBar(StatusBar1);
    actConfigPlanilha.Execute;
  end;
end;

