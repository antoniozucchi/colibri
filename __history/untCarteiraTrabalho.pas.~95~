procedure TFrmCarteiraTrabalho.actCimaExecute(Sender: TObject);
begin
  case RadioGroupVisualizar.ItemIndex of
    0: FrmPrincipal.moveCima(DBGridCarteiraOM,ColunasOM);
    else FrmPrincipal.moveCima(DBGridCarteiraOP,ColunasOP);
  end;
  actLimparFiltros.Execute;
end;

procedure TFrmCarteiraTrabalho.actCimaTudoExecute(Sender: TObject);
begin
  case RadioGroupVisualizar.ItemIndex of
    0:
    begin
      FrmPrincipal.botaoMoveTudo(FrmDataModule.ADOConnectionMemoria,
      'Carteira_OM.txt','Carteira_OM','TAB1;',
      DBGridCarteiraOM,ColunasOM);
      actLimparFiltros.Execute;
    end
    else
    begin
      FrmPrincipal.botaoMoveTudo(FrmDataModule.ADOConnectionMemoria,
      'Carteira_OP.txt','Carteira_OP','TAB1;',
      DBGridCarteiraOP,ColunasOP);
      actLimparFiltros.Execute;
    end
  end;
end;

procedure TFrmCarteiraTrabalho.actConfigPlanilhaExecute(Sender: TObject);
begin
  case RadioGroupVisualizar.ItemIndex of
    0:
    begin
      DBGridCarteiraOM.Visible:= true;
      DBGridCarteiraOP.Visible:= false;
      DBGridCarteiraOM.Align:= alClient;
    end;
    else
    begin
      DBGridCarteiraOM.Visible:= false;
      DBGridCarteiraOP.Visible:= true;
      DBGridCarteiraOP.Align:= alClient;
      if FrmPrincipal.logPerfil = 'Administrador' then
        DBGridCarteiraOP.ReadOnly:= false
      else
        DBGridCarteiraOP.ReadOnly:= true;
    end;
  end;
end;

procedure TFrmCarteiraTrabalho.actExcelExecute(Sender: TObject);
begin
  case RadioGroupVisualizar.ItemIndex of
    0: actExcelOM.Execute;
    else actExcelOP.Execute;
  end;
end;

procedure TFrmCarteiraTrabalho.actExcelOMExecute(Sender: TObject);
var
  Excel, Sheet: Variant;
  i,j,matrizLinha,matrizColuna,selRegistro,tipoNumero: Integer;
  Celula, Titulo,campoProcura: String;
begin
  selRegistro:= 0;
  try
    try
      Excel := CreateOleObject('Excel.Application');
      Excel.Workbooks.Add;
      Excel.Workbooks[1].WorkSheets[1].Name := 'Carteira OM';
      Sheet := Excel.Workbooks[1].WorkSheets['Carteira OM'];
      Excel.Caption := 'Carteira OM';
      //============================================
      selRegistro:= DBGridCarteiraOM.DataSource.DataSet.RecNo;
      matrizColuna := DBGridCarteiraOM.Columns.Count;
      matrizLinha :=  DBGridCarteiraOM.DataSource.DataSet.RecordCount;
      DBGridCarteiraOM.DataSource.Enabled:=false;
      // CONFIGURAÇĂO DO PROGRESSBAR
      FrmPrincipal.ProgressBarIncializa(matrizColuna*matrizLinha,'Gerando Excel...');
      //============================================
      for j := 0 to matrizColuna - 1 do
      begin
        Titulo:= DBGridCarteiraOM.Columns.Items[j].Title.Caption;
        campoProcura:= DBGridCarteiraOM.Columns.Items[j].FieldName;
        // Preencher os titulos
        Excel.Workbooks[1].Sheets[1].Cells[1, j+1] := Titulo;
        for i := 1 to matrizLinha do
        begin
          // Preencher as linhas
          DBGridCarteiraOM.DataSource.DataSet.RecNo:= i;
          tipoNumero:= FrmPrincipal.isNumeric(DBGridCarteiraOM.DataSource.DataSet.FieldByName(campoProcura).AsString);
          case tipoNumero of
            0://texto
            begin
              Excel.Workbooks[1].Sheets[1].Cells[i+1, j+1].NumberFormat:= '@';
              Excel.Workbooks[1].Sheets[1].Cells[i+1, j+1] :=
              DBGridCarteiraOM.DataSource.DataSet.FieldByName(campoProcura).AsString;
            end;
            1://Inteiro
            begin
              Excel.Workbooks[1].Sheets[1].Cells[i+1, j+1].NumberFormat:= '0';
              Excel.Workbooks[1].Sheets[1].Cells[i+1, j+1] :=
              DBGridCarteiraOM.DataSource.DataSet.FieldByName(campoProcura).AsInteger;
            end;
            2://Float
            begin
              Excel.Workbooks[1].Sheets[1].Cells[i+1, j+1].NumberFormat:= '0,00';
              Excel.Workbooks[1].Sheets[1].Cells[i+1, j+1] :=
              DBGridCarteiraOM.DataSource.DataSet.FieldByName(campoProcura).AsFloat;
            end;
            3://Data
            begin
              Excel.Workbooks[1].Sheets[1].Cells[i+1, j+1].NumberFormat:= 'dd/mm/aaaa';
              Excel.Workbooks[1].Sheets[1].Cells[i+1, j+1] :=
              DBGridCarteiraOM.DataSource.DataSet.FieldByName(campoProcura).AsDateTime;
            end;
          end;
          // CONFIGURAÇĂO DAS CÉLULAS DAS LINHAS
          Sheet.Rows[i+1].VerticalAlignment := 2;
          // 1=Top - 2=Center - 3=Bottom
          Sheet.Rows[i+1].HorizontalAlignment := 3; // 3=Center }
          // Atualizar ProgressBar
          FrmPrincipal.ProgressBarIncremento(1);
        end;
      end;
      //Coluna do texto longo
      Excel.Workbooks[1].Sheets[1].Cells[1, matrizColuna+1] := 'Texto Longo';
      for i := 1 to matrizLinha do
      begin
        DBGridCarteiraOM.DataSource.DataSet.RecNo:= i;
        Excel.Workbooks[1].Sheets[1].Cells[i+1, matrizColuna+1].NumberFormat:= '@';
        Excel.Workbooks[1].Sheets[1].Cells[i+1, matrizColuna+1] :=
        FrmPrincipal.verificaTextoLongoCarteira(FrmDataModule.
        DataSourceCarteiraOM.DataSet.FieldByName('OrdemManutencao').asString);
      end;
      // letras do cabeçalho
      Sheet.Rows[1].Font.Bold := true;
      Sheet.Rows[1].Font.Italic := true;
      Sheet.Rows[1].VerticalAlignment := 2; // 1=Top - 2=Center - 3=Bottom
      Sheet.Rows[1].HorizontalAlignment := 3; // 3=Center
      // desenha as grades da tabela
      Celula := FrmPrincipal.RefToCell(matrizColuna+1, matrizLinha+1);
      Sheet.Range['A1', Celula].Borders.LineStyle := 1;
      Sheet.Range['A1', Celula].Borders.Weight := 2;
      Sheet.Range['A1', Celula].Borders.ColorIndex := 1;
      Sheet.Range['A1', FrmPrincipal.RefToCell(matrizColuna+1, 1)].Interior.Color := clSilver;
      // Cor da Célula
      Excel.Visible := true;
      Excel.columns.Autofit;
    finally
      DBGridCarteiraOM.DataSource.Enabled:=true;
      DBGridCarteiraOM.DataSource.DataSet.RecNo:= selRegistro;
      // Atualizar ProgressBar
      FrmPrincipal.ProgressBarAtualizar;
    end;
  except
    MessageBox(0, 'Erro de conexăo com o Excel' + #13 + #10 +
    'Verifique se o Microsoft Office Excel esta instalado na sua máquina.',
    'Excel', MB_ICONERROR);
    // Atualizar ProgressBar
    FrmPrincipal.ProgressBarAtualizar;
  end;
end;

