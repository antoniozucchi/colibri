procedure TFrmPlataforma.FormCreate(Sender: TObject);
  var
    rangeXLow,rangeXHigh,rangeYHigh,rangeYlow,rangeX,rangeY: Double;
    YLow,YHigh,XLow,XHigh,CentroX,CentroY,Largura,Altura: Double;
    NoOrigem: TPointFloat;
begin
  //===============================================================
  AlturaAgora:=0;
  RChartMapa.GridDx:= edtGridXFEA.Value;
  RChartMapa.GridDy:= edtGridYFEA.Value;
  RChartMapa.GridStyle:= gsNone;
  PageControl1.TabIndex:= 0;
  //=====================================
  txtLayout:= 'Plataforma.txt';
  //Incicializaçăo
  FrmPrincipal.SetUpColunasLayout(DBGridPlataformas, ColunasLayout);
  FrmPrincipal.CarregarRLColunas(txtLayout, ColunasLayout);
  FrmPrincipal.CarregarColunasGRID(FrmDataModule.ADOConnectionConsulta,
  'tblPlataforma',DBGridPlataformas,ColunasLayout);
  //Carrgear Mapa com configuraçăo incial
  try
    actMarcar.Execute;
    actBrasil.Execute;
    NoOrigem.X:= -4102.2959;
    NoOrigem.Y:= -1233.1057;
    with RChartMapa do
    begin
      rangeXHigh:= NoOrigem.X + 90;
      rangeXLow:= NoOrigem.X - 90;
      rangeYHigh:= NoOrigem.Y + 90;
      rangeYlow:= NoOrigem.Y - 90;
      rangeX:= rangeXHigh-rangeXLow;
      rangeY:= rangeYHigh-rangeYLow;
      Largura:= (Width-LRim-RRim);
      Altura:= (Height -TRim-BRim);
      //====================================
      if rangeX > rangeY*(Largura/Altura) then
        rangeY:= rangeX/(Largura/Altura)
      else
        rangeX:= rangeY*(Largura/Altura);
      //=====================================
      CentroX:= ((rangeXHigh-rangeXLow)/2)+rangeXLow;
      CentroY:= ((rangeYHigh-rangeYLow)/2)+rangeYLow;
      XLow:= CentroX-(rangeX/2);
      XHigh:= CentroX+(rangeX/2);
      YLow:= CentroY-(rangeY/2);
      YHigh:= CentroY+(rangeY/2);
      setRange(0,XLow,YLow,XHigh,YHigh);
  end;
  except
  end;
  //======ADICIONAR TABSET DO FOMRMDI=======
  FrmPrincipal.MDIChildCreated(self.Handle);
  //Configuraçăo de Perfil
  if ((FrmPrincipal.logPerfil = 'Administrador') OR
  (FrmPrincipal.logPerfil = 'Supervisor')) then
  begin
    DBNavigatorCadastro.Enabled:= true;
    DBGridPlataformas.ReadOnly:= false;
    actCalcularXY.Enabled:= true;
  end
  else
  begin
    DBNavigatorCadastro.Enabled:= false;
    DBGridPlataformas.ReadOnly:= true;
    actCalcularXY.Enabled:= false;
  end;

  actProcurar.Execute;

end;

