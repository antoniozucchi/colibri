procedure TFrmRTI.actFiltroInserirExecute(Sender: TObject);
begin
  FrmPrincipal.inserirProcura(DBGridRTI,ColunasLayoutRTI);
  actProcurarRTI.Execute;
  if (FrmPrincipal.PanelFiltrosTabela.Visible)AND(FrmPrincipal.PanelAjuda1.Visible) then
    actFiltrosTabela.Execute;
end;

procedure TFrmRTI.actFiltrosExecute(Sender: TObject);
  var
    PalavraLista,PalavraBusca: String;
    i: Integer;
begin
  //Sistemas
  FrmPrincipal.configurarCheckListBox(CheckListBoxSistemaFiltro,DBGridRTI,ColunasLayoutRTI,true);
  //Plataformas
  PalavraBusca:= '';
  for I := 0 to CheckListBoxPlataforma.Count-1 do
  begin
    if CheckListBoxPlataforma.Checked[i] then
    begin
      PalavraLista:= CheckListBoxPlataforma.Items[i];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('Plataforma',PalavraBusca,'Contem',ColunasLayoutRTI,4,false);
  //Tipo Etapa Serviço
  PalavraBusca:= '';
  for I := 0 to CheckListBoxTipoEtapaServico.Count-1 do
  begin
    if CheckListBoxTipoEtapaServico.Checked[i] then
    begin
      PalavraLista:= CheckListBoxTipoEtapaServico.Items[i];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('txtTipoEtapaServico',PalavraBusca,'Contem',ColunasLayoutRTI,4,false);
  actProcurarRTI.Execute;
end;

