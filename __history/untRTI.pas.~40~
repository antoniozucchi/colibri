procedure TFrmRTI.actProcurarRTIExecute(Sender: TObject);
    var
    SQLString,SQLBase,DataProcuraIncio,DataProcuraFim,ProcuraDatas: String;
begin
  DataProcuraIncio:= (FormatDateTime('mm/dd/yyyy',dataInicio.Date));
  DataProcuraFim:= (FormatDateTime('mm/dd/yyyy',dataFim.Date));


  if ((dataInicio.Checked)AND(dataFim.Checked)) then
    ProcuraDatas:= 'WHERE (DataVencimento BETWEEN #'+DataProcuraIncio+'# and #'+DataProcuraFim+'#)'
  else if ((dataInicio.Checked)AND(dataFim.Checked=false)) then
    ProcuraDatas:= 'WHERE (DataVencimento > #'+DataProcuraIncio+'#)'
  else if ((dataInicio.Checked=false)AND(dataFim.Checked)) then
    ProcuraDatas:= 'WHERE (DataVencimento < #'+DataProcuraFim+'#)'
  else
    ProcuraDatas:= '';

  if ProcuraDatas <> '' then
  begin
    SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayoutRTI,false);
    if SQLString <> '' then
      SQLString:= ' AND '+SQLString;
  end
  else
    SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayoutRTI,true);
  //===============================================
  SQLBase:= 'SELECT tblRTI.* FROM tblRTI '+ProcuraDatas+
  SQLString+' ORDER BY DataVencimento,Plataforma;';
  FrmPrincipal.ProcuraQuery(SQLBase,FrmDataModule.ADOQueryRTI,StatusBarRTI);
end;

