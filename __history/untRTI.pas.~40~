procedure TFrmRTI.DBGridRTIDrawColumnCell(Sender: TObject;
  const Rect: TRect; DataCol: Integer; Column: TColumn; State: TGridDrawState);
    var
      DataVencimento: TDateTime;
      StatusProgramacao: String;
begin
  FrmPrincipal.GridZebrado(DBGridRTI,
  ColunasLayoutRTI,State,Rect,DataCol,Column);
  if (Column.Field.FieldName = 'BooleanCritico') then
  begin
    if (FrmDataModule.DataSourceRTI.DataSet.
    FieldByName('BooleanCritico').AsBoolean) then
    begin
      TDBGrid(Sender).Canvas.FillRect(Rect);
      FrmPrincipal.ImageList1.Draw(TDBGrid(Sender).Canvas, Rect.Left +10,Rect.Top + 1, 154);
    end
    else
    begin
      TDBGrid(Sender).Canvas.FillRect(Rect);
      FrmPrincipal.ImageList1.Draw(TDBGrid(Sender).Canvas, Rect.Left +10,Rect.Top + 1, 155);
    end;
  end
  else if (Column.Field.FieldName = 'BCVT') then
  begin
    if (FrmDataModule.DataSourceRTI.DataSet.
    FieldByName('BCVT').AsBoolean) then
    begin
      TDBGrid(Sender).Canvas.FillRect(Rect);
      FrmPrincipal.ImageList1.Draw(TDBGrid(Sender).Canvas, Rect.Left +10,Rect.Top + 1, 154);
    end
    else
    begin
      TDBGrid(Sender).Canvas.FillRect(Rect);
      FrmPrincipal.ImageList1.Draw(TDBGrid(Sender).Canvas, Rect.Left +10,Rect.Top + 1, 155);
    end;
  end
  else if (Column.Field.FieldName = 'DataVencimento') then
  begin
    DataVencimento:= FrmDataModule.DataSourceRTI.DataSet.
    FieldByName('DataVencimento').AsDateTime;
    if (DataVencimento > now) then
    begin
      DBGridRTI.Canvas.Brush.Color:= clLime;
      DBGridRTI.Font.Color:= clBlack;
      DBGridRTI.Canvas.FillRect(Rect);
      DBGridRTI.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else
    begin
      DBGridRTI.Canvas.Brush.Color:= clRed;
      DBGridRTI.Font.Color:= clBlack;
      DBGridRTI.Canvas.FillRect(Rect);
      DBGridRTI.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end;
  end
  else if (Column.Field.FieldName = 'StatusProgramacao') then
  begin
    StatusProgramacao:= FrmDataModule.DataSourceRTI.DataSet.
    FieldByName('StatusProgramacao').AsString;
    if (StatusProgramacao = 'Pendente') then
    begin
      DBGridRTI.Canvas.Brush.Color:= clSilver;
      DBGridRTI.Font.Color:= clBlack;
      DBGridRTI.Canvas.FillRect(Rect);
      DBGridRTI.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if (StatusProgramacao = 'Planejado') then
    begin
      DBGridRTI.Canvas.Brush.Color:= clBlue;
      DBGridRTI.Font.Color:= clBlack;
      DBGridRTI.Canvas.FillRect(Rect);
      DBGridRTI.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end
    else if (StatusProgramacao = 'Realizado') then
    begin
      DBGridRTI.Canvas.Brush.Color:= clLime;
      DBGridRTI.Font.Color:= clBlack;
      DBGridRTI.Canvas.FillRect(Rect);
      DBGridRTI.DefaultDrawColumnCell(Rect, DataCol,Column, State);
    end;
  end;
end;

procedure TFrmRTI.DBGridRTIKeyPress(Sender: TObject; var Key: Char);
begin
  if not ((DBGridRTI.SelectedField.FieldName = 'StatusProgramacao')OR
  (DBGridRTI.SelectedField.FieldName = 'Observacao')) then
    Key:= #0;
end;

procedure TFrmRTI.DBGridRTITitleClick(Column: TColumn);
begin
  FrmPrincipal.configurarFiltro(0,Column.FieldName,IntToStr(Column.Index),
  Column.ReadOnly,actFiltroInserir,actGridASC,actGridDESC,actGridDESC);
  //======================================================
  FrmPrincipal.titleGrid(ColunasLayoutRTI,'Memoria',
  FrmDataModule.ADOQueryRTI.SQL.Text);
end;

procedure TFrmRTI.FormClose(Sender: TObject;
  var Action: TCloseAction);
begin
  Action:= caFree;
  FrmRTI:=nil;
end;

procedure TFrmRTI.FormCreate(Sender: TObject);
  var
    Inicio,Fim,Ano: String;
begin
  FrmPrincipal.MDIChildCreated(self.Handle);
  FrmPrincipal.SetUpColunasLayout(DBGridRTI,
  ColunasLayoutRTI);
  Ano:= IntToStr(YearOf(now));
  Inicio:= '01/01/'+Ano;
  Fim:= '31/12/'+Ano;
  dataInicio.DateTime:= StrToDate(Inicio);
  dataFim.DateTime:= StrToDate(Fim);
  dataInicio.Checked:= false;
  dataFim.Checked:= false;
  actProcurarRTI.Execute;
  FrmDataModule.ADOQueryPlataformaControle.Active:= false;
  FrmDataModule.ADOQueryPlataformaControle.Active:= true;
  FrmPrincipal.carregarCheckListBox(FrmDataModule.ADOQueryPlataformaControle,
  CheckListBoxPlataforma,'Plataforma');
  FrmPrincipal.carregarCheckListBox(FrmDataModule.ADOQueryTipoEtapaServico_Carteira,
  CheckListBoxTipoEtapaServico,'TipoEtapaServico');
  FrmPrincipal.carregarFiltroSistemaCheckList(CheckListBoxSistemaFiltro,DBGridRTI);
  if ((FrmPrincipal.logPerfil = 'PCM')OR
  (FrmPrincipal.logPerfil = 'Administrador')) then
  begin
    DBGridRTI.ReadOnly:= false;
  end
  else
  begin
    DBGridRTI.ReadOnly:= true;
  end;
end;

procedure TFrmRTI.FormDestroy(Sender: TObject);
begin
  FrmPrincipal.MDIChildDestroyed(self.Handle);
end;

procedure TFrmRTI.WMMDIACTIVATE(var msg: TWMMDIACTIVATE);
var
  active: TWinControl;
  idx: Integer;
begin
  active := FindControl(msg.ActiveWnd) ;

  if Assigned(active) then
  begin
    idx := FrmPrincipal.mdiChildrenTabs.Tabs.IndexOfObject(TObject(msg.ActiveWnd));
    FrmPrincipal.mdiChildrenTabs.Tag := -1;
    FrmPrincipal.mdiChildrenTabs.TabIndex := idx;
    FrmPrincipal.mdiChildrenTabs.Tag := 0;
  end;
end;

