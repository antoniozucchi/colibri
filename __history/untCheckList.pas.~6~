    //Conexăo com a planilha do PI
    ExcelPI := CreateOleObject('Excel.Application');
    FrmPrincipal.ProgressBarIncremento(3);
    // Abrir o arquivo
    Endereco:= ExtractFilePath(Application.ExeName)+'Arquivos\ConexaoPI.xlsx';
    ExcelPI.Workbooks.Open(Endereco);
    FrmPrincipal.ProgressBarIncremento(4);
    // Abrir a primeira planilha do arquivo
    SheetCadastroPI := ExcelPI.WorkSheets[1];
    ExcelPI.Visible := true;
    ExcelPI.columns.Autofit;
    ExcelPI.ActiveWorkbook.Save;
    FrmPrincipal.ProgressBarIncremento(5);
    // Verificar necessiade de soncronismo
    PI_Sincronizar:= FrmDataModule.DataSourceColibri.DataSet.
    FieldByName('PI_Sincronizar').AsString;
    PI_SincronizarExcel:= ExcelPI.Workbooks[1].Sheets[1].Cells[1,26];
    if (PI_SincronizarExcel<>PI_Sincronizar) then
    begin
      actSincronizar_PI.Enabled:= true;
      actAtualizarPI.Enabled:= false;
    end
    else
    begin
      actSincronizar_PI.Enabled:= false;
      actAtualizarPI.Enabled:= true;
    end;
  end
  else
  begin
    actSAPSelecionado.Enabled:= false;
    actSAPFiltrados.Enabled:= false;
    actSincronizar_PI.Enabled:= false;
    actAtualizarPI.Enabled:= false;
    actImportarGeralPI.Enabled:= false;
    actCalcularPI.Enabled:= false;
    actAtualizarLimiteVinculado.Enabled:= false;
    DBNavigatorLimiteOperacional.Enabled:= false;
    DBNavigatorCadastroPI.Enabled:= false;
    DBNavigatorRegisros.Enabled:= false;
    DBGridLimiteOperacional.ReadOnly:= true;
    DBGridCadastroPI.ReadOnly:= true;
    DBGridCheckList.ReadOnly:= true;
    actGravarCheck.Enabled:= false;
  end;
  actProcurarCheckList.Execute;
  FrmPrincipal.ProgressBarAtualizar;
end;

