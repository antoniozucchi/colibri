procedure TFrmCheckList.actSincronizar_PIExecute(Sender: TObject);
  var
    i,NumLinhas: Integer;
    LimiteVinculado,Plataforma,Sistema,NomeVariavel,TAG,TAGPI,RootPath,
    LocalInstalacao,DenominacaoLocalInstalacao,
    CodigoLimiteOperacional,DiasHistorico,idPICadastro: String;
begin
  try
    ExcelPI.Visible := false;
    i:= 2;
    FrmDataModule.ADOQueryAtualizaCadastroPI.Active:= false;
    FrmDataModule.ADOQueryAtualizaCadastroPI.Active:= true;
    FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryAtualizaCadastroPI.RecordCount,
    'Atualizando a planilha Excel de conexăo com o PI...');
    //Configuraçăo Incial
    SheetCadastroPI.Range['F1','Q1500'].ClearContents;
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,1] := 'Valor Médio (Histórico)';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,2] := 'Valor Atual [PI]';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,3] := 'Unidade [PI]';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,4] := 'Descriçăo [PI]';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,5] := 'Tipo Var. [PI]';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,6] := 'TAG [PI]';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,7] := 'Root Path [PI]';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,8] := 'Plataforma';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,9] := 'Sistema';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,10] := 'Descriçăo da Variavel';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,11] := 'TAG';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,12] := 'Histórico (Dias)';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,13] := 'Local de Instalaçăo [SAP]';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,14] := 'Denomi. Local de Instalaçăo [SAP]';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,15] := 'Código';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,16] := 'idLimite';
    ExcelPI.Workbooks[1].Sheets[1].Cells[1,17] := 'Limite Vinculado';
    //Letras do cabeçalho
    SheetCadastroPI.Rows[1].Font.Bold := true;
    SheetCadastroPI.Rows[1].Font.Italic := true;
    SheetCadastroPI.Rows[1].VerticalAlignment := 2; // 1=Top - 2=Center - 3=Bottom
    SheetCadastroPI.Rows[1].HorizontalAlignment := 3; // 3=Center
    //Desenha as grades da tabela
    NumLinhas:= FrmDataModule.ADOQueryAtualizaCadastroPI.RecordCount+1;
    SheetCadastroPI.Range['A1','Q'+IntToStr(NumLinhas)].Borders.LineStyle := 1;
    SheetCadastroPI.Range['A1','Q'+IntToStr(NumLinhas)].Borders.Weight := 2;
    SheetCadastroPI.Range['A1','Q'+IntToStr(NumLinhas)].Borders.ColorIndex := 1;
    SheetCadastroPI.Range['A1','Q1'].Interior.Color := clYellow;
    //===========================================================
    while not FrmDataModule.ADOQueryAtualizaCadastroPI.Eof do
    begin
      //Integer
      idPICadastro:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('idPICadastro').AsString;
      CodigoLimiteOperacional:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('CodigoLimiteOperacional').AsString;
      DiasHistorico:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('DiasHistorico').AsString;
      //String
      LimiteVinculado:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('LimiteVinculado').AsString;
      Plataforma:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('Plataforma').AsString;
      Sistema:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('Sistema').AsString;
      NomeVariavel:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('NomeVariavel').AsString;
      TAG:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('TAG').AsString;
      TAGPI:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('TAGPI').AsString;
      RootPath:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('RootPath').AsString;
      LocalInstalacao:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('LocalInstalacao').AsString;
      DenominacaoLocalInstalacao:= FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.
      FieldByName('DenominacaoLocalInstalacao').AsString;
      //===========================================================
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,6] := TAGPI;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,7] := RootPath;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,8] := Plataforma;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,9] := Sistema;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,10] := NomeVariavel;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,11] := TAG;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,12] := DiasHistorico;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,13] := LocalInstalacao;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,14] := DenominacaoLocalInstalacao;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,15] := idPICadastro;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,16] := CodigoLimiteOperacional;
      ExcelPI.Workbooks[1].Sheets[1].Cells[i,17] := LimiteVinculado;
      //===========================================================
      FrmDataModule.ADOQueryAtualizaCadastroPI.Next;
      FrmPrincipal.ProgressBarIncremento(1);
      i:= i+1;
    end;
    FrmPrincipal.ProgressBarAtualizar;
    GravarSincronizar_PI;
    actSincronizar_PI.Enabled:= false;
    actAtualizarPI.Enabled:= true;
    ExcelPI.Visible := true;
    actAualizaPlanilhas.Execute;
  except
    FrmPrincipal.ProgressBarAtualizar;
    ExcelPI.Visible := true;
  end;
end;

