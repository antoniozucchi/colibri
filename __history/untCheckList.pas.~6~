procedure TFrmCheckList.ImportarGeralPI(ExcelImportar: Variant);
  var
    i, matrizLinha,naoBranco,ARow: Integer;
    TAGPI: String;
    ListaErro: TStringList;
begin
  try
    ARow:= 2;
    ListaErro:= TStringList.Create;
    ListaErro.Clear;
    // ============================================
    //Excluir todos os registros atuais
    FrmPrincipal.deleteQuery(FrmDataModule.ADOQueryCadastroPI,'Cadastro PI');
    //Verificar a ultima Linha
    i:= 1;
    matrizLinha:= i;
    naoBranco:= Length(ExcelImportar.Workbooks[1].Sheets[1].Cells[ARow, 6]);
    while (naoBranco <> 0) do
    begin
      matrizLinha:= ARow + i;
      naoBranco:= Length(ExcelImportar.Workbooks[1].Sheets[1].Cells[ARow+i,6]);
      i:= i + 1;
    end;
    matrizLinha:= matrizLinha - 1;
    FrmDataModule.DataSourceCadastroPI.Enabled := false;
    // Inicializar ProgressBar
    FrmPrincipal.ProgressBarIncializa(matrizLinha,
    'Importar Excel: Cadastro PI...');
    // ============================================
    for i := ARow to matrizLinha do
    begin
      try
        // Inserir novo registro na tabela de dados
        FrmDataModule.ADOQueryCadastroPI.Insert;
        // Preencher dados
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('TAGPI').AsString:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,6];
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('RootPath').AsString:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,7];
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('Plataforma').AsString:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,8];
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('Sistema').AsString:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,9];
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('NomeVariavel').AsString:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,10];
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('TAG').AsString:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,11];
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('DiasHistorico').AsString:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,12];
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('LocalInstalacao').AsString:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,13];
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('DenominacaoLocalInstalacao').AsString:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,14];
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('CodigoLimiteOperacional').AsInteger:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,16];
        FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName
        ('LimiteVinculado').AsString:= ExcelImportar.Workbooks[1].Sheets[1].Cells[i,17];
        //====================================================
        FrmDataModule.ADOQueryCadastroPI.Post;
        ExcelImportar.Workbooks[1].Sheets[1].Cells[i,15]:= FrmDataModule.DataSourceCadastroPI.
        DataSet.FieldByName('idPICadastro').AsString;
      except
        FrmDataModule.ADOQueryCadastroPI.Cancel;
        ListaErro.Add(ExcelImportar.Workbooks[1].Sheets[1].Cells[i,6]);
      end;
      // Incremento ProgressBar
      FrmPrincipal.ProgressBarIncremento(1);
    end;
    FrmDataModule.ADOQueryCadastroPI.First;
    FrmDataModule.DataSourceCadastroPI.Enabled := true;
    // Atualizar ProgressBar
    FrmPrincipal.ProgressBarAtualizar;
    if ListaErro.Count > 0 then
    begin
      TAGPI:= '';
      for I := 0 to ListaErro.Count -1 do
        TAGPI:= TAGPI+#13+ListaErro[i];

      ShowMessage('Registros năo importados com erro:'+#13+TAGPI);
    end;
  except
    MessageBox(0, 'Erro de conexăo com o Excel' + #13 + #10 +
    'Verifique se o Microsoft Office Excel esta instalado na sua máquina.',
    'Excel', MB_ICONERROR);
    // ==========================================================================
    FrmDataModule.ADOQueryCadastroPI.First;
    FrmDataModule.DataSourceCadastroPI.Enabled := true;
    // Atualizar ProgressBar
    FrmPrincipal.ProgressBarAtualizar;
  end;
end;

function TFrmCheckList.IncSincronizar: Integer;
  var
    PI_Sincronizar: Integer;
begin
  try
    FrmDataModule.ADOQueryColibri.Active:= false;
    FrmDataModule.ADOQueryColibri.Active:= true;
    PI_Sincronizar:= FrmDataModule.DataSourceColibri.DataSet.
    FieldByName('PI_Sincronizar').AsInteger+1;
    FrmDataModule.ADOQueryColibri.Edit;
    FrmDataModule.DataSourceColibri.DataSet.
    FieldByName('PI_Sincronizar').AsInteger:= PI_Sincronizar;
    FrmDataModule.ADOQueryColibri.Post;
    Result:= PI_Sincronizar;
    FrmDataModule.ADOQueryColibri.Active:= false;
    FrmDataModule.ADOQueryColibri.Active:= true;
  except
    Result:= 0;
  end;
end;

function TFrmCheckList.RecLocalSAP(Plataforma, TAG: String): TRECLocalSAP;
begin
  FrmDataModule.ADOQueryRECLocalSAP.Active := false;
  FrmDataModule.ADOQueryRECLocalSAP.Parameters.Items[0].Value:= '%'+Plataforma+'%';
  FrmDataModule.ADOQueryRECLocalSAP.Parameters.Items[1].Value:= '%'+TAG+'%';
  FrmDataModule.ADOQueryRECLocalSAP.Active := true;
  if not FrmDataModule.ADOQueryRECLocalSAP.IsEmpty then
  begin
    Result.LocalInstalacao:= FrmDataModule.DataSourceRECLocalSAP.
    DataSet.FieldByName('LocalInstalacao').AsString;
    Result.DenominacaoLocalInstalacao:= FrmDataModule.DataSourceRECLocalSAP.
    DataSet.FieldByName('DenominacaoLocalInstalacao').AsString;
  end
  else
  begin
    Result.LocalInstalacao:= 'Năo encontrado';
    Result.DenominacaoLocalInstalacao:= 'Năo encontrado';
  end;
end;

procedure TFrmCheckList.REGAtualizacaoPI;
begin
  try
