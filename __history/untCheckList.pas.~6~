procedure TFrmCheckList.actExcluirExecute(Sender: TObject);
begin
  if Application.MessageBox(PChar(
  'Deseja realmente excluir o registro selecionado?'),'.::ATENÇĂO::.',36) = 6 then
  begin
    FrmDataModule.ADOQueryPIRegistros.Delete;
  end;
end;

procedure TFrmCheckList.actFecharConexaoExecute(Sender: TObject);
begin
  try
    if (FrmPrincipal.logPerfil = 'Administrador')OR
    (FrmPrincipal.logPerfil = 'CIC-Mar')OR
    (FrmPrincipal.logPerfil = 'Supervisor') then
    begin
      FrmPrincipal.ProgressBarIncializa(6,'Fechando conexăo com o PI');
      Screen.Cursor := crDefault;
      //Fechar Excel
      ExcelPI.ActiveWorkbook.Save;
      FrmPrincipal.ProgressBarIncremento(1);
      ExcelPI.Application.DisplayAlerts := False;
      FrmPrincipal.ProgressBarIncremento(1);
      ExcelPI.Quit;
      FrmPrincipal.ProgressBarIncremento(1);
      ExcelPI := Unassigned;
      FrmPrincipal.ProgressBarIncremento(1);
      FreeAndNil(ExcelPI);
      FrmPrincipal.ProgressBarIncremento(1);
      ExcelPI := 0;
      FrmPrincipal.ProgressBarAtualizar;
    end;
  except
  end;
end;

procedure TFrmCheckList.actFiltroInserirExecute(Sender: TObject);
begin
  case PageControl1.TabIndex of
    0://Check-List
    begin
      FrmPrincipal.inserirProcura(DBGridCheckList,ColunasLayoutCheckList);
      actProcurarCheckList.Execute;
    end;
    1://Cadastro
    begin
      FrmPrincipal.inserirProcura(DBGridCadastroPI,ColunasLayoutCadastroPI);
      actProcurarCadastroPI.Execute;
    end;
    2://Limite Operacional
    begin
      FrmPrincipal.inserirProcura(DBGridLimiteOperacional,ColunasLayoutLimites);
      actProcurarLimiteOperacional.Execute;
    end;
    3://Registros
    begin
      FrmPrincipal.inserirProcura(DBGridRegistros,ColunasLayoutRegistros);
      actProcurarRegistros.Execute;
    end;
    4://Pendencias SAP
    begin
      FrmPrincipal.inserirProcura(DBGridPendenciaSAP,ColunasLayoutPendenciaSAP);
      actProcurarPendenciaSAP.Execute;
    end;
  end;
  if (FrmPrincipal.PanelFiltrosTabela.Visible)AND(FrmPrincipal.PanelAjuda1.Visible) then
    actFiltrosTabela.Execute;
end;

procedure TFrmCheckList.actFiltrosTabelaExecute(Sender: TObject);
