procedure TFrmCheckList.actCalcularPIExecute(Sender: TObject);
  var
    ToleranciaInferior,ToleranciaSuperior: Double;
    BooleanErro: Boolean;
    ListaErro: TStringList;
    TAGPI,ValorAtual,ValorMedio,LimiteInferior,LimiteSuperior,TipoVarPI: String;
    i: Integer;
begin
  ListaErro:= TStringList.Create;
  ListaErro.Clear;
  // Inicializar ProgressBar
  FrmDataModule.ADOQueryCheckList.Active:= false;
  FrmDataModule.ADOQueryCheckList.Active:= true;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryCheckList.RecordCount,
  'Calculando Limites Inferior/Superior...');
  // ============================================
  FrmDataModule.DataSourceCheckList.Enabled:= false;
  while not FrmDataModule.ADOQueryCheckList.Eof do
  begin
    try
      TipoVarPI:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('TipoVarPI').AsString;
      //Float32
      if TipoVarPI = 'Float32' then
      begin
        BooleanErro:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
        ('BooleanErro').AsBoolean;
        ValorMedio:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
        ('ValorMedio').AsString;
        ValorAtual:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
        ('ValorAtual').AsString;
        ToleranciaInferior:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
        ('ToleranciaInferior').AsFloat;
        ToleranciaSuperior:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
        ('ToleranciaSuperior').AsFloat;
        try
          LimiteInferior:= FormatFloat('0.0000',StrToFloat(ValorMedio)+(ToleranciaInferior));
          LimiteSuperior:= FormatFloat('0.0000',StrToFloat(ValorMedio)+(ToleranciaSuperior));
        except
          LimiteInferior:= '0,0000';
          LimiteSuperior:= '0,0000';
        end;
        //================================================
        FrmDataModule.ADOQueryCheckList.Edit;
        if (FrmDataModule.DataSourceCheckList.DataSet.FieldByName
        ('BooleanChekList').AsBoolean = true) then
        begin
          if (BooleanErro = true) then
          begin
            FrmDataModule.DataSourceCheckList.DataSet.FieldByName
            ('Ciente').AsString:= 'Pendente';
          end
          else if ((StrToFloat(ValorAtual)<StrToFloat(LimiteSuperior))
          AND(StrToFloat(ValorAtual)>StrToFloat(LimiteInferior))) then
          begin
            FrmDataModule.DataSourceCheckList.DataSet.FieldByName
            ('Ciente').AsString:= 'OK';
          end
          else
          begin
            FrmDataModule.DataSourceCheckList.DataSet.FieldByName
            ('Ciente').AsString:= 'Pendente';
          end;
        end;
      end
      else//Digital
      begin
        FrmDataModule.ADOQueryCheckList.Edit;
        if (FrmDataModule.DataSourceCheckList.DataSet.FieldByName
        ('BooleanChekList').AsBoolean = true) then
        begin
          LimiteInferior:= 'NA';
          LimiteSuperior:= 'NA';
          ValorAtual:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
          ('ValorAtual').AsString;
          if ((ValorAtual = '0')OR(ValorAtual = 'LIBERADO')OR
          (ValorAtual = 'OPERANDO')) then
          begin
            FrmDataModule.DataSourceCheckList.DataSet.FieldByName
            ('Ciente').AsString:= 'OK';
          end
          else
          begin
            FrmDataModule.DataSourceCheckList.DataSet.FieldByName
            ('Ciente').AsString:= 'Pendente';
          end;
        end;
      end;
      //================================================
      FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('LimiteInferior').AsString:= LimiteInferior;
      FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('LimiteSuperior').AsString:= LimiteSuperior;
      FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('AtualizadoPorPI').AsString:= FrmPrincipal.logChave;
      FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('DataAtualizacaoPI').AsDateTime:= now;
      FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('ComputadorAtualizacaoPI').AsString:= FrmPrincipal.logMaquina;
      FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('CheckPor').AsString:= '';
      FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('DataCheck').AsString:= '';
      FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('ComputadorCheck').AsString:= '';
      FrmDataModule.ADOQueryCheckList.Post;
      //=================================
    except
      FrmDataModule.ADOQueryCheckList.Cancel;
      ListaErro.Add(FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('TAGPI').AsString);
    end;
    // Incremento ProgressBar
    FrmPrincipal.ProgressBarIncremento(1);
    FrmDataModule.ADOQueryCheckList.Next;
  end;
  FrmPrincipal.ProgressBarAtualizar;
  if ListaErro.Count > 0 then
  begin
    TAGPI:= '';
    for i := 0 to ListaErro.Count -1 do
      TAGPI:= TAGPI+#13+ListaErro[i];

    ShowMessage('Lista de erros durante cálculo de tolerâncias Inferior/Superior:'+#13+TAGPI);
  end;
  FrmDataModule.DataSourceCheckList.Enabled:= true;
end;

