procedure TFrmCheckList.actGravarCheckExecute(Sender: TObject);
  var
    Plataforma,NomeVariavel,TAG,ValorMedio,ValorAtual,
    Unidade,LimiteInferior,LimiteSuperior,TipoVariavel: String;
begin
  actLimparFiltros.Execute;
  FrmPrincipal.buscaFiledGrid1('Ciente','Pendente',
  'Exato',ColunasLayoutCheckList,4,false);
  actProcurarCheckList.Execute;
  if FrmDataModule.ADOQueryCheckList.IsEmpty then
  begin
    actLimparFiltros.Execute;
    FrmPrincipal.buscaFiledGrid1('Ciente','Ciente',
    'Exato',ColunasLayoutCheckList,4,false);
    actProcurarCheckList.Execute;
    MemoCheck.Lines.Clear;
    FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryCheckList.RecordCount,
    'Gravar Check-List...');
    FrmDataModule.DataSourceCheckList.Enabled:= false;
    while not FrmDataModule.ADOQueryCheckList.Eof do
    begin
      Plataforma:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('Plataforma').AsString;
      NomeVariavel:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('NomeVariavel').AsString;
      TAG:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('TAG').AsString;
      ValorMedio:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('ValorMedio').AsString;
      TipoVariavel:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('TipoVariavel').AsString;
      Unidade:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('Unidade').AsString;
      LimiteInferior:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('LimiteInferior').AsString;
      LimiteSuperior:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('LimiteSuperior').AsString;
      ValorAtual:= FrmDataModule.DataSourceCheckList.DataSet.FieldByName
      ('ValorAtual').AsString;
      MemoCheck.Lines.Add(Plataforma+';'+NomeVariavel+';'+TAG+';'+ValorMedio+';'+
      TipoVariavel+';'+ValorAtual+';'+
      Unidade+';'+LimiteInferior+';'+LimiteSuperior+';'+TipoVariavel);
      FrmDataModule.ADOQueryCheckList.Next;
      FrmPrincipal.ProgressBarIncremento(1);
    end;
    FrmDataModule.DataSourceCheckList.Enabled:= true;
    FrmDataModule.ADOQueryPIRegistros.Active:= false;
    FrmDataModule.ADOQueryPIRegistros.Active:= true;
    FrmDataModule.ADOQueryPIRegistros.Insert;
    FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName
    ('Resultados').AsString:= MemoCheck.Text;
    //=================================================
    FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName
    ('AvaliadoPor').AsString:= FrmPrincipal.logChave;
    FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName
    ('DataRegistro').AsDateTime:= now;
    FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName
    ('Computador').AsString:= FrmPrincipal.logMaquina;
    //=================================================
    FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName
    ('PI_AtualizadoPor').AsString:= DBEditAtualizadoPor.Text;
    FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName
    ('PI_DataAtualizacao').AsString:= DBEditDataAtualizacao.Text;
    FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName
    ('PI_Computador').AsString:= DBEditComputador.Text;
    //=================================================
    FrmDataModule.ADOQueryPIRegistros.Post;
    FrmPrincipal.ProgressBarAtualizar;
  end
  else
  begin
    MessageBox(0, PChar('Necessário validar itens listados antes de gravar Check-List!'),
    'Gravar Check-List', MB_ICONINFORMATION);
  end;
end;

