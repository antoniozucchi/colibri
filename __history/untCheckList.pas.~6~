procedure TFrmCheckList.actImportarGeralPIExecute(Sender: TObject);
  var
    ExcelImportacao: Variant;
begin
  OpenDialog1.Filter := 'Microsoft Excel|*.xlsx|Microsoft Excel 97-2003|*.xls';
  OpenDialog1.DefaultExt:= '*.xlsx';
  if OpenDialog1.Execute then
  begin
    ExcelImportacao := CreateOleObject('Excel.Application');
    // Abrir o arquivo
    ExcelImportacao.Workbooks.Open(OpenDialog1.FileName);
    try
      //Importar planilha Geral PI
      ImportarGeralPI(ExcelImportacao);
      //Incrementar Sincronizar
      IncSincronizar;
      GravarSincronizar_PI;
    finally
      //Fechar Excel
      ExcelImportacao.Application.DisplayAlerts := False;
      ExcelImportacao.Quit;
      ExcelImportacao := Unassigned;
      FreeAndNil(ExcelImportacao);
      ExcelImportacao := 0;
    end;
  end;
end;

