procedure TFrmCheckList.actAtualizarLimiteVinculadoExecute(Sender: TObject);
  var
    CodigoLimiteOperacional,SelRegistro: Integer;
begin
  FrmDataModule.naoGravar:= true;
  SelRegistro:= FrmDataModule.ADOQueryCadastroPI.RecNo;
  FrmDataModule.DataSourceCadastroPI.Enabled:= false;
  FrmDataModule.ADOQueryCadastroPI.First;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryCadastroPI.RecordCount,
  'Atualizando texto do Limite Operacional vinculado...');
  while not FrmDataModule.ADOQueryCadastroPI.Eof do
  begin
    try
      CodigoLimiteOperacional:= FrmDataModule.DataSourceCadastroPI.
      DataSet.FieldByName('CodigoLimiteOperacional').AsInteger;
      //SELECIONAR
      FrmDataModule.ADOQueryConsultaLimiteOperacional_ID.Active := false;
      FrmDataModule.ADOQueryConsultaLimiteOperacional_ID.Parameters.Items[0].Value:=
      CodigoLimiteOperacional;
      FrmDataModule.ADOQueryConsultaLimiteOperacional_ID.Active := true;
      //CARREGAR O SISTEMA NA TABELA
      FrmDataModule.ADOQueryCadastroPI.Edit;
      FrmDataModule.DataSourceCadastroPI.DataSet.FieldByName('LimiteVinculado').AsString:=
      FrmDataModule.DataSourceConsultaLimiteOperacional_ID.DataSet.
      FieldByName('DescricaoLimite').AsString;
      FrmDataModule.ADOQueryCadastroPI.Post;
      FrmDataModule.ADOQueryCadastroPI.Next;
      FrmPrincipal.ProgressBarIncremento(1);
    except
      FrmDataModule.ADOQueryCadastroPI.Cancel;
    end;
  end;
  FrmPrincipal.ProgressBarAtualizar;
  FrmDataModule.DataSourceCadastroPI.Enabled:= true;
  FrmDataModule.ADOQueryCadastroPI.RecNo:= SelRegistro;
  FrmDataModule.naoGravar:= false;
end;

