procedure TFrmCheckList.actAbrirCheckListExecute(Sender: TObject);
  var
    ListaRegistro: TStringLIst;
    i,j,numLinhas: Integer;
    DataRegistro,AvaliadoPor,Computador,PI_AtualizadoPor,PI_DataAtualizacao,
    PI_Computador: String;
begin
  ListaRegistro:= TStringList.Create;
  ListaRegistro.delimiter:= ';';
  ListaRegistro.StrictDelimiter:=true;
  DataRegistro:= FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName('DataRegistro').AsString;
  AvaliadoPor:= FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName('AvaliadoPor').AsString;
  Computador:= FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName('Computador').AsString;
  PI_AtualizadoPor:= FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName('PI_AtualizadoPor').AsString;
  PI_DataAtualizacao:= FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName('PI_DataAtualizacao').AsString;
  PI_Computador:= FrmDataModule.DataSourcePIRegistros.DataSet.FieldByName('PI_Computador').AsString;
  //Preencher dados
  edtTitulo1.Text:= 'Check-List: '+
  AvaliadoPor+', '+DataRegistro+', '+Computador;
  edtTitulo2.Text:= 'Atualizaçăo do PI: '+
  PI_AtualizadoPor+', '+PI_DataAtualizacao+', '+PI_Computador;
  RLImpressao.FixedRows:= 0;
  RLImpressao.RowCount:= 1;
  RLImpressao.ColCount:= 9;
  RLImpressao.Cells[0,0]:= 'Plataf.';
  RLImpressao.Cells[1,0]:= 'Descriçăo Variavel';
  RLImpressao.Cells[2,0]:= 'TAG';
  RLImpressao.Cells[3,0]:= 'Valor Médio';
  RLImpressao.Cells[4,0]:= 'Tipo Variavel';
  RLImpressao.Cells[5,0]:= 'Unidade';
  RLImpressao.Cells[6,0]:= 'Limite Inferior';
  RLImpressao.Cells[7,0]:= 'Limite Superior';
  RLImpressao.Cells[8,0]:= 'Valor Atual';
  MemoCheck.Text:= FrmDataModule.DataSourcePIRegistros.DataSet.
  FieldByName('Resultados').AsString;
  FrmPrincipal.ProgressBarIncializa(MemoCheck.Lines.Count,
  'Carregando Check-List...');
  for i := 0 to MemoCheck.Lines.Count-1 do
  begin
    numLinhas:= RLImpressao.RowCount;
    RLImpressao.RowCount:= numLinhas+1;
    ListaRegistro.DelimitedText:= MemoCheck.Lines[i];
    //Preencher valores
    for j := 0 to RLImpressao.ColCount-1 do
    begin
      RLImpressao.Cells[j,numLinhas]:= ListaRegistro[j];
    end;
    //====================================
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  StatusBarImpressao.Panels[0].Text:= 'N° registros: '+
  intToStr(RLImpressao.RowCount-1);
  FrmPrincipal.AutoFitGrade(RLImpressao);
  FrmPrincipal.ProgressBarAtualizar;
  try
    RLImpressao.FixedRows:= 1;
  except
  end;
end;

