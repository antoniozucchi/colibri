procedure TFrmCheckList.actAtualizarPIExecute(Sender: TObject);
  var
    i: Integer;
    ListaErro: TStringList;
    Endereco,TAGPI,ValorMedio,ValorAtual,UnidadePI,DescricaoPI,TipoVarPI: String;
    BooleanErro: Boolean;
begin
  try
    ListaErro:= TStringList.Create;
    ListaErro.Clear;
    // Inicializar ProgressBar
    FrmDataModule.ADOQueryAtualizaCadastroPI.Active:= false;
    FrmDataModule.ADOQueryAtualizaCadastroPI.Active:= true;
    FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryAtualizaCadastroPI.RecordCount,
    'Atualizando dados do PI...');
    // ============================================
    i:= 2;
    while not FrmDataModule.ADOQueryAtualizaCadastroPI.Eof do
    begin
      FrmDataModule.ADOQueryAtualizaCadastroPI.Edit;
      TipoVarPI:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,5];
      if TipoVarPI = 'Float32' then
      begin
        try
          ValorMedio:= FormatFloat('0.0000',ExcelPI.Workbooks[1].Sheets[1].Cells[i,1]);
          ValorAtual:= FormatFloat('0.0000',ExcelPI.Workbooks[1].Sheets[1].Cells[i,2]);
          UnidadePI:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,3];
          DescricaoPI:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,4];
          BooleanErro:= false;
        except
          ValorMedio:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,1];
          ValorAtual:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,2];
          UnidadePI:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,3];
          DescricaoPI:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,4];
          ListaErro.Add(ExcelPI.Workbooks[1].Sheets[1].Cells[i,6]);
          BooleanErro:= true;
        end;
      end
      else
      begin
        ValorMedio:= 'Digital';
        try
          ValorAtual:= FormatFloat('0',ExcelPI.Workbooks[1].Sheets[1].Cells[i,2]);
          UnidadePI:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,3];
          DescricaoPI:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,4];
          BooleanErro:= false;
        except
          ValorAtual:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,2];
          UnidadePI:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,3];
          DescricaoPI:= ExcelPI.Workbooks[1].Sheets[1].Cells[i,4];
          ListaErro.Add(ExcelPI.Workbooks[1].Sheets[1].Cells[i,6]);
          BooleanErro:= true;
        end;
      end;
      FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.FieldByName
      ('ValorMedio').AsString:= ValorMedio;
      FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.FieldByName
      ('ValorAtual').AsString:= ValorAtual;
      FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.FieldByName
      ('UnidadePI').AsString:= UnidadePI;
      FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.FieldByName
      ('DescricaoPI').AsString:= DescricaoPI;
      FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.FieldByName
      ('TipoVarPI').AsString:= TipoVarPI;
      FrmDataModule.DataSourceAtualizaCadastroPI.DataSet.FieldByName
      ('BooleanErro').AsBoolean:= BooleanErro;
      FrmDataModule.ADOQueryAtualizaCadastroPI.Post;
      // Incremento ProgressBar
      FrmPrincipal.ProgressBarIncremento(1);
      i:= i+1;
      FrmDataModule.ADOQueryAtualizaCadastroPI.Next;
    end;
    // Atualizar ProgressBar
    FrmPrincipal.ProgressBarAtualizar;
    if ListaErro.Count > 0 then
    begin
      TAGPI:= '';
      for I := 0 to ListaErro.Count -1 do
        TAGPI:= TAGPI+#13+ListaErro[i];

      ShowMessage('Lista de erros durante atualizaçăo com planilha de conexăo com o PI:'+#13+TAGPI);
    end;
    //VERIFICAÇĂO E PREENCHIMENTO DE CÁLCULO
    REGAtualizacaoPI;
    actCalcularPI.Execute;
    actAualizaPlanilhas.Execute;
  except
    Endereco:= ExtractFilePath(Application.ExeName)+'Arquivos\ConexaoPI.xlsx';
    MessageBox(0, PChar('Erro de conexăo com o Excel [PI]' + #13 + #10 +
    'Possibilidades:' + #13 + #10 +
    '1. Verifique vocę tem acesso ao PI via Excel.'+ #13 + #10 +
    '2. Verifique se existe o arquivo no endereço: '+Endereco+ #13 + #10 +
    '3. Verifique se o Microsoft Office Excel esta instalado na sua máquina.'),
    'Conexăo com o PI', MB_ICONERROR);
    // Atualizar ProgressBar
    FrmPrincipal.ProgressBarAtualizar;
  end;
end;

