procedure TFrmPreview.PrintPreviewNewPage(Sender: TObject);
  var
    MaxSize: TSize;
    rectLogoTipo: TRect;
    posX,posY,SizeTexto,NumLinhas: Integer;
    Texto: String;
begin
  with PrintPreview do
  begin
    linhaSolida(3,clBlack);
    // We are going to draw a rectangle on the page to distinguish the page's
    // margin. The margin is already calculated in the GeneratePages function.
    with PageBoundsAfterMargin do
    begin
      Pagina := PageBoundsAfterMargin;
      //LINHAS DE DIVISĂO DO RELATÓRIO
      SetRect(Cabecalho,Pagina.Left,Pagina.Top,Pagina.Right,Pagina.Top+YFrom(mmLoMetric, 200));
      //LOGOTIPO NO CABEÇALHO
      SetRect(rectLogoTipo,Pagina.Left+ XFrom(mmLoMetric, 20),Pagina.Top,
      Pagina.Left + XFrom(mmLoMetric, 250),Pagina.Top +YFrom(mmLoMetric, 200));
      //Retangulo do cabeçalho
      Canvas.Rectangle(
      Cabecalho.Left,
      Cabecalho.Top,
      Cabecalho.Right,
      Cabecalho.Bottom);
      Canvas.MoveTo(rectLogoTipo.Right+ XFrom(mmLoMetric, 20),Cabecalho.Top);
      Canvas.LineTo(rectLogoTipo.Right+ XFrom(mmLoMetric, 20),Pagina.Top+YFrom(mmLoMetric, 195));
      //LogoTipo do cabeçalho
      PaintGraphicEx(rectLogoTipo, ImageLogo.Picture.Graphic, True, True, True);
      //=====================CABEÇALHO========================
      NumLinhas:= ListaTituloRelatorio1.Count;
      case NumLinhas of
        1:
        begin
          fontTitulo2(TRUNC(edtFontTitulo1.Value));
          Texto:= ListaTituloRelatorio1[0];
          SizeTexto:= PrintPreview.Canvas.TextWidth(Texto);
          posX:= ROUND(((Pagina.Right-
          (rectLogoTipo.Right+ XFrom(mmLoMetric, 20))-SizeTexto)/2)+
          (rectLogoTipo.Right+ XFrom(mmLoMetric, 20)));
          posY:= Cabecalho.Top + YFrom(mmLoMetric, 90);
          Canvas.TextOut(posX,posY,Texto);
          edtFontTitulo1.Visible:= true;
          edtFontTitulo2.Visible:= false;
          edtFontTitulo3.Visible:= false;
        end;
        2:
        begin
          fontTitulo2(TRUNC(edtFontTitulo1.Value));
          Texto:= ListaTituloRelatorio1[0];
          SizeTexto:= PrintPreview.Canvas.TextWidth(Texto);
          posX:= ROUND(((Pagina.Right-
          (rectLogoTipo.Right+ XFrom(mmLoMetric, 20))-SizeTexto)/2)+
          (rectLogoTipo.Right+ XFrom(mmLoMetric, 20)));
          posY:= Cabecalho.Top + YFrom(mmLoMetric, 40);
          Canvas.TextOut(posX,posY,Texto);
