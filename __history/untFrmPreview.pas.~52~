procedure TFrmPreview.tabelaStrGrid(Grid: TStringGrid; XTabela, YTabela, fonte,
  alturaLinha, alinhamento: Integer);
  var
    i,j,XTitulo,YCel,LarguraColuna: Integer;
    contLinha: Integer;
    CelColor: TColor;
begin
  XTitulo:= XTabela;
  with FrmPreview.PrintPreview do
  begin
    Canvas.Font.Size:= fonte;
    for j := 0 to Grid.ColCount-1 do
    begin
      LarguraColuna:= XFrom(mmLoEnglish,Grid.ColWidths[j]+25);
      //Preencher o titulo da tabela
      celula(XTitulo,YTabela,LarguraColuna,
      alturaLinha,fonte,0,String(Grid.Cells[j,0]),clSilver);
      //Preencher as linhas da tabela
      contLinha:=1;
      for i := 1 to Grid.RowCount-1 do
      begin
        Grid.Row:= i;
        CelColor:= clWhite;
        YCel:= YTabela+(contLinha*alturaLinha);
        celula(XTitulo,YCel,LarguraColuna,alturaLinha,fonte,alinhamento,
        String(Grid.Cells[j,i]),CelColor);
        contLinha:= contLinha+1;
      end;
      XTitulo:= XTitulo+LarguraColuna;
    end;
  end;
end;

procedure TFrmPreview.tabelaStringGrid(Grid: TStringGrid; XTabela, YTabela,
  fonte, alturaLinha, alinhamento: Integer);
  var
    i,j,XTitulo,YCel,LarguraColuna: Integer;
    comecarLinha1,comecarLinha2,contLinha: Integer;
    CelColor: TColor;
    passouPagina: Boolean;
begin
  XTitulo:= XTabela;
  passouPagina:= false;
  comecarLinha1:= 1;
  with FrmPreview.PrintPreview do
  begin
    Canvas.Font.Size:= fonte;
    for j := 0 to Grid.ColCount-1 do
    begin
      if j <> Grid.ColCount-1 then
        LarguraColuna:= XFrom(mmLoEnglish,Grid.ColWidths[j]+25)
      else
        LarguraColuna:= Cabecalho.Right-XTitulo;
      //Preencher o titulo da tabela
      celula(XTitulo,YTabela,LarguraColuna,
      alturaLinha,fonte,0,String(Grid.Cells[j,0]),clSilver);
      //Preencher as linhas da tabela
      contLinha:=1;
      for i := 1 to Grid.RowCount-1 do
      begin
        Grid.Row:= i;
        CelColor:= clWhite;
        YCel:= YTabela+(contLinha*alturaLinha);
        if YCel < Pagina.Bottom then
          celula(XTitulo,YCel,LarguraColuna,alturaLinha,fonte,alinhamento,
          String(Grid.Cells[j,i]),CelColor)
        else
        begin
          passouPagina:= true;
          comecarLinha1:= i;
          break;
        end;
        contLinha:= contLinha+1;
      end;
      XTitulo:= XTitulo+LarguraColuna;
    end;
    //=========================================================================
    comecarLinha2:= comecarLinha1;
    while passouPagina = true do
    begin
      NewPage;
      XTitulo:= XTabela;
      YTabela:= Cabecalho.Bottom + YFrom(mmLoMetric,30);
      passouPagina:= false;
      comecarLinha1:= comecarLinha2;
      Canvas.Font.Size:= fonte;
      for j := 0 to Grid.ColCount-1 do
      begin
        if j <> Grid.ColCount-1 then
          LarguraColuna:= XFrom(mmLoEnglish,Grid.ColWidths[j]+25)
        else
          LarguraColuna:= Cabecalho.Right-XTitulo;
        //Preencher o titulo da tabela
        celula(XTitulo,YTabela,LarguraColuna,alturaLinha,fonte,0,
        (Grid.Cells[j,0]),clSilver);
        //Preencher as linhas da tabela
        contLinha:= 1;
        for i := comecarLinha1 to Grid.RowCount-1 do
        begin
          Grid.Row:= i;
          CelColor:= clWhite;
          YCel:= YTabela+(contLinha*alturaLinha);
          if YCel < Pagina.Bottom then
            celula(XTitulo,YCel,LarguraColuna,alturaLinha,fonte,alinhamento,
            (Grid.Cells[j,i]),CelColor)
          else
          begin
            passouPagina:= true;
            comecarLinha2:= i;
            break;
          end;
          contLinha:= contLinha+1;
        end;
        XTitulo:= XTitulo+LarguraColuna;
      end;
    end;
  end;
end;

