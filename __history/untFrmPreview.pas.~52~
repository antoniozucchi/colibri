procedure TFrmPreview.celula(XCelula,YCelula,largura,altura,fonte,alinhamento: Integer;
  Texto: String; CelulaColor: TColor);
  var
  TextoSizeX,TextoSizeY,XFont,YFont: Integer;
begin
  with PrintPreview do
  begin
    linhaSolida(1,clBlack);
    fontNormal(fonte);
    Canvas.Brush.Color:= CelulaColor;
    Canvas.Brush.Style:= bsSolid;
    Canvas.Rectangle(XCelula,YCelula,XCelula+largura,YCelula+altura);
    TextoSizeX:=Canvas.TextWidth(Texto);
    TextoSizeY:=Canvas.TextHeight(Texto);
    {for i := 0 to fonte - 1 do
    begin
      if  (TextoSizeX + XFrom(mmLoMetric, 10)) >= largura then
      begin
        menorFonte:= fonte-i;
        Canvas.Font.Size:= menorFonte;
        TextoSizeX:=Canvas.TextWidth(Texto);
        TextoSizeY:=Canvas.TextHeight(Texto);
      end;
      if  (TextoSizeY + XFrom(mmLoMetric, 8)) >= altura then
      begin
        menorFonte:= fonte-i;
        Canvas.Font.Size:= menorFonte;
        TextoSizeX:=Canvas.TextWidth(Texto);
        TextoSizeY:=Canvas.TextHeight(Texto);
      end;
    end;}
    XFont:= TRUNC(XCelula+(largura-TextoSizeX)/2);
    YFont:= TRUNC(YCelula+(altura-TextoSizeY)/2);
    case alinhamento of
      0://Centralizado
      begin
        XFont:= TRUNC(XCelula+(largura-TextoSizeX)/2);
        YFont:= TRUNC(YCelula+(altura-TextoSizeY)/2);
      end;
      1://Esquerda
      begin
        XFont:= XCelula+ XFrom(mmLoMetric, 8);
        YFont:= YCelula+ YFrom(mmLoMetric, 8);
      end;
    end;
    Canvas.TextOut(XFont,YFont,Texto);
  end;
end;

