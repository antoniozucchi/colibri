procedure TFrmPreview.GeneratePages;
begin
  with PrintPreview do
  begin
    {if Abertura then
    begin
      PageBoundsAfterMargin := PageBounds;
      with PointFrom(mmLoMetric, 100, 100) do
        InflateRect(PageBoundsAfterMargin, -X, -Y);

      //Abertura:= true;
    end
    else
    begin
      //{$IFDEF COMPILER7_UP}
       // PageBoundsAfterMargin := GetPageSetupParameters(PageSetupDialog);
      //{$ELSE}
       // PageBoundsAfterMargin := PageBounds;
       // with PointFrom(mmLoMetric, 100, 100) do
       //   InflateRect(PageBoundsAfterMargin, -X, -Y);
      //{$ENDIF}
    //end;}
    PageBoundsAfterMargin := PageBounds;
    with PointFrom(mmLoMetric, 100, 100) do
      InflateRect(PageBoundsAfterMargin, -X, -Y);
    //======================================================================
    BeginDoc(btnExcluirAntes.Down);
    try
    begin
      case RadioGroupRelatorio.ItemIndex of
        0: actPrintMapaRotas.Execute;
        1: actPrintPageRelatorio.Execute;
        2: actPrintConsultaExecutante.Execute;
        3: actPrintMapaPlataforma.Execute;
        5: actProgramacaoEmbarcacao.Execute;
        6: actPainelEquipamentos.Execute;
        7: actPrintExtrato.Execute;
        8: actPrintSIGM.Execute;
      end;
    end;
    finally
      EndDoc;
    end;
  end;
end;

procedure TFrmPreview.graficoTChart(grafico: TChart; graficoHeight,
  graficoWidth, posYgrafico: Integer);
  var
    graficoRect: TRect;
    graficoImage: TMetaFile;
begin
  with PrintPreview do
  begin
    try
      //GRÁFICO PROVA DE CARGA
      SetRect(graficoRect,
      Cabecalho.Left,
      posYgrafico,
      Cabecalho.Right,
      YFrom(mmLoMetric, 1600)+posYgrafico);
      //CARREGAR IMAGEM
      graficoImage := grafico.TeeCreateMetafile
      (False, Rect(0, 0,
      graficoWidth,
      graficoHeight));
      //IMPRIMIR IMAGEM
      PaintGraphicEx(graficoRect, graficoImage, true, true, true);
    except
      MessageBox(0, 'Năo foi possivel imprimir o gráfico!',
      'Impressăo de relatórios', MB_ICONERROR);
    end;
  end;
end;

procedure TFrmPreview.graticoTRChartCentral(grafico: TRChart; graficoHeight,
  posYgrafico: Integer);
  var
    graficoRect: TRect;
    graficoImage: TMetaFile;
    GRFWindColor: TColor;
begin
  with PrintPreview do
  begin
    try
      GRFWindColor:= grafico.WindColor;
      grafico.WindColor:= clWhite;
      //GRÁFICO PROVA DE CARGA
      SetRect(graficoRect,
      Cabecalho.Left,
      posYgrafico,
      Cabecalho.Right,
      graficoHeight+ posYgrafico);
      //CARREGAR IMAGEM
      grafico.CopyToClipboardWMF(false);
      graficoImage:= TMetafile.Create;
      graficoImage.Assign(ClipBoard);
      //IMPRIMIR IMAGEM
      PaintGraphicEx(graficoRect, graficoImage, true, true, true);
      //
      grafico.WindColor:= GRFWindColor;
    except
      MessageBox(0, 'Năo foi possivel imprimir o gráfico!',
      'Impressăo de relatórios', MB_ICONERROR);
    end;
  end;
end;

