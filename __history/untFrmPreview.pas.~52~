procedure TFrmPreview.actPrintPageRelatorioExecute(Sender: TObject);
  var
    contLinhas,alturaLinha,i,largura,altura: Integer;
    TextoSizeX,TextoSizeY,XFont,YFont,XCelula,YCelula: Integer;
    Texto: String;
begin
  with PrintPreview do
  begin
    //RLimpressao
    alturaLinha:= YFrom(mmLoMetric,TRUNC(FrmGerenciarEmbarcacoes.SpinEditFonte.Value*6.25));
    tabelaStringGrid(FrmGerenciarEmbarcacoes.RLImpressao,
    Pagina.Left-YFrom(mmLoMetric,20),
    Cabecalho.Bottom+YFrom(mmLoMetric,30),
    FrmGerenciarEmbarcacoes.SpinEditFonte.Value,alturaLinha,1);
    //===================================================================
    if FrmGerenciarEmbarcacoes.RadioGroupImpressao.ItemIndex = 0 then
    begin
      fontTitulo2(10);
      linhaSolida(1,clBlack);
      Canvas.Brush.Color:= clWhite;
      Canvas.Brush.Style:= bsSolid;
      Canvas.Font.Color:= clRed;
      Texto:= 'HORÁRIO';
      largura:= XFrom(mmLoMetric,200);
      altura:= Cabecalho.Bottom-Cabecalho.Top;
      XCelula:= Cabecalho.Right-largura;
      YCelula:= Cabecalho.Top;
      Canvas.MoveTo(XCelula,YCelula);
      Canvas.LineTo(XCelula,YCelula+altura);
      TextoSizeX:=Canvas.TextWidth(Texto);
      TextoSizeY:=Canvas.TextHeight(Texto);
      XFont:= TRUNC(XCelula+(largura-TextoSizeX)/2);
      YFont:= TRUNC(YCelula+TextoSizeY);
      Canvas.TextOut(XFont,YFont,Texto);
    end;
    //===================================================================
    //Observaçőes
    contLinhas:= FrmGerenciarEmbarcacoes.Memo1.Lines.Count;
    if contLinhas > 0 then
    begin
      fontTitulo2(10);
      Canvas.TextOut(Pagina.Left,Pagina.Bottom-((contLinhas+1)*alturaLinha),'Notas:');
      fontNormal(FrmGerenciarEmbarcacoes.SpinEditFonte.Value);
      for i := 0 to contLinhas - 1 do
      begin
        Canvas.TextOut(Pagina.Left,Pagina.Bottom-(contLinhas*alturaLinha),
        FrmGerenciarEmbarcacoes.Memo1.Lines[i]);
        contLinhas:= contLinhas-1;
      end;
    end;
  end;
end;

