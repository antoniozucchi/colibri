procedure TFrmIndicadoresManutencao.actFiltroInserirExecute(Sender: TObject);
begin
  case TabIndexPageControl of
    0:
    begin
      FrmPrincipal.inserirProcura(DBGridResumoIndicador,ColunasLayoutResumo);
      actProcurarResumo.Execute;
    end;
    1:
    begin
      FrmPrincipal.inserirProcura(DBGridICPM,ColunasLayoutICPM);
      actProcurarICPM.Execute;
    end;
    3:
    begin
      FrmPrincipal.inserirProcura(DBGridICPI,ColunasLayoutICPI);
      actProcurarICPI.Execute;
    end;
  end;
  if (FrmPrincipal.PanelFiltrosTabela.Visible)AND(FrmPrincipal.PanelAjuda1.Visible) then
    actFiltrosTabela.Execute;
end;

procedure TFrmIndicadoresManutencao.actFiltrosICPMExecute(Sender: TObject);
  var
    PalavraLista,PalavraBusca: String;
    i: Integer;
begin
  //Sistemas
  FrmPrincipal.configurarCheckListBox(CheckListBoxSistemaFiltroICPM,DBGridICPM,ColunasLayoutICPM,true);
  //Plataformas
  PalavraBusca:= '';
  for I := 0 to CheckListBoxPlataformaICPM.Count-1 do
  begin
    if CheckListBoxPlataformaICPM.Checked[i] then
    begin
      PalavraLista:= CheckListBoxPlataformaICPM.Items[i];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('Plataforma',PalavraBusca,'Contem',ColunasLayoutICPM,4,false);
  //Tipo Etapa Serviço
  PalavraBusca:= '';
  for I := 0 to CheckListBoxTipoEtapaServicoICPM.Count-1 do
  begin
    if CheckListBoxTipoEtapaServicoICPM.Checked[i] then
    begin
      PalavraLista:= CheckListBoxTipoEtapaServicoICPM.Items[i];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('txtTipoEtapaServico',PalavraBusca,'Contem',ColunasLayoutICPM,4,false);
  actProcurarICPM.Execute;
end;

procedure TFrmIndicadoresManutencao.actFiltrosTabelaExecute(Sender: TObject);
begin
  FrmPrincipal.btnProcurarFiltrosTabela.Action:= actProcuraFiltrosTabela;
  case TabIndexPageControl of
    0: FrmPrincipal.FiltrosTabela(DBGridResumoIndicador,ColunasLayoutResumo);
    1: FrmPrincipal.FiltrosTabela(DBGridICPM,ColunasLayoutICPM);
    3: FrmPrincipal.FiltrosTabela(DBGridICPI,ColunasLayoutICPI);
  end;
end;

procedure TFrmIndicadoresManutencao.actGravarResumoExecute(Sender: TObject);
  var
    PrimeiroDiaMes: TDateTime;
    Descricao: String;
begin
  PrimeiroDiaMes := RecodeDay(Date, 1);
  Descricao:= 'S'+IntToStr(WeekOf(now))+'-'+FrmPrincipal.PrimeiraLetraMaiscula(FormatDateTime('mmmm yyyy', PrimeiroDiaMes));

  FrmDataModule.ADOQueryResumoIndicador.Insert;
  FrmDataModule.ADOQueryResumoIndicador.FieldByName('DataIndicador').AsString:= FrmPrincipal.corrigirData(now);
  try
    FrmDataModule.ADOQueryResumoIndicador.FieldByName('ICPM').AsFloat:= StrToFloat(RLResumo.Cells[3,1]);
  except
    FrmDataModule.ADOQueryResumoIndicador.FieldByName('ICPM').AsFloat:= 0;
  end;
  try
    FrmDataModule.ADOQueryResumoIndicador.FieldByName('ICPMSO').AsFloat:= StrToFloat(RLResumo.Cells[3,2]);
  except
    FrmDataModule.ADOQueryResumoIndicador.FieldByName('ICPMSO').AsFloat:= 0;
  end;
  try
    FrmDataModule.ADOQueryResumoIndicador.FieldByName('ICPI').AsFloat:= StrToFloat(RLResumo.Cells[3,3]);
  except
    FrmDataModule.ADOQueryResumoIndicador.FieldByName('ICPI').AsFloat:= 0;
  end;
  try
  FrmDataModule.ADOQueryResumoIndicador.FieldByName('IMRI').AsFloat:= StrToFloat(RLResumo.Cells[3,4]);
  except
    FrmDataModule.ADOQueryResumoIndicador.FieldByName('IMRI').AsFloat:= 0;
  end;
  try
    FrmDataModule.ADOQueryResumoIndicador.FieldByName('IMRI_B').AsFloat:= StrToFloat(RLResumo.Cells[3,5]);
  except
    FrmDataModule.ADOQueryResumoIndicador.FieldByName('IMRI_B').AsFloat:= 0;
  end;
  FrmDataModule.ADOQueryResumoIndicador.FieldByName('Descricao').AsString:= Descricao;
  FrmDataModule.ADOQueryResumoIndicador.Post;
end;

procedure TFrmIndicadoresManutencao.actGRFImprimirExecute(Sender: TObject);
begin
  if not Assigned(FrmPreview) then
    FrmPreview:=TFrmPreview.Create(Application)
  else
    FrmPreview.Show;

  FrmPreview.ListaTituloRelatorio:= TStringList.Create;
  FrmPreview.ListaTituloRelatorio.Add(ChartGrafico.Title.Caption);
  FrmPreview.PrintPreview.PrintJobTitle:= ChartGrafico.Title.Caption;
  FrmPreview.paginaTChart(ChartGrafico,FrmPreview.btnExcluirAntes.Down);
  ChartGrafico.Legend.CheckBoxes:= false;
end;

