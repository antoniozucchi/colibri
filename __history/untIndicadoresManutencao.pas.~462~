procedure TFrmIndicadoresManutencao.actGraficoExecute(Sender: TObject);
  var
    SerieLinha: TLineSeries;
begin
  ChartGrafico.RemoveAllSeries;
  case RadioGroupGrafico.ItemIndex of
    0:
    begin
      SerieLinha:= linhaGrafico('ICPM',95,clBlue);
      ChartGrafico.Title.Caption:= 'ICPM';
      ChartGrafico.Axes.Left.Title.Caption:= 'ICPM';
      ChartGrafico.AddSeries(SerieLinha);
    end;
    1:
    begin
      SerieLinha:= linhaGrafico('ICPMSO',97,clFuchsia);
      ChartGrafico.Title.Caption:= 'ICPM-SO';
      ChartGrafico.Axes.Left.Title.Caption:= 'ICPM-SO';
      ChartGrafico.AddSeries(SerieLinha);
    end;
    2:
    begin
      SerieLinha:= linhaGrafico('ICPI',99.5,clOlive);
      ChartGrafico.Title.Caption:= 'ICPI';
      ChartGrafico.Axes.Left.Title.Caption:= 'ICPI';
      ChartGrafico.AddSeries(SerieLinha);
    end;
    3:
    begin
      SerieLinha:= linhaGrafico('IMRI',95,clAqua);
      ChartGrafico.Title.Caption:= 'IMRI';
      ChartGrafico.Axes.Left.Title.Caption:= 'IMRI';
      ChartGrafico.AddSeries(SerieLinha);
    end;
    4:
    begin
      SerieLinha:= linhaGrafico('IMRI_B',95,clTeal);
      ChartGrafico.Title.Caption:= 'IMRI-B';
      ChartGrafico.Axes.Left.Title.Caption:= 'IMRI-B';
      ChartGrafico.AddSeries(SerieLinha);
    end;
    5:
    begin
      ChartGrafico.AddSeries(linhaGrafico('ICPM',95,clBlue));
      ChartGrafico.AddSeries(linhaGrafico('ICPMSO',97,clFuchsia));
      ChartGrafico.AddSeries(linhaGrafico('ICPI',99.5,clOlive) );
      ChartGrafico.AddSeries(linhaGrafico('IMRI',95,clAqua));
      ChartGrafico.AddSeries(linhaGrafico('IMRI_B',95,clTeal));
      ChartGrafico.Title.Caption:= 'Indicadores';
      ChartGrafico.Axes.Left.Title.Caption:= 'Indicadores';
    end;
  end;

end;

procedure TFrmIndicadoresManutencao.actICPMLimparExecute(Sender: TObject);
  var
    selRegistro: Integer;
begin
  selRegistro:= FrmDataModule.ADOQueryICPM.RecNo;
  FrmDataModule.DataSourceICPM.Enabled:= false;
  FrmDataModule.ADOQueryICPM.First;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryICPM.RecordCount,'Risco de atendimento');
  while not FrmDataModule.ADOQueryICPM.Eof do
  begin
    FrmDataModule.ADOQueryICPM.Edit;
    FrmDataModule.DataSourceICPM.DataSet.
    FieldByName('RiscoAtendimento').AsBoolean:= false;
    FrmDataModule.ADOQueryICPM.Post;

    //=============================================
    FrmDataModule.ADOQueryICPM.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmDataModule.ADOQueryICPM.Active:= false;
  FrmDataModule.ADOQueryICPM.Active:= true;
  FrmDataModule.ADOQueryICPM.RecNo:= selRegistro;
  FrmDataModule.DataSourceICPM.Enabled:= true;
  FrmPrincipal.ProgressBarAtualizar;
end;

procedure TFrmIndicadoresManutencao.actICPMSelExecute(Sender: TObject);
  var
    selRegistro: Integer;
begin
  selRegistro:= FrmDataModule.ADOQueryICPM.RecNo;
  FrmDataModule.DataSourceICPM.Enabled:= false;
  FrmDataModule.ADOQueryICPM.First;
  FrmPrincipal.ProgressBarIncializa(FrmDataModule.ADOQueryICPM.RecordCount,'Risco de atendimento');
  while not FrmDataModule.ADOQueryICPM.Eof do
  begin
    FrmDataModule.ADOQueryICPM.Edit;
    FrmDataModule.DataSourceICPM.DataSet.
    FieldByName('RiscoAtendimento').AsBoolean:= true;
    FrmDataModule.ADOQueryICPM.Post;

    //=============================================
    FrmDataModule.ADOQueryICPM.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmDataModule.ADOQueryICPM.Active:= false;
  FrmDataModule.ADOQueryICPM.Active:= true;
