procedure TFrmIndicadoresManutencao.actMedidasPHExecute(Sender: TObject);
  var
    SQLBase: String;
    ListaCentroTrabalhoResp: TStringList;
    i,Linha,Qtd,TotalPH,A,B,C,D,BCVT: Integer;
begin
  RLPH.RowCount:= 1;
  RLPH.ColCount:= 7;
  RLPH.Cells[0,0]:= 'Centro Trabalho Resp.';
  RLPH.Cells[1,0]:= '∑';
  RLPH.Cells[2,0]:= 'A';
  RLPH.Cells[3,0]:= 'B-CVT';
  RLPH.Cells[4,0]:= 'B';
  RLPH.Cells[5,0]:= 'C';
  RLPH.Cells[6,0]:= 'D';
  //Tipo Etapa Serviço
  SQLBase:= 'SELECT tblRTI.* FROM tblRTI '+
  'WHERE ((StatusUsuarioMedida LIKE "PH"));';
  FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
  FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
  TotalPH:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
  ListaCentroTrabalhoResp:= TStringList.Create;
  ListaCentroTrabalhoResp.Clear;
  while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
  begin
    ListaCentroTrabalhoResp.Add(FrmDataModule.ADOQueryTemporarioDBMemoria.
    FieldByName('CentroTrabalhoResp').AsString);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
  end;
  FrmPrincipal.deleteRepetidosList(ListaCentroTrabalhoResp);
  for I := 0 to ListaCentroTrabalhoResp.Count-1 do
  begin
    Linha:= RLPH.RowCount;
    RLPH.RowCount:= RLPH.RowCount+1;
    SQLBase:= 'SELECT tblRTI.* FROM tblRTI '+
    'WHERE ((StatusUsuarioMedida LIKE "PH")AND(CentroTrabalhoResp LIKE '+QuotedStr(ListaCentroTrabalhoResp[i])+'));';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    Qtd:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
    //
    SQLBase:= 'SELECT tblRTI.* FROM tblRTI '+
    'WHERE ((StatusUsuarioMedida LIKE "PH")AND(CodigoMedidaABCD LIKE "A")AND(CentroTrabalhoResp LIKE '+QuotedStr(ListaCentroTrabalhoResp[i])+'));';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    A:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
    //
    SQLBase:= 'SELECT tblRTI.* FROM tblRTI '+
    'WHERE ((StatusUsuarioMedida LIKE "PH")AND(CodigoMedidaABCD LIKE "B")AND(CentroTrabalhoResp LIKE '+QuotedStr(ListaCentroTrabalhoResp[i])+'));';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    B:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
    //
    SQLBase:= 'SELECT tblRTI.* FROM tblRTI '+
    'WHERE ((StatusUsuarioMedida LIKE "PH")AND(BCVT = True)AND(CentroTrabalhoResp LIKE '+QuotedStr(ListaCentroTrabalhoResp[i])+'));';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    BCVT:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
    //
    SQLBase:= 'SELECT tblRTI.* FROM tblRTI '+
    'WHERE ((StatusUsuarioMedida LIKE "PH")AND(CodigoMedidaABCD LIKE "C")AND(CentroTrabalhoResp LIKE '+QuotedStr(ListaCentroTrabalhoResp[i])+'));';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    C:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
    //
    SQLBase:= 'SELECT tblRTI.* FROM tblRTI '+
    'WHERE ((StatusUsuarioMedida LIKE "PH")AND(CodigoMedidaABCD LIKE "D")AND(CentroTrabalhoResp LIKE '+QuotedStr(ListaCentroTrabalhoResp[i])+'));';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    D:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
    //=================================================
    RLPH.Cells[0,Linha]:= ListaCentroTrabalhoResp[i];
    RLPH.Cells[1,Linha]:= IntToStr(Qtd);
    RLPH.Cells[2,Linha]:= IntToStr(A);
    RLPH.Cells[3,Linha]:= IntToStr(BCVT);
    RLPH.Cells[4,Linha]:= IntToStr(B);
    RLPH.Cells[5,Linha]:= IntToStr(C);
    RLPH.Cells[6,Linha]:= IntToStr(D);
  end;
  Linha:= RLPH.RowCount;
  RLPH.RowCount:= RLPH.RowCount+1;
  RLPH.Cells[0,Linha]:= 'Total ∑';
  RLPH.Cells[1,Linha]:= IntToStr(TotalPH);

  A:=0;
  B:=0;
  C:=0;
  D:=0;
  BCVT:=0;
  for i := 1 to RLPH.RowCount-2 do
  begin
    A:= A+ StrToInt(RLPH.Cells[2,i]);
    BCVT:= BCVT+ StrToInt(RLPH.Cells[3,i]);
    B:= B+ StrToInt(RLPH.Cells[4,i]);
    C:= C+ StrToInt(RLPH.Cells[5,i]);
    D:= D+ StrToInt(RLPH.Cells[6,i]);
  end;
  RLPH.Cells[2,RLPH.RowCount-1]:= IntToStr(A);
  RLPH.Cells[3,RLPH.RowCount-1]:= IntToStr(BCVT);
  RLPH.Cells[4,RLPH.RowCount-1]:= IntToStr(B);
  RLPH.Cells[5,RLPH.RowCount-1]:= IntToStr(C);
  RLPH.Cells[6,RLPH.RowCount-1]:= IntToStr(D);
  FrmPrincipal.AutoFitGrade(RLPH);
end;

