function TFrmIndicadoresManutencao.linhaGrafico(Field: String;Meta: Double; Color: TColor): TLineSeries;
var
  SerieMeta: TLineSeries;
  DataIndicador: TDateTime;
  ICPM: Double;
begin
  ChartGrafico.Axes.Bottom.Title.Caption:= 'Tempo';
  ChartGrafico.BottomAxis.Visible:= true;
  Result:= TLineSeries.Create(ChartGrafico);
  SerieMeta:= TLineSeries.Create(ChartGrafico);
  Result.XValues.DateTime:= true;
  SerieMeta.XValues.DateTime:= true;
  Result.Pointer.Visible:= true;
  FrmDataModule.ADOQueryResumoIndicador.Active:= false;
  FrmDataModule.ADOQueryResumoIndicador.Active:= true;
  FrmDataModule.ADOQueryResumoIndicador.First;
  FrmDataModule.DataSourceResumoIndicador.Enabled:= false;
  //=============================================================
  while not FrmDataModule.ADOQueryResumoIndicador.Eof do
  begin
    DataIndicador:= FrmDataModule.ADOQueryResumoIndicador.FieldByName('DataIndicador').AsDateTime;
    ICPM:= FrmDataModule.ADOQueryResumoIndicador.FieldByName(Field).AsFloat;
    Result.AddXY(DataIndicador,ICPM,DateToStr(DataIndicador),Color);
    SerieMeta.AddXY(DataIndicador,Meta,DateToStr(DataIndicador),clRed);
    FrmDataModule.ADOQueryResumoIndicador.Next;
  end;
  FrmDataModule.ADOQueryResumoIndicador.First;
  FrmDataModule.DataSourceResumoIndicador.Enabled:= true;
  ChartGrafico.AutoSize:= true;
  ChartGrafico.AddSeries(SerieMeta);
end;

