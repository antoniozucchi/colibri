function TFrmIndicadoresManutencao.PreecherICPM(RLSrt: TStringGrid; SQLBase,
  Meta: String; Linha: Integer): TICPM;
  var
    Atual,Projecao,HHRealizado,HHPlanejado,HHRealizadoProjecao,HHRisco:Double;
begin
  FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
  FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
  HHRealizado:=0;
  HHPlanejado:=0;
  HHRealizadoProjecao:=0;
  HHRisco:=0;
  while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
  begin
    HHPlanejado:=HHPlanejado+FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('HHPlanejado').AsFloat;
    HHRealizado:=HHRealizado+FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('HHRealizado').AsFloat;
    if (FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('RiscoAtendimento').AsBoolean=false) then
    begin
      HHRealizadoProjecao:= HHRealizadoProjecao+FrmDataModule.ADOQueryTemporarioDBMemoria.
      FieldByName('HHPlanejado').AsFloat;
    end
    else
    begin
      HHRisco:= HHRisco+FrmDataModule.ADOQueryTemporarioDBMemoria.
      FieldByName('HHPlanejado').AsFloat;
    end;
    FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
  end;
  //============================================================================
  if HHPlanejado = 0 then
  begin
    Atual:= 100;
    Projecao:= 100;
  end
  else
  begin
    Atual:= (HHRealizado/HHPlanejado)*100;
    Projecao:= (HHRealizadoProjecao/HHPlanejado)*100;
  end;
  RLSrt.Cells[1,Linha]:= FormatFloat('0.00',Atual);
  RLSrt.Cells[2,Linha]:= FormatFloat('0.00',Projecao);
  RLSrt.Cells[3,Linha]:= FormatFloat('0.00',HHPlanejado);
  RLSrt.Cells[4,Linha]:= FormatFloat('0.00',HHRealizado);
  RLSrt.Cells[5,Linha]:= FormatFloat('0.00',HHRisco);
  RLSrt.Cells[6,Linha]:= Meta;
  Result.Atual:= Atual;
  Result.Projecao:= Projecao;
  Result.HHRealizado:= HHRealizado;
  Result.HHPlanejado:= HHPlanejado;
  Result.HHRealizadoProjecao:= HHRealizadoProjecao;
  Result.HHRisco:= HHRisco;
end;

function TFrmIndicadoresManutencao.PreencherICPI(RLSrt: TStringGrid;
  Resumo: Boolean): TICPI;
  var
    SQLBase: String;
    TotalICPI,EmAtraso,TotalProjetado: Integer;
    Indicador,Projetado: Double;
begin
  RLSrt.ColCount:=3;
  RLSrt.RowCount:= 4;
  RLSrt.Rows[1].Clear;
  RLSrt.Rows[2].Clear;
  RLSrt.Cells[0,0]:= '';
  RLSrt.Cells[0,1]:= 'Em Atraso';
  RLSrt.Cells[0,2]:= 'Total';
  //===========================================================
  SQLBase:= 'SELECT tblICPI.* FROM tblICPI;';
  FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
  FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
  TotalICPI:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
  //Em Atraso
  SQLBase:= 'SELECT tblICPI.* FROM tblICPI '+
  'WHERE ((EmAtraso <> 0)AND(StatusICPI LIKE "PENDENTE"));';
  FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
  FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
  EmAtraso:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
  //TotalProjetado
  SQLBase:= 'SELECT tblICPI.* FROM tblICPI '+
  'WHERE ((EmAtraso <> 0)AND(RiscoAtendimento = True));';
  FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
  FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
  TotalProjetado:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
  //==========================================================
  RLSrt.Cells[1,0]:= FrmPrincipal.PrimeiraLetraMaiscula(FormatDateTime('mmmm yyyy', now));
  RLSrt.Cells[2,0]:= 'Projetado';
  //EmAtraso
  RLSrt.Cells[1,1]:= IntToStr(EmAtraso);
  RLSrt.Cells[2,1]:= IntToStr(TotalProjetado);
  //TotalICPI
  RLSrt.Cells[1,2]:= IntToStr(TotalICPI);
  RLSrt.Cells[2,2]:= IntToStr(TotalICPI);
  //Indicador
  if TotalICPI = 0 then
  begin
    Indicador:= 100;
    Projetado:= 100;
  end
  else
  begin
    Indicador:= RoundTo((1-(EmAtraso/TotalICPI))*100,-2);
    Projetado:= RoundTo((1-(TotalProjetado/TotalICPI))*100,-2);
  end;
  //=====================================
  RLSrt.Cells[0,3]:= 'ICPI';
  RLSrt.Cells[1,3]:= FormatFloat('0.00%',Indicador);
  RLSrt.Cells[2,3]:= FormatFloat('0.00%',Projetado);
  //================================================================
  FrmPrincipal.AutoFitGrade(RLSrt);
  Result.EmAtraso:= EmAtraso;
  Result.TotalICPI:= TotalICPI;
  Result.ICPI:= Indicador;
  Result.Projetado:= Projetado;
end;

function TFrmIndicadoresManutencao.PreencherIMRI(DataReferencia: TDateTime;RLSrt: TStringGrid;
  BCVT,Resumo: Boolean): TIMRI;
  var
    SQLBase,SQLBCVT: String;
    DataProcura,Coluna: String;
    Vencidas,TotalMONI,Projecao,i,VencidaA,VencidaB,VencidaC,VencidaD,
    MonitoradaA,MonitoradaB,MonitoradaC,MonitoradaD: Integer;
    PrimeiroDiaMes: TDateTime;
    IMRI,IMRI_B: Double;
begin
  VencidaA:=0;VencidaB:=0;VencidaC:=0;VencidaD:=0;
  MonitoradaA:=0;MonitoradaB:=0;MonitoradaC:=0;MonitoradaD:=0;
  if Resumo then
    Projecao:= 0
  else
    Projecao:= SpinEdit1.Value;
  if BCVT then
  begin
    RLSrt.RowCount:= 4;
    for I := 1 to RLSrt.RowCount-1 do
      RLSrt.Rows[i].Clear;
    //=================================
    RLSrt.Cells[0,0]:= '';
    RLSrt.Cells[0,1]:= 'Vencida ∑';
    RLSrt.Cells[0,2]:= 'Monitorada ∑';
    RLSrt.Cells[0,3]:= 'IMRI-B-CVT %';
  end
  else
  begin
    RLSrt.RowCount:= 12;
    for I := 1 to RLSrt.RowCount-1 do
      RLSrt.Rows[i].Clear;
    //=================================
    RLSrt.Cells[0,0]:= '';
    RLSrt.Cells[0,1]:= 'Vencida A';
    RLSrt.Cells[0,2]:= 'MONI A';
    RLSrt.Cells[0,3]:= 'Vencida B';
    RLSrt.Cells[0,4]:= 'MONI B';
    RLSrt.Cells[0,5]:= 'Vencida C';
    RLSrt.Cells[0,6]:= 'MONI C';
    RLSrt.Cells[0,7]:= 'Vencida D';
    RLSrt.Cells[0,8]:= 'MONI D';
    RLSrt.Cells[0,9]:= 'Vencida ∑';
    RLSrt.Cells[0,10]:= 'Monitorada ∑';
    RLSrt.Cells[0,11]:= 'IMRI %';
  end;
  RLSrt.ColCount:=1;

  for i := 0 to Projecao do
  begin
    RLSrt.ColCount:= RLSrt.ColCount+1;
    DataProcura:= (FormatDateTime('mm/dd/yyyy',IncMonth(DataReferencia,i)));
    if BCVT then
      SQLBCVT:= 'AND(BCVT = True));'
    else
      SQLBCVT:= ');';

    if BCVT = false then
    begin
      //Vencidas A
      SQLBase:= 'SELECT tblRTI.* FROM tblRTI '+
      'WHERE ((DataVencimento < #'+DataProcura+'#)AND(CodigoMedidaABCD LIKE "A")'+SQLBCVT;
      FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
      FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
      FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
      FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
      VencidaA:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
      //Vencidas B
      SQLBase:= 'SELECT tblRTI.* FROM tblRTI '+
