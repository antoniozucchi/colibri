procedure TFrmIndicadoresManutencao.actResumoIndicadoresExecute(
  Sender: TObject);
  var
    ICPM,ICPM_SO: TICPM;
    IMRI: TIMRI;
    ICPI: TICPI;
    SQLBase,Anterior,Atual,Mes,Ano: String;
    PrimeiroDiaMes: TDateTime;
begin
  PrimeiroDiaMes := RecodeDay(Date, 1);
  Atual:= FrmPrincipal.PrimeiraLetraMaiscula(FormatDateTime('mmmm yyyy', PrimeiroDiaMes));
  PrimeiroDiaMes:= IncMonth(PrimeiroDiaMes,-1);
  Anterior:= FrmPrincipal.PrimeiraLetraMaiscula(FormatDateTime('mmmm yyyy', PrimeiroDiaMes));

  RLResumo.RowCount:= 6;
  RLResumo.ColCount:= 5;
  RLResumo.Rows[1].Clear;
  RLResumo.Rows[2].Clear;
  RLResumo.Rows[3].Clear;
  RLResumo.Rows[4].Clear;
  RLResumo.Rows[5].Clear;
  //=====================================
  RLResumo.Cells[0,0]:= 'Indicador (%)';
  RLResumo.Cells[1,0]:= 'Meta';
  RLResumo.Cells[2,0]:= Anterior;
  RLResumo.Cells[3,0]:= Atual;
  RLResumo.Cells[4,0]:= 'Projeção';
  //Titulos
  RLResumo.Cells[0,1]:= 'ICPM';
  RLResumo.Cells[0,2]:= 'ICPM-SO';
  RLResumo.Cells[0,3]:= 'ICPI';
  RLResumo.Cells[0,4]:= 'IMRI';
  RLResumo.Cells[0,5]:= 'IMRI-B';
  //Meta
  RLResumo.Cells[1,1]:= MetaICPM;
  RLResumo.Cells[1,2]:= MetaICPMSO;
  RLResumo.Cells[1,3]:= MetaICPI;
  RLResumo.Cells[1,4]:= MetaIMRI;
  RLResumo.Cells[1,5]:= MetaIMRIB;
  //Anterior
  Mes:= IntToSTr(MonthOf(PrimeiroDiaMes));
  Ano:= IntToSTr(YearOf(PrimeiroDiaMes));
  SQLBase:= 'SELECT tblResumoIndicador.* FROM tblResumoIndicador '+
  'WHERE ((Month(DataIndicador)= '+(Mes)+')AND(Year(DataIndicador)= '+(Ano)+')) '+
  'ORDER BY DataIndicador DESC';
  FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Clear;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Add(SQLBase);
  FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
  if not FrmDataModule.ADOQueryTemporarioDBConsulta1.IsEmpty then
  begin
    RLResumo.Cells[2,1]:= FrmDataModule.ADOQueryTemporarioDBConsulta1.FieldByName('ICPM').AsString;
    RLResumo.Cells[2,2]:= FrmDataModule.ADOQueryTemporarioDBConsulta1.FieldByName('ICPMSO').AsString;
    RLResumo.Cells[2,3]:= FrmDataModule.ADOQueryTemporarioDBConsulta1.FieldByName('ICPI').AsString;
    RLResumo.Cells[2,4]:= FrmDataModule.ADOQueryTemporarioDBConsulta1.FieldByName('IMRI').AsString;
    RLResumo.Cells[2,5]:= FrmDataModule.ADOQueryTemporarioDBConsulta1.FieldByName('IMRI_B').AsString;
  end;
  //ICPM
  SQLBase:= 'SELECT tblICPM.* FROM tblICPM;';
  ICPM:= PreecherICPM(RLICPM,SQLBase,MetaICPM,1);
  SQLBase:= 'SELECT tblICPM.* FROM tblICPM WHERE (BooleanCritico = True);';
  ICPM_SO:= PreecherICPM(RLICPMSO,SQLBase,MetaICPMSO,1);
  //ICPI
  ICPI:= PreencherICPI(RLICPI,true);
  //IMRI
  IMRI:= PreencherIMRI(now,RLIMRI,false,true);
  //IMRIB:= PreencherIMRI(now,RLIMRIB,true,true);
  //Atual
  RLResumo.Cells[3,1]:= FormatFloat('0.00',ICPM.Atual);
  RLResumo.Cells[3,2]:= FormatFloat('0.00',ICPM_SO.Atual);
  RLResumo.Cells[3,3]:= FormatFloat('0.00',ICPI.ICPI);
  RLResumo.Cells[3,4]:= FormatFloat('0.00',IMRI.IMRI);
  RLResumo.Cells[3,5]:= FormatFloat('0.00',IMRI.IMRI_B);
  //Projeção
  RLResumo.Cells[4,1]:= FormatFloat('0.00',ICPM.Projecao);
  RLResumo.Cells[4,2]:= FormatFloat('0.00',ICPM_SO.Projecao);
  RLResumo.Cells[4,3]:= FormatFloat('0.00',ICPI.Projetado);
  //FrmPrincipal.AutoFitGrade(RLResumo);
end;

