procedure TFrmIndicadoresManutencao.actColarComentarioExecute(Sender: TObject);
begin
  FrmDataModule.ADOQueryICPM.Edit;
  DBEditComentario.Text:= CopiaComentario;
  FrmDataModule.ADOQueryICPM.Post;
end;

procedure TFrmIndicadoresManutencao.actCopiarComentarioExecute(Sender: TObject);
begin
  case PageControlIndicadores.TabIndex of
    1: CopiaComentario:= DBEditComentarioICPM.Text;
    3: CopiaComentario:= DBEditComentarioICPI.Text;
  end;
end;

procedure TFrmIndicadoresManutencao.actEtiquetaExecute(Sender: TObject);
begin
  if btnMark.Down then
  begin
    ChartGrafico.Series[0].Marks.Style:= smsLabelValue;
    ChartGrafico.Series[0].Marks.MultiLine:= true;
    ChartGrafico.Series[0].Marks.Arrow.Visible:= true;
    ChartGrafico.Series[0].Marks.Arrow.Color:= clBlack;
    ChartGrafico.Series[0].Marks.Margins.Left:= 2;
    ChartGrafico.Series[0].Marks.Margins.Right:= 2;
    ChartGrafico.Series[0].Marks.Margins.Top:= 1;
    ChartGrafico.Series[0].Marks.Margins.Bottom:= 1;
    ChartGrafico.Series[0].Marks.Visible:= true;
  end
  else
    ChartGrafico.Series[0].Marks.Visible:= false;
end;

procedure TFrmIndicadoresManutencao.actExcelICPMExecute(Sender: TObject);
