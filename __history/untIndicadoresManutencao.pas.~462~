procedure TFrmIndicadoresManutencao.actImprimirICPMExecute(Sender: TObject);
  var
   BooleanCritico,RiscoAtendimento: Boolean;
   TextoBreveOM,DenominacaoLocalInstalacao,txtTipoEtapaServico,
   Comentario,HHPlanejado,Plataforma:String;
   Linha: Integer;
begin
  //Titulo e Configuração da tabela base
  RLImprimirICPM.ColCount:= 8;
  RLImprimirICPM.RowCount:= 1;
  RLImprimirICPM.Cells[0,0]:= 'Crítico';
  RLImprimirICPM.Cells[1,0]:= 'Texto Breve [OM]';
  RLImprimirICPM.Cells[2,0]:= 'Denomin. Local Instalação';
  RLImprimirICPM.Cells[3,0]:= 'Tipo Etapa Serviço';
  RLImprimirICPM.Cells[4,0]:= 'Risco';
  RLImprimirICPM.Cells[5,0]:= 'Comentário';
  RLImprimirICPM.Cells[6,0]:= 'HH Plan.';
  RLImprimirICPM.Cells[7,0]:= 'Instalação';
  //Preencher tabela base
  FrmDataModule.DataSourceICPM.Enabled:= false;
  FrmDataModule.ADOQueryICPM.First;
  while not FrmDataModule.ADOQueryICPM.Eof do
  begin
    Linha:= RLImprimirICPM.RowCount;
    RLImprimirICPM.RowCount:= RLImprimirICPM.RowCount+1;
    TextoBreveOM:=FrmDataModule.DataSourceICPM.DataSet.FieldByName('TextoBreveOM').AsString;
    DenominacaoLocalInstalacao:=FrmDataModule.DataSourceICPM.DataSet.FieldByName('DenominacaoLocalInstalacao').AsString;
    txtTipoEtapaServico:=FrmDataModule.DataSourceICPM.DataSet.FieldByName('txtTipoEtapaServico').AsString;
    RiscoAtendimento:=FrmDataModule.DataSourceICPM.DataSet.FieldByName('RiscoAtendimento').AsBoolean;
    BooleanCritico:=FrmDataModule.DataSourceICPM.DataSet.FieldByName('BooleanCritico').AsBoolean;
    Comentario:=FrmDataModule.DataSourceICPM.DataSet.FieldByName('Comentario').AsString;
    HHPlanejado:=FrmDataModule.DataSourceICPM.DataSet.FieldByName('HHPlanejado').AsString;
    Plataforma:=FrmDataModule.DataSourceICPM.DataSet.FieldByName('Plataforma').AsString;
    if BooleanCritico then
      RLImprimirICPM.Cells[0,Linha]:= 'SIM'
    else
      RLImprimirICPM.Cells[0,Linha]:= 'NÃO';
    if RiscoAtendimento then
      RLImprimirICPM.Cells[4,Linha]:= 'SIM'
    else
      RLImprimirICPM.Cells[4,Linha]:= 'NÃO';
    RLImprimirICPM.Cells[1,Linha]:= TextoBreveOM;
    RLImprimirICPM.Cells[2,Linha]:= DenominacaoLocalInstalacao;
    RLImprimirICPM.Cells[3,Linha]:= txtTipoEtapaServico;
    RLImprimirICPM.Cells[5,Linha]:= Comentario;
    RLImprimirICPM.Cells[6,Linha]:= HHPlanejado;
    RLImprimirICPM.Cells[7,Linha]:= Plataforma;
    FrmDataModule.ADOQueryICPM.Next;
  end;
  FrmDataModule.ADOQueryICPM.First;
  FrmDataModule.DataSourceICPM.Enabled:= true;
  FrmPrincipal.AutoFitGrade(RLImprimirICPM);
  //Imprimir
  if not Assigned(FrmPreview) then
    FrmPreview:=TFrmPreview.Create(Application)
  else
    FrmPreview.Show;

  FrmPreview.ListaTituloRelatorio:= TStringList.Create;
  FrmPreview.ListaTituloRelatorio.Add('Pendencias ICPM - '+DateToStr(now));
  FrmPreview.RadioGroupRelatorio.ItemIndex:= 9;
  FrmPreview.GeneratePages;
end;

