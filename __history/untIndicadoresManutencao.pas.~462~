    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    TotalMONI:= FrmDataModule.ADOQueryTemporarioDBMemoria.RecordCount;
    //Preencher IMRI
    PrimeiroDiaMes := RecodeDay(DateTimeVencimentoRTI.Date, 1);
    Coluna:= FrmPrincipal.PrimeiraLetraMaiscula(FormatDateTime('mmmm yyyy', IncMonth(PrimeiroDiaMes,i)));
    RLSrt.Cells[i+1,0]:= Coluna;
    if Vencidas = 0 then
      IMRI:= 100
    else
      IMRI:= RoundTo((TotalMONI/Vencidas)*100,-2);
    if VencidaB = 0 then
      IMRI_B:= 100
    else
      IMRI_B:= RoundTo((MonitoradaB/VencidaB)*100,-2);
    if BCVT then
    begin
      RLSrt.Cells[i+1,1]:= IntToStr(Vencidas);
      RLSrt.Cells[i+1,2]:= IntToStr(TotalMONI);
      RLSrt.Cells[i+1,3]:= FormatFloat('0.00%',IMRI);
    end
    else
    begin
      RLSrt.Cells[i+1,1]:= IntToStr(VencidaA);
      RLSrt.Cells[i+1,2]:= IntToStr(MonitoradaA);
      RLSrt.Cells[i+1,3]:= IntToStr(VencidaB);
      RLSrt.Cells[i+1,4]:= IntToStr(MonitoradaB);
      RLSrt.Cells[i+1,5]:= IntToStr(VencidaC);
      RLSrt.Cells[i+1,6]:= IntToStr(MonitoradaC);
      RLSrt.Cells[i+1,7]:= IntToStr(VencidaD);
      RLSrt.Cells[i+1,8]:= IntToStr(MonitoradaD);
      RLSrt.Cells[i+1,9]:= IntToStr(Vencidas);
      RLSrt.Cells[i+1,10]:= IntToStr(TotalMONI);
      RLSrt.Cells[i+1,11]:= FormatFloat('0.00%',IMRI);
    end;
    //================================================================
    FrmPrincipal.AutoFitGrade(RLSrt);
    Result.Vencidas:= Vencidas;
    Result.Monitoradas:= TotalMONI;
    Result.IMRI:= IMRI;
    Result.IMRI_B:= IMRI_B;
  end;
end;

