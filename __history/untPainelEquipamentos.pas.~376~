procedure TFrmPainelEquipamentos.infoDuto(posX, posY: Double);
  var
    Dist: Double;
    X1,Y1,X2,Y2,ers: Integer;
begin
  try
    //===========================================================
    ers:= 2;
    FrmDataModule.ADOQueryEditarDutos.First;
    while not FrmDataModule.ADOQueryEditarDutos.Eof do
    begin
      X1:= FrmDataModule.DataSourceEditarDutos.DataSet.FieldByName('X1').AsInteger;
      Y1:= FrmDataModule.DataSourceEditarDutos.DataSet.FieldByName('Y1').AsInteger;
      X2:= FrmDataModule.DataSourceEditarDutos.DataSet.FieldByName('X2').AsInteger;
      Y2:= FrmDataModule.DataSourceEditarDutos.DataSet.FieldByName('Y2').AsInteger;
      Dist:= ABS(DistanciaPontoReta(posX,posY,X1,Y1,X2,Y2));
      if (Dist<=ers) then
      begin
        if ((
        (posX >= X1-ers)AND(posX <= X2+ers)AND
        (posY <= Y1+ers)AND(posY >= Y2-ers))OR(
        (posX >= X1-ers)AND(posX <= X2+ers)AND
        (posY >= Y1-ers)AND(posY <= Y2+ers))OR(
        (posX <= X1+ers)AND(posX >= X2-ers)AND
        (posY >= Y1-ers)AND(posY <= Y2+ers))OR(
        (posX <= X1+ers)AND(posX >= X2-ers)AND
        (posY <= Y1+ers)AND(posY >= Y2-ers))) then
        begin
          PanelTituloAjuda1.Caption:= 'Informaçăo Dutos';
          actAjudaLimpar.Execute;
          PanelEditarDutos.Align:= alClient;
          PanelEditarDutos.Visible:= true;
          PanelAjuda.Height:= 370;
          PanelAjuda.Width:= 350;
          PanelAjuda.Visible:= true;
          abort;
        end;
      end;
      FrmDataModule.ADOQueryEditarDutos.Next;
    end;
  except
  end;
end;

