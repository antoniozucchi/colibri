function TFrmPainelEquipamentos.infoPlataforma(posX, posY: Double): boolean;
  var
    X1,Y1,ers: Integer;
begin
  Result:= false;
  try
    ers:= 10;
    FrmDataModule.ADOQueryEditarPlataformaPainel.First;
    while not FrmDataModule.ADOQueryEditarPlataformaPainel.Eof do
    begin
      X1:= FrmDataModule.DataSourceEditarPlataformaPainel.DataSet.FieldByName('Painel_X').AsInteger;
      Y1:= FrmDataModule.DataSourceEditarPlataformaPainel.DataSet.FieldByName('Painel_Y').AsInteger;
      if ((posX >= X1-ers)AND(posX <= X1+ers)AND
      (posY <= Y1+ers)AND(posY >= Y1-ers)) then
      begin
        Result := true;
        PanelTituloAjuda1.Caption:= 'Informaçăo Plataforma';
        actAjudaLimpar.Execute;
        PanelEditarPlataforma.Align:= alClient;
        PanelEditarPlataforma.Visible:= true;
        PanelAjuda.Height:= 370;
        PanelAjuda.Width:= 450;
        PanelAjuda.Visible:= true;
        abort;
      end;
      FrmDataModule.ADOQueryEditarPlataformaPainel.Next;
    end;
  except
    Result:= false;
  end;
end;

