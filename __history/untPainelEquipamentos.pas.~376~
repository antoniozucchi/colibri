procedure TFrmPainelEquipamentos.actMatrizDutosExecute(Sender: TObject);
  var
    i,j,Registros: Integer;
    TipoDuto,X1,X2,Y1,Y2,idDutosOPAR,Sentido,CondicaoDuto: String;
    ListaBusca: TStringList;
    PalavraLista,PalavraBusca,SQLString,SQLBase: String;
    QueryDesenho: TADOQuery;
begin
  ListaBusca:= TStringList.Create;
  ListaBusca.delimiter:= ':';
  ListaBusca.StrictDelimiter:= False;
  //==================================================
  PalavraBusca:= '';
  for I := 0 to CheckListBoxTipoDuto.Count-1 do
  begin
    if CheckListBoxTipoDuto.Checked[i] then
    begin
      ListaBusca.DelimitedText:= CheckListBoxTipoDuto.Items[i];
      PalavraLista:= ListaBusca[0];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('TipoDuto',PalavraBusca,'Contem',ColunasLayoutDutos,4,false);
  //==================================================
  PalavraBusca:= '';
  for I := 0 to CheckListBoxCondicaoDuto.Count-1 do
  begin
    if CheckListBoxCondicaoDuto.Checked[i] then
    begin
      ListaBusca.DelimitedText:= CheckListBoxCondicaoDuto.Items[i];
      PalavraLista:= ListaBusca[0];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  //==============================================================
  FrmPrincipal.buscaFiledGrid1('CondicaoDuto',PalavraBusca,'Contem',ColunasLayoutDutos,4,false);
  SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayoutDutos,true);
  SQLBase:= 'SELECT tblPainelDutos.* FROM tblPainelDutos '+
  SQLString+' ORDER BY BooleanDesenho,TAG_Duto;';
  QueryDesenho := TADOQuery.Create(self);
  QueryDesenho.Connection := FrmDataModule.ADOQueryPainelDutosOPAR.Connection;
  QueryDesenho.Close;
  QueryDesenho.SQL.Clear;
  QueryDesenho.SQL.Add(SQLBase);
  QueryDesenho.Open;
  QueryDesenho.Active:= true;
  QueryDesenho.First;
  //===============================================================
  Registros:= QueryDesenho.RecordCount;
  MatrizDutos:= nil;
  SetLength(MatrizDutos, 10);
  for i := 0 to High(MatrizDutos) do
    SetLength(MatrizDutos[i], Registros);
  j:=0;
  while not QueryDesenho.Eof do
  begin
    idDutosOPAR:= QueryDesenho.FieldByName('idDutosOPAR').AsString;
    X1:= QueryDesenho.FieldByName('X1').AsString;
    Y1:= QueryDesenho.FieldByName('Y1').AsString;
    X2:= QueryDesenho.FieldByName('X2').AsString;
    Y2:= QueryDesenho.FieldByName('Y2').AsString;
    TipoDuto:= QueryDesenho.FieldByName('TipoDuto').AsString;
    CondicaoDuto:= QueryDesenho.FieldByName('CondicaoDuto').AsString;
    Sentido:= QueryDesenho.FieldByName('Sentido').AsString;
    //=======================================
    if TipoDuto = 'Óleoduto' then
