procedure TFrmPainelEquipamentos.actDesDutosExecute(Sender: TObject);
  var
    i: Integer;
    X1,Y1,X2,Y2: Double;
begin
  for I := 0 to High(MatrizDutos[0]) do
  begin
    try
      X1:= StrToFloat(MatrizDutos[2,i]);
    except
      X1:= 0;
    end;
    try
      Y1:= StrToFloat(MatrizDutos[3,i]);
    except
      Y1:= 0;
    end;
    try
      X2:= StrToFloat(MatrizDutos[4,i]);
    except
      X2:= 0;
    end;
    try
      Y2:= StrToFloat(MatrizDutos[5,i]);
    except
      Y2:= 0;
    end;
    desDuto(X1,Y1,X2,Y2,
    MatrizDutos[1,i],MatrizDutos[0,i],MatrizDutos[7,i]
    ,MatrizDutos[8,i],MatrizDutos[9,i],MatrizDutos[6,i]);
