procedure TFrmPainelEquipamentos.StringGridSAPDrawCell(Sender: TObject; ACol,
  ARow: Integer; Rect: TRect; State: TGridDrawState);
  var
  R: TRect;
  MesHoje,AnoHoje,MesPrev,AnoPrev: Integer;
begin
if (ARow > 0) then
  begin
    R := Rect;
    R.Left := R.Left - 4;
    try
      //N° Aprovado
      if ((StringGridSAP.Cells[0,ARow] = 'FO')AND(ACol=0)) then
      begin
        StringGridSAP.Canvas.Brush.Color := clRed;
        StringGridSAP.Canvas.Font.Style := [];
        StringGridSAP.Canvas.FillRect(R);
        DrawText(StringGridSAP.Canvas.Handle, PChar(StringGridSAP.Cells[ACol, ARow]),
        -1, R, DT_Center);
      end
      else if ((StringGridSAP.Cells[0,ARow] = 'RO')AND(ACol=0)) then
      begin
        StringGridSAP.Canvas.Brush.Color := clYellow;
        StringGridSAP.Canvas.Font.Style := [];
        StringGridSAP.Canvas.FillRect(R);
        DrawText(StringGridSAP.Canvas.Handle, PChar(StringGridSAP.Cells[ACol, ARow]),
        -1, R, DT_Center);
      end
      else if ((StringGridSAP.Cells[0,ARow] = 'PREV.')AND(ACol=0)) then
      begin
        MesHoje:= StrToInt(FormatDateTime('M',Now));
        AnoHoje:= StrToInt(FormatDateTime('YYYY',Now));
        MesPrev:= StrToInt(FormatDateTime('M',StrToDate(StringGridSAP.Cells[4,ARow])));
        AnoPrev:= StrToInt(FormatDateTime('YYYY',StrToDate(StringGridSAP.Cells[4,ARow])));
        if ((MesPrev < MesHoje)AND(AnoPrev <= AnoHoje)) then
          StringGridSAP.Canvas.Brush.Color := clFuchsia
        else
          StringGridSAP.Canvas.Brush.Color := clGray;

        StringGridSAP.Canvas.Font.Style := [];
        StringGridSAP.Canvas.FillRect(R);
        DrawText(StringGridSAP.Canvas.Handle, PChar(StringGridSAP.Cells[ACol, ARow]),
        -1, R, DT_Center);
      end
      else if ((StringGridSAP.Cells[0,ARow] = 'PEND.')AND(ACol=0)) then
      begin
        StringGridSAP.Canvas.Brush.Color := clAqua;
        StringGridSAP.Canvas.Font.Style := [];
        StringGridSAP.Canvas.FillRect(R);
        DrawText(StringGridSAP.Canvas.Handle, PChar(StringGridSAP.Cells[ACol, ARow]),
        -1, R, DT_Center);
      end;
    except
    end;
  end;
end;

