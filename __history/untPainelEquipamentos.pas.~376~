procedure TFrmPainelEquipamentos.desDuto(X1, Y1, X2, Y2: Double; Cor,TipoLinha,Sentido,MarkX1,MarkX2,idDutosOPAR: String);
  var
    Pintar: TColor;
begin
  if ((PanelEditarDutos.Visible)AND(idDutosOPAR = DBEdit_idDutosOPAR.Text)) then
  begin
    Pintar:= clBlack;
    RChartDutos.LineWidth:= 3;
  end
  else
  begin
    Pintar:= clBlack;
    if Cor = 'Azul' then
      Pintar:= clBlue
    else if Cor = 'Amarelo' then
      Pintar:= clYellow
    else if Cor = 'Vermelho' then
      Pintar:= clRed
    else if Cor = 'Verde' then
      Pintar:= clGreen
    else if Cor = 'Aqua' then
      Pintar:= clRed
    else if Cor = 'Fuschia' then
      Pintar:= clFuchsia
    else if Cor = 'Preto' then
      Pintar:= clBlack;

    RChartDutos.LineWidth:= 1;
  end;
  //============================================================================
  if TipoLinha = 'Solido' then
  begin
    RChartDutos.PenStyle:= psSolid;
    RChartDutos.FillColor:= RChartDutos.ChartColor;
  end
  else if TipoLinha = 'Traco' then
  begin
    RChartDutos.PenStyle:= psDash;
    RChartDutos.FillColor:= RChartDutos.ChartColor;
  end
  else if TipoLinha = 'Ponto' then
  begin
    RChartDutos.PenStyle:= psDot;
    RChartDutos.FillColor:= RChartDutos.ChartColor;
  end;

  RChartDutos.DataColor:= Pintar;

  if Sentido = 'X1 -> X2' then
    RChartDutos.Arrow(X1,Y1,X2,Y2,10)
  else if Sentido = 'X2 -> X1' then
    RChartDutos.Arrow(X2,Y2,X1,Y1,10)
  else if Sentido = 'Ambos' then
  begin
    RChartDutos.Arrow(X1,Y1,X2,Y2,10);
    RChartDutos.Arrow(X2,Y2,X1,Y1,10);
  end
  else if Sentido = 'Linha' then
  begin
    RChartDutos.MoveTo(X1, Y1);
    RChartDutos.DrawTo(X2, Y2);
  end;
  if MarkX1 = 'True' then
    RChartDutos.MarkAt(X1, Y1,24);
  if MarkX2 = 'True' then
    RChartDutos.MarkAt(X2, Y2,24);
end;

