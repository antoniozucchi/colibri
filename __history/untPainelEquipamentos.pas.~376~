function TFrmPainelEquipamentos.DistanciaPontoReta(Xpt, Ypt, X1, Y1, X2,
  Y2: Double): Double;
  var
    ck,aX,bY: Double;
begin
  aX:= (Y1-Y2);
  bY:= (X2-X1);
  cK:= (X1*Y2) - (X2*Y1);
  if SQRT(POWER(aX,2)+POWER(bY,2))<>0 then
    Result:= ABS((aX*Xpt)+(bY*Ypt)+ck)/(SQRT(POWER(aX,2)+POWER(bY,2)))
  else
    Result:= 0;
end;

