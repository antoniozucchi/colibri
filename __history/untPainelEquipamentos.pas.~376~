procedure TFrmPainelEquipamentos.actMatrizPlataformasExecute(Sender: TObject);
  var
    i,j,Registros: Integer;
    Painel_Tipo,Painel_X,Painel_Y,Painel_Condicao,Plataforma: String;
    ListaBusca: TStringList;
    PalavraLista,PalavraBusca: String;
begin
  ListaBusca:= TStringList.Create;
  ListaBusca.delimiter:= ':';
  ListaBusca.StrictDelimiter:= False;
  //==================================================
  PalavraBusca:= '';
  for I := 0 to CheckListBoxTipoPlataforma.Count-1 do
  begin
    if CheckListBoxTipoPlataforma.Checked[i] then
    begin
      ListaBusca.DelimitedText:= CheckListBoxTipoPlataforma.Items[i];
      PalavraLista:= ListaBusca[0];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('Painel_Tipo',PalavraBusca,'Contem',ColunasLayoutPlataformas,4,false);
  //==================================================
  PalavraBusca:= '';
  for I := 0 to CheckListBoxCondicaoPlataforma.Count-1 do
  begin
    if CheckListBoxCondicaoPlataforma.Checked[i] then
    begin
      ListaBusca.DelimitedText:= CheckListBoxCondicaoPlataforma.Items[i];
      PalavraLista:= ListaBusca[0];
      if PalavraBusca <> '' then
        PalavraBusca:= PalavraBusca+';'+PalavraLista
      else
        PalavraBusca:= PalavraLista;
    end;
  end;
  FrmPrincipal.buscaFiledGrid1('Painel_Condicao',PalavraBusca,'Contem',ColunasLayoutPlataformas,4,false);
  //===========================================================================
  actProcurarPlataformas.Execute;
  Registros:= FrmDataModule.ADOQueryPainelPlataformas.RecordCount;

  MatrizPlataforma:= nil;
  SetLength(MatrizPlataforma, 6);
  for i := 0 to High(MatrizPlataforma) do
    SetLength(MatrizPlataforma[i], Registros);

  j:=0;
  while not FrmDataModule.ADOQueryPainelPlataformas.Eof do
  begin
    Plataforma:= FrmDataModule.ADOQueryPainelPlataformas.FieldByName('Plataforma').AsString;
    Painel_X:= FrmDataModule.ADOQueryPainelPlataformas.FieldByName('Painel_X').AsString;
    Painel_Y:= FrmDataModule.ADOQueryPainelPlataformas.FieldByName('Painel_Y').AsString;
    Painel_Tipo:= FrmDataModule.ADOQueryPainelPlataformas.FieldByName('Painel_Tipo').AsString;
    Painel_Condicao:= FrmDataModule.ADOQueryPainelPlataformas.FieldByName('Painel_Condicao').AsString;
    if Painel_Condicao = 'Operaçăo' then
      MatrizPlataforma[4,j]:= 'Verde'
    else if Painel_Condicao = 'Paralisado' then
      MatrizPlataforma[4,j]:= 'Vermelho'
    else if Painel_Condicao = 'Desativado' then
      MatrizPlataforma[4,j]:= 'Azul'
    else if Painel_Condicao = 'Descomissionado' then
      MatrizPlataforma[4,j]:= 'Fuschia';

    MatrizPlataforma[0,j]:= Plataforma;
    MatrizPlataforma[1,j]:= Painel_X;
    MatrizPlataforma[2,j]:= Painel_Y;
    MatrizPlataforma[3,j]:= Painel_Tipo;
    MatrizPlataforma[5,j]:= FrmDataModule.ADOQueryPainelPlataformas.FieldByName('idPainelPlataforma').AsString;
    FrmDataModule.ADOQueryPainelPlataformas.Next;
    j:= j+1;
  end;
end;

