procedure TFrmConsultaLEC.actArvoreExecute(Sender: TObject);
  var
    NodePai,NodeFilho1,NodeFilho2,NodeFilho3: TTreeNode;
    SQLBase,LocalInstalacao,DenominacaoLocalInstalacao,SQLString: String;
    QueryNivel0,QueryNivel1,QueryNivel2,QueryNivel3,QueryNivel4: TADOQuery;
    i: Integer;
    cancelado: Boolean;
begin
  TreeView.Items.Clear;
  Interromper := False;
  actInterromper.Enabled:= true;
  Cancelado:= false;
  SQLString:= frmPrincipal.SQLStringFiltroTabela(ColunasLayoutSAP,false);
  if SQLString <> '' then
    SQLString:= 'AND'+SQLString;
  //=========================================================
  for I := 1 to 4 do
  begin
    SQLBase:= 'SELECT tblLocalInstalacao.* FROM tblLocalInstalacao '+
    'WHERE (Hierarquia = '+IntToStr(i)+')'+SQLString+' ORDER BY LocalInstalacao;';
    QueryNivel0 := TADOQuery.Create(self);
    QueryNivel0.Connection := FrmDataModule.ADOConnectionMemoria;
    QueryNivel0.Close;
    QueryNivel0.SQL.Clear;
    QueryNivel0.SQL.Add(SQLBase);
    QueryNivel0.Open;
    if not QueryNivel0.IsEmpty then
    begin
       break;
    end;
  end;
  FrmPrincipal.ProgressBarIncializa(QueryNivel0.RecordCount,'Carregando...');
  while not QueryNivel0.Eof do
  begin
    //Interromper Processo
    Application.ProcessMessages;
    if Cancelado then
      break
    else if Interromper and (Application.MessageBox(PChar('Deseja realmente cancelar o processo?'),
    '.::ATENЫO::.',36) = 6) then
    begin
      Interromper := true;
      break;
    end
    else
      Interromper := False;
    //=========================================
    LocalInstalacao:= QueryNivel0.FieldByName('LocalInstalacao').AsString;
    DenominacaoLocalInstalacao:= QueryNivel0.FieldByName('DenominacaoLocalInstalacao').AsString;
    NodePai:= TreeView.Items.Add(nil,DenominacaoLocalInstalacao);
    SQLBase:= 'SELECT tblLocalInstalacao.* FROM tblLocalInstalacao '+
    'WHERE ((Hierarquia = '+IntToStr(i+1)+')AND(LocalInstalacao LIKE '+QuotedStr(LocalInstalacao+'%')+
    ')'+SQLString+') ORDER BY LocalInstalacao;';
    QueryNivel1 := TADOQuery.Create(self);
    QueryNivel1.Connection := FrmDataModule.ADOConnectionMemoria;
    QueryNivel1.Close;
    QueryNivel1.SQL.Clear;
    QueryNivel1.SQL.Add(SQLBase);
    QueryNivel1.Open;
    QueryNivel1.Active:= true;
    while not QueryNivel1.Eof do
    begin
      //Interromper Processo
      Application.ProcessMessages;
      if Cancelado then
        break
      else if Interromper and (Application.MessageBox(PChar('Deseja realmente cancelar o processo?'),
      '.::ATENЫO::.',36) = 6) then
      begin
        Interromper := true;
        Cancelado:= true;
        break;
      end
      else
        Interromper := False;
      //============================================================
      LocalInstalacao:= QueryNivel1.FieldByName('LocalInstalacao').AsString;
      NodeFilho1:= TreeView.Items.AddChild(NodePai,QueryNivel1.FieldByName
      ('LocalInstalacao').AsString+' = '+QueryNivel1.FieldByName
      ('DenominacaoLocalInstalacao').AsString);
      SQLBase:= 'SELECT tblLocalInstalacao.* FROM tblLocalInstalacao '+
      'WHERE ((Hierarquia = '+IntToStr(i+2)+')AND(LocalInstalacao LIKE '+QuotedStr(LocalInstalacao+'%')+
      ')'+SQLString+') ORDER BY LocalInstalacao;';
      QueryNivel2 := TADOQuery.Create(self);
      QueryNivel2.Connection := FrmDataModule.ADOConnectionMemoria;
      QueryNivel2.Close;
      QueryNivel2.SQL.Clear;
      QueryNivel2.SQL.Add(SQLBase);
      QueryNivel2.Open;
      QueryNivel2.Active:= true;
      while not QueryNivel2.Eof do
      begin
        //Interromper Processo
        Application.ProcessMessages;
        if Cancelado then
          break
        else if Interromper and (Application.MessageBox(PChar('Deseja realmente cancelar o processo?'),
        '.::ATENЫO::.',36) = 6) then
        begin
          Interromper := true;
          Cancelado:= true;
          break;
        end
        else
          Interromper := False;
        //============================================================
        LocalInstalacao:= QueryNivel2.FieldByName('LocalInstalacao').AsString;
        NodeFilho2:= TreeView.Items.AddChild(NodeFilho1,QueryNivel2.FieldByName
        ('LocalInstalacao').AsString+' = '+QueryNivel2.FieldByName
        ('DenominacaoLocalInstalacao').AsString);
        //=================================================================
        SQLBase:= 'SELECT tblLocalInstalacao.* FROM tblLocalInstalacao '+
        'WHERE ((Hierarquia = '+IntToStr(i+3)+')AND(LocalInstalacao LIKE '+QuotedStr(LocalInstalacao+'%')+
        ')'+SQLString+') ORDER BY LocalInstalacao;';
        QueryNivel3 := TADOQuery.Create(self);
        QueryNivel3.Connection := FrmDataModule.ADOConnectionMemoria;
        QueryNivel3.Close;
        QueryNivel3.SQL.Clear;
        QueryNivel3.SQL.Add(SQLBase);
        QueryNivel3.Open;
        QueryNivel3.Active:= true;
        while not QueryNivel3.Eof do
        begin
          //Interromper Processo
          Application.ProcessMessages;
          if Cancelado then
            break
          else if Interromper and (Application.MessageBox(PChar('Deseja realmente cancelar o processo?'),
          '.::ATENЫO::.',36) = 6) then
          begin
            Interromper := true;
            Cancelado:= true;
            break;
          end
          else
            Interromper := False;
          //============================================================
          LocalInstalacao:= QueryNivel3.FieldByName('LocalInstalacao').AsString;
          NodeFilho3:= TreeView.Items.AddChild(NodeFilho2,QueryNivel3.FieldByName
          ('LocalInstalacao').AsString+' = '+QueryNivel3.FieldByName
          ('DenominacaoLocalInstalacao').AsString);
          SQLBase:= 'SELECT tblLocalInstalacao.* FROM tblLocalInstalacao '+
          'WHERE ((Hierarquia = '+IntToStr(i+4)+')AND(LocalInstalacao LIKE '+QuotedStr(LocalInstalacao+'%')+
          ')'+SQLString+') ORDER BY LocalInstalacao;';
          QueryNivel4 := TADOQuery.Create(self);
          QueryNivel4.Connection := FrmDataModule.ADOConnectionMemoria;
          QueryNivel4.Close;
          QueryNivel4.SQL.Clear;
          QueryNivel4.SQL.Add(SQLBase);
          QueryNivel4.Open;
          QueryNivel4.Active:= true;
          while not QueryNivel4.Eof do
          begin
            //Interromper Processo
            Application.ProcessMessages;
            if Cancelado then
              break
            else if Interromper and (Application.MessageBox(PChar('Deseja realmente cancelar o processo?'),
            '.::ATENЫO::.',36) = 6) then
            begin
              Interromper := true;
              Cancelado:= true;
              break;
            end
            else
              Interromper := False;
            //============================================================
            LocalInstalacao:= QueryNivel4.FieldByName('LocalInstalacao').AsString;
            TreeView.Items.AddChild(NodeFilho3,QueryNivel4.FieldByName
            ('LocalInstalacao').AsString+' = '+QueryNivel4.FieldByName
            ('DenominacaoLocalInstalacao').AsString);
            QueryNivel4.Next;
          end;
          QueryNivel3.Next;

        end;
        QueryNivel2.Next;
      end;
      QueryNivel1.Next;
    end;
    QueryNivel0.Next;
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmPrincipal.ProgressBarAtualizar;
  actInterromper.Enabled:= false;
  Interromper := False;
end;

