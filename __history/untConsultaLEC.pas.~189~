function TFrmConsultaLEC.CriarLECItemManutncao(idLECLista: Integer; BuscaLocal: String): Boolean;
  var
    SQLString,SQLBase: string;
begin
  Result:= false;
  //ITEM DE MANUTENЫO
  SQLString:= FrmPrincipal.palavraBusca('','LocalInstalacao','Exato',BuscaLocal,'AND');
  if SQLString <> '' then
  begin
    SQLBase:= 'SELECT tblItemManutencao.* FROM tblItemManutencao '+
    'WHERE '+SQLString+';';
    FrmDataModule.ADOQueryTemporarioDBMemoria.Close;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Clear;
    FrmDataModule.ADOQueryTemporarioDBMemoria.SQL.Add(SQLBase);
    FrmDataModule.ADOQueryTemporarioDBMemoria.Open;
    //=========================================================
    FrmDataModule.ADOQueryLECItemManutencao.Active:= false;
    FrmDataModule.ADOQueryLECItemManutencao.Parameters.Items[0].Value:= idLECLista;
    FrmDataModule.ADOQueryLECItemManutencao.Active:= true;
    while not FrmDataModule.ADOQueryLECItemManutencao.Eof do
      FrmDataModule.ADOQueryLECItemManutencao.Delete;
    //=========================================================
    while not FrmDataModule.ADOQueryTemporarioDBMemoria.Eof do
    begin
      FrmDataModule.ADOQueryLECItemManutencao.Insert;
      FrmDataModule.ADOQueryLECItemManutencao.FieldByName('PlanoManutencao').AsString:=
      FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('PlanoManutencao').AsString;
      FrmDataModule.ADOQueryLECItemManutencao.FieldByName('ItemManutencao').AsString:=
      FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('ItemManutencao').AsString;
      FrmDataModule.ADOQueryLECItemManutencao.FieldByName('DescricaoItem').AsString:=
      FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('DescricaoItem').AsString;
      FrmDataModule.ADOQueryLECItemManutencao.FieldByName('LocalInstalacao').AsString:=
      FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('LocalInstalacao').AsString;
      FrmDataModule.ADOQueryLECItemManutencao.FieldByName('DenominacaoLocalInstalacao').AsString:=
      FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('DenominacaoLocalInstalacao').AsString;
      FrmDataModule.ADOQueryLECItemManutencao.FieldByName('CentroTrabalho').AsString:=
      FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('CentroTrabalho').AsString;
      FrmDataModule.ADOQueryLECItemManutencao.FieldByName('TipoEtapaServico').AsString:=
      FrmDataModule.ADOQueryTemporarioDBMemoria.FieldByName('TipoEtapaServico').AsString;
      FrmDataModule.ADOQueryLECItemManutencao.Post;
      //=============================================================
      Result:= true;
      FrmDataModule.ADOQueryTemporarioDBMemoria.Next;
    end;
  end
  else
  begin
    FrmDataModule.ADOQueryLECItemManutencao.Active:= false;
    FrmDataModule.ADOQueryLECItemManutencao.Parameters.Items[0].Value:= idLECLista;
    FrmDataModule.ADOQueryLECItemManutencao.Active:= true;
    while not FrmDataModule.ADOQueryLECItemManutencao.Eof do
      FrmDataModule.ADOQueryLECItemManutencao.Delete;
  end;
end;

