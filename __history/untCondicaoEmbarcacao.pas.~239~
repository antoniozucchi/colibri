procedure TFrmCondicaoEmbarcacao.actGraficoGeralExecute(Sender: TObject);
  var
    SQLBase,Ano,DataProcura,NumEmbarcacaoIndisponivel: String;
    mes,dia,TotalDias,DiasMes: Integer;
    Lista: TStringList;
begin
  GRF2.Checked:= true;
  GRF1.Checked:= false;
  RLEmbarcacao.Visible:= false;
  RLGeral.Visible:= true;
  RLGeral.Align:= alClient;
  Ano:= IntToStr(YearOf(PrimeiroDiaMes));
  FrmPrincipal.ProgressBarIncializa(12,'Gr·fico geral');
  RLGeral.Cells[0,0]:= 'MÍs/Ano';
  RLGeral.Cells[1,0]:= 'Total Dias';
  RLGeral.Cells[33,0]:= 'Dias Perdidos';
  RLGeral.Cells[34,0]:= 'Dias Trab.';
  //InicializaÁ„o
  for mes := 1 to 12 do
    RLGeral.Rows[mes].Clear;
  for dia := 2 to 32 do
    RLGeral.Cells[dia,0]:= IntToStr(dia-1);
  //================================================
  for mes := 1 to 12 do
  begin
    RLGeral.Cells[0,mes]:= IntToStr(mes)+'/'+Ano;
    TotalDias:= 0;
    DiasMes:= DaysInMonth(StrToDate('01/'+FormatFloat('00',mes)+'/'+Ano));
    for dia := 1 to 31 do
    begin
      DataProcura:= FormatFloat('00',dia)+'/'+FormatFloat('00',mes)+'/'+Ano;
      try
        if (StrToDate(DataProcura) <= now) then
        begin
          //=================================================================
          SQLBase:= 'SELECT tblCondicaoEmbarcacao.* FROM tblCondicaoEmbarcacao '+
          'WHERE(DataCondicaoEmbarcacao LIKE '+QuotedStr(DataProcura)+');';
          FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
          FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Text:= SQLBase;
          FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
          NumEmbarcacaoIndisponivel:= FrmDataModule.ADOQueryTemporarioDBConsulta1.
          FieldByName('NumEmbarcacaoIndisponivel').AsString;
          if not FrmDataModule.ADOQueryTemporarioDBConsulta1.IsEmpty then
            RLGeral.Cells[dia+1,mes]:= NumEmbarcacaoIndisponivel
          else
            RLGeral.Cells[dia+1,mes]:= '0';
          //=================================================================
          SQLBase:= 'SELECT tblCondicaoMar.* FROM tblCondicaoMar '+
          'WHERE(DataCondicaoMar LIKE '+QuotedStr(DataProcura)+');';
          FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
          FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Text:= SQLBase;
          FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
          if not FrmDataModule.ADOQueryTemporarioDBConsulta1.IsEmpty then
            RLGeral.Cells[dia+1,mes]:= RLGeral.Cells[dia+1,mes]+';R'
          else
            RLGeral.Cells[dia+1,mes]:= RLGeral.Cells[dia+1,mes]+';B';
          //Contar
          Lista:= FrmPrincipal.incialListaBusca(RLGeral.Cells[dia+1,mes]);
          if ((StrToInt(Lista[0])>0)OR(Lista[1]='R')) then
            TotalDias:= TotalDias+1;
        end;
      except
      end;
    end;
    RLGeral.Cells[1,mes]:= IntToStr(TotalDias);
    RLGeral.Cells[33,mes]:= FormatFloat('0.0%',(TotalDias*100)/DiasMes);
    RLGeral.Cells[34,mes]:= FormatFloat('0.0%',100-(TotalDias*100)/DiasMes);
    FrmPrincipal.ProgressBarIncremento(1);
  end;
  FrmPrincipal.AutoFitGrade(RLGeral);
  FrmPrincipal.ProgressBarAtualizar;
end;

