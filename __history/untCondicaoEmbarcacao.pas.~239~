procedure TFrmCondicaoEmbarcacao.RLEmbarcacaoDrawCell(Sender: TObject; ACol,
  ARow: Integer; Rect: TRect; State: TGridDrawState);
var
  R: TRect;
  DataTeste: TDateTime;
  Numero,DiasMes,DiaColuna: Integer;
begin
  try
    DiaColuna:= StrToInt(RLEmbarcacao.Cells[ACol,0]);
  except
    DiaColuna:= 0;
  end;
  if (ACol>1)AND(ACol<33)AND(ARow>0) then
  begin
    R := Rect;
    R.Left := R.Left - 4;
    Numero:= StrToInt(RLEmbarcacao.Cells[ACol,ARow]);
    try
      DataTeste:= StrToDate(IntToStr(DiaColuna)+'/'+RLEmbarcacao.Cells[0,ARow]);
      DiasMes:= DaysInMonth(DataTeste);
    except
      DiasMes:= 1;
      DataTeste:= now;
    end;
    if (Numero > 0) then
    begin
      RLEmbarcacao.Canvas.Brush.Color := clRed;
      RLEmbarcacao.Canvas.Font.Style := [];
      RLEmbarcacao.Canvas.FillRect(R);
      DrawText(RLEmbarcacao.Canvas.Handle, PChar(RLEmbarcacao.Cells[ACol, ARow]),
      -1, R, DT_Center);
    end
    else if ((Numero = 0)AND(DataTeste>now)OR((Numero = 0)AND((DiaColuna)>DiasMes))) then
    begin
      RLEmbarcacao.Canvas.Brush.Color := clSilver;
      RLEmbarcacao.Canvas.Font.Style := [];
      RLEmbarcacao.Canvas.FillRect(R);
      DrawText(RLEmbarcacao.Canvas.Handle, PChar(RLEmbarcacao.Cells[ACol, ARow]),
      -1, R, DT_Center);
    end
    else if (Numero = 0) then
    begin
      RLEmbarcacao.Canvas.Brush.Color := clLime;
      RLEmbarcacao.Canvas.Font.Style := [];
      RLEmbarcacao.Canvas.FillRect(R);
      DrawText(RLEmbarcacao.Canvas.Handle, PChar(RLEmbarcacao.Cells[ACol, ARow]),
      -1, R, DT_Center);
    end;
  end;
end;

