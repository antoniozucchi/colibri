procedure TFrmCondicaoEmbarcacao.actDadosEmbarcacaoExecute(Sender: TObject);
  var
    SQLBase,Ano: String;
    Mes1,Mes2,Dia,Linha,TotalIndisponivel,Previsto,Indisponivel,
    i,j,DiasMes,NumEmbarcacaoPrevista,NumEmbarcacaoIndisponivel: Integer;
    DataCondicaoEmbarcacao,DataTeste: TDateTime;
    Media,Disponivel: Double;
begin
  GRF2.Checked:= false;
  GRF1.Checked:= true;
  RLEmbarcacao.Visible:= true;
  RLGeral.Visible:= false;
  RLEmbarcacao.Align:= alClient;
  Ano:= IntToStr(YearOf(PrimeiroDiaMes));
  SQLBase:= 'SELECT tblCondicaoEmbarcacao.* FROM tblCondicaoEmbarcacao '+
  'WHERE(Year(DataCondicaoEmbarcacao)='+Ano+') ORDER BY DataCondicaoEmbarcacao;';
  FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Text:= SQLBase;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
  //==================================================================
  CheckListBoxEmbarcacao.Items.Clear;
  Linha:= 1;
  Mes1:= 0;
  RLEmbarcacao.RowCount:= 1;
  RLPrevisto.RowCount:= 1;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.First;
  while not FrmDataModule.ADOQueryTemporarioDBConsulta1.Eof do
  begin
    DataCondicaoEmbarcacao:= FrmDataModule.ADOQueryTemporarioDBConsulta1.
    FieldByName('DataCondicaoEmbarcacao').AsDateTime;
    NumEmbarcacaoPrevista:= FrmDataModule.ADOQueryTemporarioDBConsulta1.
    FieldByName('NumEmbarcacaoPrevista').AsInteger;
    NumEmbarcacaoIndisponivel:= FrmDataModule.ADOQueryTemporarioDBConsulta1.
    FieldByName('NumEmbarcacaoIndisponivel').AsInteger;
    if (NumEmbarcacaoIndisponivel>0) then
    begin
      CheckListBoxEmbarcacao.Items.Add(DateToStr(DataCondicaoEmbarcacao));
      Dia:= DayOf(DataCondicaoEmbarcacao);
      Mes2:= MonthOf(DataCondicaoEmbarcacao);
      if Mes1<>Mes2 then
      begin
        Linha:= RLEmbarcacao.RowCount;
        RLEmbarcacao.RowCount:= RLEmbarcacao.RowCount+1;
        RLPrevisto.RowCount:= RLEmbarcacao.RowCount;
        Ano:= IntToStr(YearOf(DataCondicaoEmbarcacao));
        RLEmbarcacao.Cells[0,Linha]:= IntToStr(Mes2)+'/'+Ano;
        for I := 2 to 33 do
        begin
          RLEmbarcacao.Cells[i,Linha]:= '0';
          RLPrevisto.Cells[i,Linha]:= '0';
        end;
      end;
      RLEmbarcacao.Cells[Dia+1,Linha]:= IntToStr(NumEmbarcacaoIndisponivel+
      StrToInt(RLEmbarcacao.Cells[Dia+1,Linha]));
      RLPrevisto.Cells[Dia+1,Linha]:= IntToStr(NumEmbarcacaoPrevista);
      Mes1:= Mes2;
    end;
    FrmDataModule.ADOQueryTemporarioDBConsulta1.Next;
  end;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.First;
  //===========================================================
  for j := 1 to RLEmbarcacao.RowCount-1 do
  begin
    TotalIndisponivel:= 0;
    Media:= 0;
    DataTeste:= StrToDate('1/'+RLEmbarcacao.Cells[0,j]);
    DiasMes:= DaysInMonth(DataTeste);
    if ((MonthOf(now) = MonthOf(DataTeste))AND(YearOf(now) = YearOf(DataTeste))) then
      DiasMes:= DayOf(now);
    for I := 2 to DiasMes+1 do
    begin
      Indisponivel:= StrToInt(RLEmbarcacao.Cells[i,j]);
      Previsto:= StrToInt(RLPrevisto.Cells[i,j]);
      Disponivel:= Previsto-Indisponivel;
      if (Disponivel = 0)AND(Indisponivel=0) then
        Disponivel:= 100
      else
        Disponivel:= (Disponivel*100)/Previsto;
      Media:= Media+Disponivel;
      TotalIndisponivel:= TotalIndisponivel+Indisponivel;
    end;
    RLEmbarcacao.Cells[1,j]:= IntToStr(TotalIndisponivel);
    RLEmbarcacao.Cells[33,j]:= FormatFloat('0.00%',Media/DiasMes);
    RLEmbarcacao.Cells[34,j]:= FormatFloat('0.00%',100-(Media/DiasMes));
  end;
  CalendarioEmbarcacao.Repaint;
end;

procedure TFrmCondicaoEmbarcacao.actDadosMarExecute(Sender: TObject);
  var
    SQLBase,Ano: String;
    Mes1,Mes2,Dia,Linha,TotalDias,i,j,DiasMes: Integer;
    DataCondicaoMar,DataTeste: TDateTime;
begin
  Ano:= IntToStr(YearOf(PrimeiroDiaMes));
  SQLBase:= 'SELECT tblCondicaoMar.* FROM tblCondicaoMar '+
  'WHERE(Year(DataCondicaoMar)='+Ano+') ORDER BY DataCondicaoMar;';
  FrmDataModule.ADOQueryTemporarioDBConsulta1.Close;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.SQL.Text:= SQLBase;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.Open;
  //=========================================================
  CheckListBoxMar.Items.Clear;
  Linha:= 1;
  Mes1:= 0;
  RLMar.RowCount:= 1;
  FrmDataModule.ADOQueryTemporarioDBConsulta1.First;
  while not FrmDataModule.ADOQueryTemporarioDBConsulta1.Eof do
  begin
    DataCondicaoMar:= FrmDataModule.ADOQueryTemporarioDBConsulta1.FieldByName('DataCondicaoMar').AsDateTime;
    CheckListBoxMar.Items.Add(DateToStr(DataCondicaoMar));
    Dia:= DayOf(DataCondicaoMar);
    Mes2:= MonthOf(DataCondicaoMar);
    if Mes1<>Mes2 then
    begin
      Linha:= RLMar.RowCount;
      RLMar.RowCount:= RLMar.RowCount+1;
      Ano:= IntToStr(YearOf(DataCondicaoMar));
      RLMar.Cells[0,Linha]:= IntToStr(Mes2)+'/'+Ano;
      for I := 2 to 33 do
        RLMar.Cells[i,Linha]:= '0';
    end;
    RLMar.Cells[Dia+1,Linha]:= '1';
    Mes1:= Mes2;
    FrmDataModule.ADOQueryTemporarioDBConsulta1.Next;
  end;
  //=======================================================
  for j := 1 to RLMar.RowCount-1 do
  begin
    TotalDias:= 0;
    for I := 2 to 32 do
    begin
      TotalDias:= TotalDias+StrToInt(RLMar.Cells[i,j]);
    end;
    DataTeste:= StrToDate('1/'+RLMar.Cells[0,j]);
    DiasMes:= DaysInMonth(DataTeste);
    if MonthOf(now) = MonthOf(DataTeste) then
      DiasMes:= DayOf(now);
    RLMar.Cells[1,j]:= IntToStr(TotalDias);
    RLMar.Cells[33,j]:= FormatFloat('0.0%',(TotalDias*100)/DiasMes);
    RLMar.Cells[34,j]:= FormatFloat('0.0%',100-(TotalDias*100)/DiasMes);
  end;
  CalendarMar.Repaint;
end;

