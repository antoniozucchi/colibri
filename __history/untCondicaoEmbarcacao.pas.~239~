procedure TFrmCondicaoEmbarcacao.actSelLimparEmbarcacaoExecute(Sender: TObject);
var
  I: Integer;
  txtString: String;
begin
  for I := 0 to CheckListBoxEmbarcacao.Count-1 do
    CheckListBoxEmbarcacao.Checked[i]:= false;
  //Filtro Check-list
  txtString:= '';
  for i := 0 to CheckListBoxEmbarcacao.Items.Count-1 do
  begin
    if CheckListBoxEmbarcacao.Checked[i] then
